  "content": "<!-- ========= DOTACE – DIGI PRO FIRMY (ELEMENTOR HTML WIDGET) v6 ========= -->\n<style>\n/* ===== tokens & layout ===== */\n#digi-pro-firmu{\n  --brand:#5075ff;--brand-2:#4c6ef5;--text:#111827;--text-light:#6b7280;--bg:#f8fafc;--surface:#fff;--line:#e5e7eb;--success:#10b981;\n  --radius-lg:16px;--radius:12px;--shadow-lg:0 12px 36px rgba(80,117,255,.17);--shadow:0 4px 16px rgba(0,0,0,.08);\n  --h1:clamp(2.6rem,4.6vw,4rem);--h2:clamp(2rem,3.6vw,3rem);--h3:clamp(1.3rem,2.2vw,1.7rem);--lead:1.125rem;--body:1.04rem;\n  --space-xs:8px;--space-sm:16px;--space-md:24px;--space-lg:32px;--space-xl:48px;--space-2xl:64px;--space-3xl:96px;\n  font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;color:var(--text);line-height:1.6;margin:0 auto;max-width:100%;\n  padding:var(--space-md);font-size:var(--body);background:var(--bg)\n}\n#digi-pro-firmu .page-wrap{max-width:1120px;margin:0 auto}\n#digi-pro-firmu h1,#digi-pro-firmu h2,#digi-pro-firmu h3{line-height:1.22!important;font-weight:800!important;margin:0 0 var(--space-sm)!important}\n#digi-pro-firmu p,#digi-pro-firmu li{margin:0 0 var(--space-sm)!important;font-size:var(--body)!important}\n#digi-pro-firmu .section{margin-bottom:var(--space-3xl)}\n#digi-pro-firmu .section-header{text-align:center;margin-bottom:var(--space-xl)}\n#digi-pro-firmu .section-header .subtitle{color:var(--text-light);font-size:calc(var(--lead)*1.02);font-weight:600;max-width:900px;margin:0 auto var(--space-md)!important;line-height:1.5;text-align:center!important}\n#digi-pro-firmu .section-divider{width:92px;height:4px;background:var(--brand);border:none;border-radius:2px;margin:var(--space-sm) auto var(--space-lg)}\n#digi-pro-firmu .container{max-width:1100px;margin:0 auto;padding:0 var(--space-md)}\n#digi-pro-firmu .container-narrow{max-width:900px;margin:0 auto;padding:0 var(--space-md)}\n#digi-pro-firmu .grid{display:grid;gap:var(--space-lg)}\n#digi-pro-firmu .grid-3{grid-template-columns:repeat(3,1fr)}\n#digi-pro-firmu .grid-2{grid-template-columns:repeat(2,1fr)}\n@media (max-width:992px){#digi-pro-firmu .grid-3,#digi-pro-firmu .grid-2{grid-template-columns:1fr}}\n#digi-pro-firmu .card{background:#fff;border:1px solid var(--line);border-radius:var(--radius-lg);padding:var(--space-lg);box-shadow:var(--shadow);text-align:center}\n/* ===== buttons (větší rozestupy nad/po) ===== */\n#digi-pro-firmu .btn{display:inline-block;padding:14px 22px;border:2px solid transparent;border-radius:12px;text-decoration:none;font-weight:800;\n  font-size:var(--body);line-height:1.2;transition:.2s;cursor:pointer;box-shadow:var(--shadow);white-space:nowrap}\n#digi-pro-firmu .btn-primary{background:var(--brand);color:#fff;border-color:var(--brand)}\n#digi-pro-firmu .btn-primary:hover{background:var(--brand-2);border-color:var(--brand-2);transform:translateY(-2px)}\n#digi-pro-firmu .btn-white{background:#fff;color:var(--brand);border-color:#fff}\n#digi-pro-firmu .btn-white:hover{background:#f1f5f9}\n#digi-pro-firmu .btn-outline-white{background:transparent;color:#fff;border-color:#fff}\n#digi-pro-firmu .btn-outline-white:hover{background:#fff;color:var(--brand);transform:translateY(-2px)}\n#digi-pro-firmu .btn-group{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:22px;margin-bottom:8px}\n/* ===== hero ===== */\n#digi-pro-firmu .hero{\n  background:linear-gradient(135deg,var(--brand) 0%,var(--brand-2) 100%);color:#fff;border-radius:20px;text-align:center;box-shadow:var(--shadow-lg);\n  padding:72px 28px;margin:0 auto var(--space-lg);max-width:1280px\n}\n#digi-pro-firmu .hero .badge{display:inline-block;background:rgba(255,255,255,.12);color:#fff;padding:6px 12px;border-radius:999px;font-size:.8rem;font-weight:900;letter-spacing:.3px;text-transform:uppercase;margin-bottom:14px;border:1px solid rgba(255,255,255,.2)}\n#digi-pro-firmu .hero h1{color:#fff;font-size:var(--h1)!important;margin-bottom:10px!important}\n#digi-pro-firmu .hero .subtitle{font-size:clamp(1.08rem,2.2vw,1.35rem)!important;font-weight:800;margin:0 auto 10px;opacity:.98;max-width:880px}\n/* >>> pevné centrování dvou vět v hero <<< */\n#digi-pro-firmu .hero .subtitle,\n#digi-pro-firmu .hero .kicker{\n  text-align:center!important;\n  margin-left:auto!important;\n  margin-right:auto!important;\n  display:block!important;\n  width:100%!important;        /* pro případy, kdy Elementor vnutí inline šířku */\n}\n#digi-pro-firmu .hero .kicker{font-size:1.02rem;opacity:.95;margin:0 auto 10px;max-width:820px}\n/* ===== info box (větší top/bottom mezera) ===== */\n#digi-pro-firmu .blue-info-box{background:linear-gradient(135deg,#f0f4ff 0%,#e8f0fe 100%);border:2px solid rgba(80,117,255,.25);border-radius:20px;\n  padding:calc(var(--space-lg) + 6px);text-align:center;box-shadow:0 6px 20px rgba(80,117,255,.12);position:relative;max-width:880px;margin:calc(var(--space-xl) + 8px) auto var(--space-xl)}\n#digi-pro-firmu .blue-info-box::before{content:\"\";position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--brand) 0%,#818cf8 100%);border-radius:20px 20px 0 0}\n/* ===== 2-sloupcový seznam školení ===== */\n#digi-pro-firmu .training-list{max-width:820px;margin:0 auto}\n#digi-pro-firmu .training-list ul{list-style:disc;padding-left:22px;margin:0 auto}\n#digi-pro-firmu .training-two{columns:2;column-gap:42px}\n#digi-pro-firmu .training-two li{break-inside:avoid;margin-bottom:10px}\n@media (max-width:820px){#digi-pro-firmu .training-two{columns:1}}\n/* ===== FAQ ===== */\n#digi-pro-firmu .faq{background:#fff;border:1px solid var(--line);border-radius:20px;padding:var(--space-xl);box-shadow:var(--shadow)}\n#digi-pro-firmu .faq-item{border:1px solid var(--line);border-radius:14px;margin-bottom:var(--space-md);overflow:hidden;background:#f8fafc}\n#digi-pro-firmu .faq-question{width:100%;background:#f3f6fb;border:none;text-align:left;font-size:1.05rem;font-weight:900;color:var(--text);\n  padding:16px 20px;cursor:pointer;display:flex;justify-content:space-between;align-items:center}\n#digi-pro-firmu .faq-question:hover,#digi-pro-firmu .faq-question[aria-expanded=\"true\"]{background:#e9eef8;color:var(--brand)}\n#digi-pro-firmu .faq-answer{background:#fff;padding:0 20px;max-height:0;overflow:hidden;border-top:1px solid var(--line);opacity:0;transition:max-height .2s ease,opacity .2s ease}\n#digi-pro-firmu .faq-answer.open{padding:16px 20px;opacity:1;max-height:560px}\n#digi-pro-firmu .faq-icon{color:var(--brand);font-size:1.4rem}\n/* ===== process cards ===== */\n#digi-pro-firmu .process{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;max-width:980px;margin:0 auto}\n#digi-pro-firmu .p-card{background:#fff;border:1px solid var(--line);border-radius:16px;padding:18px;text-align:left;box-shadow:var(--shadow);position:relative}\n#digi-pro-firmu .p-card .num{position:absolute;top:-10px;left:-10px;width:36px;height:36px;border-radius:50%;background:var(--brand);color:#fff;font-weight:900;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 18px rgba(80,117,255,.35)}\n#digi-pro-firmu .p-card .title{font-weight:900;margin:6px 0 4px;font-size:1.02rem}\n#digi-pro-firmu .p-card .desc{color:var(--text-light);margin:0}\n@media (max-width:960px){#digi-pro-firmu .process{grid-template-columns:1fr}}\n/* ===== CTA ===== */\n#digi-pro-firmu .cta{background:linear-gradient(135deg,var(--brand) 0%,var(--brand-2) 100%);color:#fff;padding:var(--space-2xl) var(--space-lg);border-radius:20px;text-align:center;box-shadow:var(--shadow-lg);max-width:1280px;margin:0 auto}\n#digi-pro-firmu .cta h2{margin-bottom:var(--space-sm);color:#fff;font-size:clamp(1.8rem,3vw,2.5rem)}\n#digi-pro-firmu .cta .description{font-size:var(--lead);margin-bottom:var(--space-lg);opacity:.95;max-width:820px;margin-left:auto;margin-right:auto;text-align:center}\n@media (max-width:768px){#digi-pro-firmu{padding:var(--space-sm)}#digi-pro-firmu .hero{padding:56px 20px}#digi-pro-firmu h1{font-size:clamp(2.1rem,7vw,2.6rem)}#digi-pro-firmu .faq{padding:var(--space-lg)}}\n</style>\n<!-- ===== HERO ===== -->\n<section>\n  DIGI pro firmy\n  <h1>Dotace na školení AI – DIGI pro firmy</h1>\n  <p>Získejte až 137 000 Kč na jedno firemní školení AI.</p>\n  <p>Typické dvoudenní školení pro 16 lidí můžete mít díky dotaci téměř bez nákladů.</p>\n    <a href=\"#kolik\">Kolik můžeme získat</a>\n    <a href=\"#jak\">Jak to probíhá</a>\n</section>\n<!-- ===== KOLIK MŮŽETE ZÍSKAT ===== -->\n<section id=\"kolik\">\n    <h2>Kolik můžete získat</h2>\n    <hr>\n    <p>Přehledná částka za celé školení. Detail výpočtu najdete níže.</p>\n      <!-- Hlavní sdělení největším písmem -->\n      <h3 id=\"sum-title\" style=\"font-size:clamp(1.4rem,2.4vw,1.7rem);margin-bottom:8px\">Až 137 000 Kč z dotace na jedno školení AI</h3>\n      <!-- Výpočet až pod tím -->\n      <p style=\"margin-top:6px;\">Příklad: 16 účastníků × 16 hodin (2 dny) při čerpání příspěvku na školení i mzdy.</p>\n      <p style=\"font-size:.98rem;color:#0f172a;margin-top:6px\">Čerpáte-li pouze příspěvek na školení (bez mezd), je to cca <strong>67 000 Kč</strong> za stejné školení.</p>\n    <p style=\"text-align:center;color:var(--text-light);max-width:880px;margin:var(--space-md) auto 0\">\n      <small>Mzdový příspěvek lze čerpat na zaměstnance v pracovním poměru (HPP/DPČ) u subjektů, které mzdy nehradí z veřejných rozpočtů. Veřejná správa a příspěvkové organizace mzdový příspěvek nečerpají (mají nárok pouze na příspěvek na školení). OSVČ a DPP také čerpají pouze příspěvek na školení. Proplácí se zpětně po doložení účasti a mezd.</small>\n    </p>\n      <a href=\"https://pavelkovarik.cz/skoleni/\" rel=\"noopener\">Podívat se na školení</a>\n</section>\n<!-- ===== PRO KOHO ===== -->\n<section id=\"pro-koho\">\n    <h2>Pro koho je dotace vhodná</h2>\n    <hr>\n    <p>Malé, střední i velké firmy. HR, administrativa, obchod, marketing i vedení.</p>\n        <h3>Firmy a organizace</h3>\n        <p>Soukromé společnosti, obce, kraje, příspěvkové organizace (u těch bez mzdy).</p>\n        <h3>Zaměstnanci na HPP/DPČ</h3>\n        <p>Plné čerpání: školení + mzdový příspěvek (mimo veřejnou správu/příspěvky).</p>\n        <h3>OSVČ a DPP</h3>\n        <p>Příspěvek pouze na školení. Mzdový příspěvek se nevztahuje.</p>\n</section>\n<!-- ===== JAK TO PROBÍHÁ ===== -->\n<section id=\"jak\">\n    <h2>Jak to probíhá</h2>\n    <hr>\n    <p>Vysvětlím postup a připravím vám podklady. Administraci si držíte vy.</p>\n        1\n        Krátká konzultace (15 min)\n        <p>Zjistíme cíle, počet lidí a vhodný formát (prezenčně/online).</p>\n        2\n        Podání žádosti\n        <p>Dám přesné instrukce, co vyplnit a kam poslat. Připravím osnovu.</p>\n        3\n        Školení\n        <p>Proběhne v pracovní dny, živě a s evidencí osobohodin.</p>\n        4\n        Proplacení\n        <p>Po doložení prezenční listiny, faktury a mezd (pokud čerpáte mzdu) úřad dotaci proplatí.</p>\n      <a href=\"https://pavelkovarik.cz/kontakt/\" rel=\"noopener\">Nezávazná konzultace</a>\n</section>\n<!-- ===== ŠKOLENÍ (2 sloupce, odrážky) ===== -->\n<section id=\"skoleni\">\n    <h2>Jaká školení nabízím v rámci dotace</h2>\n    <hr>\n    <p>Obsah upravím podle vašeho oboru a úrovně týmu.</p>\n    <ul>\n      <li><a href=\"https://pavelkovarik.cz/prakticke-skoleni-ai-pro-firmy/\" style=\"text-decoration:underline;color:var(--brand)\">Základy AI pro firmy</a></li>\n      <li><a href=\"https://pavelkovarik.cz/microsoft-copilot-pro-firmy/\" style=\"text-decoration:underline;color:var(--brand)\">Microsoft Copilot v praxi</a></li>\n      <li><a href=\"https://pavelkovarik.cz/marketing-pr-s-ai/\" style=\"text-decoration:underline;color:var(--brand)\">AI v marketingu</a></li>\n      <li><a href=\"https://pavelkovarik.cz/ai-pro-verejnou-spravu/\" style=\"text-decoration:underline;color:var(--brand)\">AI pro veřejnou správu</a></li>\n      <li><a href=\"https://pavelkovarik.cz/linkedin-byznys-osobni-znacka-ai/\" style=\"text-decoration:underline;color:var(--brand)\">LinkedIn s AI pro byznys</a></li>\n      <li><a href=\"https://pavelkovarik.cz/skoleni-na-miru/\" style=\"text-decoration:underline;color:var(--brand)\">Školení na míru</a></li>\n    </ul>\n      <a href=\"https://pavelkovarik.cz/skoleni/\" rel=\"noopener\">Podívat se na školení</a>\n</section>\n<!-- ===== FAQ ===== -->\n<section id=\"faq\">\n    <h2>Často kladené otázky</h2>\n    <hr>\n      <button aria-expanded=\"false\">\n        Jaké jsou sazby a limity?\n      </button>\n        <p>263,98 Kč/osobohodina (školení) a 272,13 Kč/osobohodina (mzda). Maximálně 80 osobohodin na účastníka.</p>\n      <button aria-expanded=\"false\">\n        Kolik lze získat na jednoho zaměstnance?\n      </button>\n        <p>Až 42 888 Kč na osobu při rozsahu 80 osobohodin. Celkový rozpočet propočítáme předem podle počtu lidí a délky kurzu.</p>\n      <button aria-expanded=\"false\">\n        Mohou dotaci čerpat i města, veřejná správa a příspěvkové organizace?\n      </button>\n        <p>Ano, ale pouze příspěvek na školení. Mzdový příspěvek se na veřejnou správu a příspěvkové organizace nevztahuje.</p>\n      <button aria-expanded=\"false\">\n        Kdo má nárok na mzdový příspěvek?\n      </button>\n        <p>Zaměstnanci v pracovním poměru (HPP/DPČ) u subjektů, které mzdy nehradí z veřejných rozpočtů. OSVČ a DPP mohou čerpat pouze příspěvek na školení.</p>\n      <button aria-expanded=\"false\">\n        Může být školení online?\n      </button>\n        <p>Ano, pokud probíhá živě v reálném čase a je řádně evidované. Prezenční forma je také možná.</p>\n    <p style=\"margin-top:var(--space-md);color:var(--text-light);font-size:.95rem\">\n      <small>Informace na této stránce vycházejí z oficiálních podmínek programu platných k 2. 4. 2025.</small>\n    </p>\n</section>\n<!-- ===== CTA ===== -->\n<section id=\"kontakt\">\n    <h2>Pojďme spočítat, na co dosáhnete</h2>\n    <p>Během 15 minut si řekneme rozsah školení a jakou podporu lze čerpat.</p>\n      <a href=\"https://pavelkovarik.cz/kontakt/\" rel=\"noopener\">Nezávazná konzultace</a>\n      <a href=\"https://pavelkovarik.cz/skoleni/\">Podívat se na školení</a>\n</section>\n<!-- /page-wrap -->\n<!-- Font Awesome (ikony) -->\n<link rel=\"preconnect\" href=\"https://cdnjs.cloudflare.com\" crossorigin>\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\" crossorigin=\"anonymous\" referrerpolicy=\"no-referrer\"/>"
}