  "content": "<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css\">\n<style>\n/* ==================== DESIGN SYSTEM ==================== */\n#kontakt-final-v10 {\n  --brand: #3d5cd9;\n  --brand-dark: #2a49c7;\n  --text: #1f2937;\n  --text-light: #4b5563;\n  --bg: #f8fafc;\n  --surface: #ffffff;\n  --line: #e5e7eb;\n  --radius-lg: 16px;\n  --radius-md: 12px;\n  --shadow: 0 4px 16px rgba(0,0,0,0.08);\n  --shadow-lg: 0 12px 36px rgba(61,92,217,0.15);\n  font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;\n  color: var(--text);\n  line-height: 1.6;\n  width: 100%;\n  overflow-x: clip;\n}\n/* SKRYTÍ GOOGLE RECAPTCHA IKONY (Pro jistotu i zde) */\n.grecaptcha-badge { \n    visibility: hidden !important; \n}\n/* === FULL WIDTH UTILITY === */\n.full-bleed {\n  width: 100vw;\n  position: relative;\n  left: 50%;\n  right: 50%;\n  margin-left: -50vw;\n  margin-right: -50vw;\n}\n#kontakt-final-v10 .container {\n  max-width: 1100px;\n  margin: 0 auto;\n  padding: 0 24px;\n  position: relative;\n  z-index: 5;\n}\n/* TYPOGRAFIE */\n#kontakt-final-v10 h1, #kontakt-final-v10 h2, #kontakt-final-v10 h3 {\n  font-weight: 800 !important;\n  color: var(--text);\n  margin-top: 0;\n  line-height: 1.25;\n}\n#kontakt-final-v10 h1 { font-size: 2.8rem; color: #fff !important; margin-bottom: 1.5rem !important; }\n#kontakt-final-v10 h2 { font-size: 2rem; text-align: center; margin-bottom: 1rem !important; }\n#kontakt-final-v10 h3 { font-size: 1.25rem; margin-bottom: 0.5rem !important; }\n/* === BUTTONS === */\n#kontakt-final-v10 .btn {\n  display: inline-flex !important;\n  align-items: center !important;\n  justify-content: center !important;\n  min-width: 200px !important;\n  height: 52px !important;\n  padding: 0 32px !important;\n  border-radius: var(--radius-md) !important;\n  font-weight: 700 !important;\n  text-decoration: none !important;\n  font-size: 1rem !important;\n  border: 2px solid transparent !important;\n  cursor: pointer !important;\n  transition: all 0.3s ease !important;\n}\n#kontakt-final-v10 .btn-white {\n  background: #fff !important;\n  color: var(--brand) !important;\n  box-shadow: var(--shadow);\n}\n#kontakt-final-v10 .btn-white:hover {\n  background: #f1f5f9 !important;\n  transform: translateY(-2px);\n  box-shadow: 0 8px 20px rgba(0,0,0,0.12);\n}\n#kontakt-final-v10 .btn-primary {\n  background: var(--brand) !important;\n  color: #fff !important;\n}\n#kontakt-final-v10 .btn-primary:hover {\n  background: var(--brand-dark) !important;\n  transform: translateY(-2px);\n}\n/* === HERO SEKCE === */\n#kontakt-final-v10 .hero {\n  background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%) !important;\n  color: #fff !important;\n  text-align: center;\n  padding: 80px 24px 140px 24px;\n  margin-top: -50px;\n}\n#kontakt-final-v10 .hero-lead {\n  font-size: 1.2rem;\n  max-width: 700px;\n  margin: 0 auto 2rem;\n  opacity: 0.95;\n  color: #fff !important;\n}\n#kontakt-final-v10 .hero-stats {\n  display: flex;\n  justify-content: center;\n  gap: 15px;\n  flex-wrap: wrap;\n  margin-top: 2rem;\n}\n#kontakt-final-v10 .stat-pill {\n  background: rgba(255,255,255,0.15);\n  padding: 8px 20px;\n  border-radius: 50px;\n  font-size: 0.95rem;\n  font-weight: 600;\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  color: #fff;\n  border: 1px solid rgba(255,255,255,0.2);\n}\n/* === GRID KARET === */\n#kontakt-final-v10 .cards-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 30px;\n  margin-top: -80px; \n  margin-bottom: 60px;\n  position: relative;\n  z-index: 10;\n}\n#kontakt-final-v10 .contact-card {\n  background: #fff;\n  border-radius: var(--radius-lg);\n  padding: 40px 30px;\n  text-align: center;\n  box-shadow: var(--shadow-lg);\n  border: 1px solid var(--line);\n  transition: transform 0.3s ease, box-shadow 0.3s ease;\n}\n#kontakt-final-v10 .contact-card:hover {\n  transform: translateY(-5px);\n  box-shadow: 0 20px 40px rgba(61,92,217,0.2);\n}\n#kontakt-final-v10 .card-icon {\n  width: 70px;\n  height: 70px;\n  background: linear-gradient(135deg, #f0f4ff 0%, #e8f0fe 100%);\n  color: var(--brand);\n  border-radius: 20px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 1.8rem;\n  margin: 0 auto 25px;\n}\n#kontakt-final-v10 .card-meta { font-size: 0.9rem; color: var(--text-light); margin-top: 15px; }\n/* === FORMULÁŘ === */\n#kontakt-final-v10 .pk-cf7-wrapper {\n  max-width: 900px;\n  margin: 0 auto;\n  padding: 40px;\n  background: #fff;\n  border: 1px solid var(--line);\n  border-radius: var(--radius-lg);\n  box-shadow: 0 4px 20px rgba(0,0,0,0.05);\n}\n#kontakt-final-v10 .pk-form-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 24px;\n}\n#kontakt-final-v10 .pk-field-full { grid-column: span 2; }\n#kontakt-final-v10 .pk-label {\n  display: block;\n  font-weight: 700;\n  margin-bottom: 8px;\n  color: var(--text);\n  font-size: 0.95rem;\n}\n#kontakt-final-v10 .pk-req { display: none; }\n#kontakt-final-v10 input[type=\"text\"],\n#kontakt-final-v10 input[type=\"email\"],\n#kontakt-final-v10 input[type=\"tel\"],\n#kontakt-final-v10 select,\n#kontakt-final-v10 textarea {\n  width: 100%;\n  max-width: 100%;\n  padding: 14px 16px;\n  border: 1px solid #d1d5db;\n  border-radius: 10px;\n  font-size: 1rem;\n  font-family: inherit;\n  background: #f9fafb;\n  transition: border-color 0.2s, background 0.2s;\n  box-sizing: border-box;\n}\n#kontakt-final-v10 input:focus,\n#kontakt-final-v10 select:focus,\n#kontakt-final-v10 textarea:focus {\n  border-color: var(--brand);\n  background: #fff;\n  outline: none;\n  box-shadow: 0 0 0 4px rgba(61,92,217,0.1);\n}\n/* === TLAČÍTKO + LOADING (NEPRŮSTŘELNÉ) === */\n#kontakt-final-v10 .pk-submit-wrapper {\n    position: relative;\n    width: 100%;\n}\n/* Základní vzhled */\n#kontakt-final-v10 .pk-submit-btn {\n  background-color: var(--brand) !important;\n  color: #fff !important;\n  font-weight: 700;\n  font-size: 1.1rem;\n  padding: 16px 32px;\n  border: none !important;\n  border-radius: 10px;\n  cursor: pointer;\n  width: 100%;\n  transition: all 0.3s;\n  opacity: 1 !important;\n  height: auto;\n  min-height: 54px;\n  display: block;\n}\n#kontakt-final-v10 .pk-submit-btn:hover {\n  background-color: var(--brand-dark) !important;\n  transform: translateY(-2px);\n}\n/* STAV: ODESÍLÁNÍ / DISABLED / SUBMITTING */\n#kontakt-final-v10 form.submitting .pk-submit-btn,\n#kontakt-final-v10 form.wpcf7-submitting .pk-submit-btn,\n#kontakt-final-v10 .pk-submit-btn:disabled {\n  background-color: var(--brand) !important;\n  color: transparent !important;\n  cursor: wait !important;\n  transform: none !important;\n  opacity: 1 !important;\n}\n/* Vytvoření SPINNERU */\n#kontakt-final-v10 form.submitting .pk-submit-wrapper::after,\n#kontakt-final-v10 form.wpcf7-submitting .pk-submit-wrapper::after {\n  content: \"\";\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  width: 26px;\n  height: 26px;\n  margin-top: -13px;\n  margin-left: -13px;\n  border: 4px solid rgba(255,255,255,0.4);\n  border-top-color: #fff;\n  border-radius: 50%;\n  animation: pk-spin 0.8s linear infinite;\n  display: block;\n  z-index: 20;\n  pointer-events: none;\n}\n@keyframes pk-spin {\n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n/* Skrytí defaultních spinnerů a hlášek */\n#kontakt-final-v10 .wpcf7-spinner { display: none !important; }\n#kontakt-final-v10 div.wpcf7-response-output { display: none !important; }\n/* Checkboxy */\n#kontakt-final-v10 .pk-checklist .wpcf7-list-item { display: block; margin: 0 0 10px 0; }\n#kontakt-final-v10 .pk-checklist input[type=\"checkbox\"] { width: 18px; height: 18px; margin-right: 10px; accent-color: var(--brand); }\n/* === POPUP MODALS === */\n.pk-modal {\n  display: none;\n  position: fixed;\n  z-index: 99999;\n  left: 0;\n  top: 0;\n  width: 100%;\n  height: 100%;\n  background-color: rgba(0,0,0,0.6);\n  backdrop-filter: blur(5px);\n  align-items: center;\n  justify-content: center;\n}\n.pk-modal-content {\n  background-color: #fff;\n  padding: 40px;\n  border-radius: 16px;\n  text-align: center;\n  max-width: 450px;\n  width: 90%;\n  position: relative;\n  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);\n  animation: modalFadeIn 0.3s ease-out;\n}\n@keyframes modalFadeIn {\n  from {opacity: 0; transform: translateY(20px);}\n  to {opacity: 1; transform: translateY(0);}\n}\n.pk-modal h3 { font-size: 1.6rem; margin-bottom: 10px; }\n.pk-modal p { font-size: 1.05rem; color: #4b5563; margin-bottom: 25px; }\n.pk-modal-icon { font-size: 3.5rem; margin-bottom: 20px; display: block; }\n#pkSuccessModal h3 { color: #10b981; }\n#pkSuccessModal .pk-modal-icon { color: #10b981; }\n#pkErrorModal h3 { color: #ef4444; }\n#pkErrorModal .pk-modal-icon { color: #ef4444; }\n/* === CTA SECTION === */\n#kontakt-final-v10 .cta-final {\n  background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%) !important;\n  color: #fff !important;\n  padding: 80px 24px;\n  text-align: center;\n  margin-top: 20px;\n  margin-bottom: -5px; \n  padding-bottom: 85px; \n}\n#kontakt-final-v10 .cta-final h2 { color: #fff !important; font-size: 1.8rem !important; }\n#kontakt-final-v10 .cta-final p { color: rgba(255,255,255,0.9) !important; font-size: 1.1rem; margin-bottom: 2rem; }\n/* === RESPONZIVITA === */\n@media (max-width: 900px) {\n  #kontakt-final-v10 .cards-grid { grid-template-columns: 1fr; gap: 20px; margin-top: -40px; }\n  #kontakt-final-v10 .pk-form-grid { grid-template-columns: 1fr; }\n  #kontakt-final-v10 .pk-field-full { grid-column: span 1; }\n  #kontakt-final-v10 .pk-cf7-wrapper { padding: 20px; }\n  #kontakt-final-v10 .container { padding: 0 16px; }\n}\n</style>\n<section>\n    KONTAKT\n    <h1>Kontakt a poptávka školení</h1>\n    <p>\n      Do 24 hodin se Vám ozvu s návrhem obsahu školení a možnými termíny.\n    </p>\n       Odpověď do 24 hodin\n       On-line i u vás ve firmě\n       Nezávazná poptávka\n</section>\n      <h3>Zavolejte mi</h3>\n      <p style=\"margin-bottom:20px; color:var(--text-light);\">Nejrychlejší cesta pro domluvu termínu nebo rychlý dotaz.</p>\n      <a href=\"tel:+420770126519\">+420 770 126 519</a>\n      Po-Pá 9:00 - 17:00\n      <h3>Napište e-mail</h3>\n      <p style=\"margin-bottom:20px; color:var(--text-light);\">Preferujete písemnou komunikaci? Napište mi své požadavky.</p>\n      <a href=\"mailto:mail@pavelkovarik.cz\">mail@pavelkovarik.cz</a>\n      Odpovídám do 24 hodin\n      <h3>Spojme se</h3>\n      <p style=\"margin-bottom:20px; color:var(--text-light);\">Sledujte novinky ze světa AI nebo mi napište zprávu přímo tam.</p>\n      <a href=\"https://www.linkedin.com/in/pkovarik/\" target=\"_blank\">Profil LinkedIn</a>\n      Profesní síť\n      <h2>Nezávazná poptávka školení AI</h2>\n      <p style=\"color:var(--text-light);\">Stačí stručně. Detaily doladíme později.</p>\n    [contact-form-7 id=\"bb380a0\" title=\"Objednávka školení\"]\n    <strong>Fakturační údaje:</strong> Ing. Bc. Pavel Kovařík, IČO: 76233006, Hromádkova 4020/22, 636 00 Brno\n<section>\n    <h2>Nenašli jste, co hledáte?</h2>\n    <p>Podívejte se na kompletní přehled školení, která nabízím.</p>\n    <a href=\"/skoleni/\">Zobrazit nabídku školení</a>\n</section>\n    <h3>Odesláno!</h3>\n    <p>Díky! Vaši objednávku jsem obdržel.<br>Ozvu se vám do 24 hodin.</p>\n    <button onclick=\"closePkModal('pkSuccessModal')\">Skvělé, zavřít</button>\n    <h3>Chybí údaje</h3>\n    <p>Zkontrolujte prosím formulář. Některá povinná pole nejsou vyplněna.</p>\n    <button onclick=\"closePkModal('pkErrorModal')\">Zkontrolovat formulář</button>"
}