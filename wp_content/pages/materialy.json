  "content": "<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css\">\n<style>\n/* ==================== DESIGN SYSTEM (Podle \"O mně\") ==================== */\n#materialy-hub {\n  --brand: #3d5cd9;\n  --brand-dark: #2a49c7;\n  --text: #1f2937;\n  --text-light: #4b5563;\n  --bg: #f8fafc;\n  --surface: #ffffff;\n  --line: #e5e7eb;\n  --radius-lg: 16px;\n  --radius-md: 12px;\n  --shadow: 0 4px 16px rgba(0,0,0,0.08);\n  --shadow-lg: 0 12px 36px rgba(61,92,217,0.15);\n  font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;\n  color: var(--text);\n  line-height: 1.6;\n  max-width: 100%;\n  margin: 0 auto;\n  background: var(--bg);\n  -webkit-font-smoothing: antialiased;\n}\n#materialy-hub .container {\n  max-width: 1000px;\n  margin: 0 auto;\n  padding: 0 24px;\n}\n/* TYPOGRAFIE */\n#materialy-hub h1,\n#materialy-hub h2,\n#materialy-hub h3 {\n  line-height: 1.25 !important;\n  font-weight: 800 !important;\n  margin-bottom: 1rem !important;\n  color: var(--text);\n}\n#materialy-hub h1 {\n  font-size: 2.5rem;\n  color: #fff !important;\n}\n#materialy-hub h2 {\n  font-size: 1.9rem;\n  text-align: center;\n  margin-bottom: 1.5rem !important;\n}\n#materialy-hub h3 {\n  font-size: 1.5rem; /* Větší nadpis pro karty materiálů */\n}\n#materialy-hub p {\n  font-weight: 400 !important;\n  margin-bottom: 1rem !important;\n  color: var(--text-light);\n}\n/* BUTTONS */\n#materialy-hub .btn {\n  display: inline-flex !important;\n  align-items: center !important;\n  justify-content: center !important;\n  min-width: 200px !important;\n  height: 52px !important;\n  padding: 0 32px !important;\n  border-radius: var(--radius-md) !important;\n  font-weight: 700 !important;\n  text-decoration: none !important;\n  font-size: 1rem !important;\n  border: 2px solid transparent !important;\n  cursor: pointer !important;\n  white-space: nowrap !important;\n  transition: all 0.3s ease !important;\n}\n#materialy-hub .btn-white {\n  background: #fff !important;\n  color: var(--brand) !important;\n  box-shadow: var(--shadow);\n}\n#materialy-hub .btn-white:hover {\n  background: #f1f5f9 !important;\n  transform: translateY(-2px);\n  box-shadow: 0 8px 20px rgba(0,0,0,0.12);\n}\n#materialy-hub .btn-outline {\n  border: 2px solid #fff !important;\n  color: #fff !important;\n  background: transparent !important;\n}\n#materialy-hub .btn-outline:hover {\n  background: rgba(255,255,255,0.1) !important;\n  transform: translateY(-2px);\n}\n#materialy-hub .btn-group {\n  display: flex;\n  gap: 16px;\n  justify-content: center;\n  flex-wrap: wrap;\n  margin-top: 1.5rem;\n}\n/* SECTIONS */\n#materialy-hub .section {\n  padding: 50px 0;\n}\n/* === HERO === */\n#materialy-hub .hero {\n  background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%) !important;\n  color: #fff !important;\n  padding: 60px 24px 80px 24px; /* Větší padding dole pro odstup */\n  text-align: center;\n}\n#materialy-hub .badge {\n  display: inline-block;\n  background: rgba(255,255,255,0.15);\n  padding: 6px 16px;\n  border-radius: 50px;\n  font-size: 0.85rem;\n  font-weight: 700;\n  margin-bottom: 1.2rem;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n#materialy-hub .hero-subtitle {\n  font-size: 1.2rem;\n  max-width: 700px;\n  margin: 0 auto;\n  opacity: 0.95;\n  color: #fff !important;\n}\n/* === MAIN GRID (Rozcestník) === */\n#materialy-hub .main-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));\n  gap: 30px;\n  margin-top: -40px; /* Jemný přesah do Hero */\n  margin-bottom: 50px;\n  position: relative;\n  z-index: 10;\n}\n/* KARTA MATERIÁLU */\n#materialy-hub .hub-card {\n  background: #fff !important;\n  border-radius: var(--radius-lg);\n  padding: 40px;\n  border: 1px solid var(--line);\n  box-shadow: var(--shadow);\n  transition: all 0.3s ease;\n  display: flex;\n  flex-direction: column;\n  align-items: flex-start;\n  height: 100%;\n}\n#materialy-hub .hub-card:hover {\n  transform: translateY(-5px); /* Jen posun, žádné jiné transformace */\n  box-shadow: 0 15px 35px rgba(61,92,217,0.15);\n  border-color: var(--brand);\n}\n/* Ikona */\n#materialy-hub .card-icon-wrapper {\n  width: 70px;\n  height: 70px;\n  background: linear-gradient(135deg, #f0f4ff 0%, #e8f0fe 100%);\n  border-radius: 16px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin-bottom: 25px;\n  transition: background 0.3s;\n}\n#materialy-hub .hub-card:hover .card-icon-wrapper {\n  background: var(--brand);\n}\n#materialy-hub .card-icon {\n  font-size: 2rem;\n  color: var(--brand);\n  transition: color 0.3s;\n}\n#materialy-hub .hub-card:hover .card-icon {\n  color: #fff;\n}\n/* Odkaz v nadpisu */\n#materialy-hub .hub-card h2 a {\n  color: var(--text);\n  text-decoration: none;\n  transition: color 0.2s;\n}\n#materialy-hub .hub-card:hover h2 a {\n  color: var(--brand);\n}\n/* Tlačítko uvnitř karty */\n#materialy-hub .card-link {\n  font-weight: 700;\n  color: var(--brand);\n  font-size: 1rem;\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  text-decoration: none;\n  margin-top: auto; /* Zarovná tlačítko dolů */\n}\n#materialy-hub .card-link i { transition: transform 0.2s; }\n#materialy-hub .hub-card:hover .card-link i { transform: translateX(5px); }\n/* === SEKCE \"CO CHYSTÁM\" === */\n#materialy-hub .newsletter-section {\n  background: #fff;\n  border-radius: var(--radius-lg);\n  padding: 50px;\n  text-align: center;\n  border: 1px solid var(--line);\n  margin-bottom: 0;\n}\n#materialy-hub .tags {\n  display: flex;\n  justify-content: center;\n  gap: 10px;\n  flex-wrap: wrap;\n  margin-top: 20px;\n}\n#materialy-hub .tag {\n  background: #f1f5f9;\n  color: #64748b;\n  padding: 6px 14px;\n  border-radius: 50px;\n  font-size: 0.85rem;\n  font-weight: 600;\n}\n/* === CTA FINAL (Stejná jako O mně) === */\n#materialy-hub .cta-final {\n  background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%) !important;\n  color: #fff !important;\n  padding: 60px 24px;\n  text-align: center;\n  margin-top: 40px;\n}\n#materialy-hub .cta-final h2 {\n  color: #fff !important;\n  font-size: 1.8rem !important;\n}\n#materialy-hub .cta-final p {\n  color: rgba(255,255,255,0.9) !important;\n}\n#materialy-hub .cta-contact {\n  margin-top: 25px;\n  font-weight: 700;\n  font-size: 1.05rem;\n}\n/* === RESPONSIVE === */\n@media (max-width: 768px) {\n  #materialy-hub h1 { font-size: 2rem; }\n  #materialy-hub .main-grid { grid-template-columns: 1fr; margin-top: -30px; }\n  #materialy-hub .hub-card { padding: 30px; }\n  #materialy-hub .btn { width: 100%; }\n  #materialy-hub .btn-group { flex-direction: column; }\n}\n</style>\n<section>\n    Know-how\n    <h1>Materiály a zdroje k AI</h1>\n    <p>Praktické nástroje, prompty a návody, které využívám na školeních. Vše na jednom místě a zdarma pro vaše použití.</p>\n</section>\n      <h2><a href=\"/materialy/ai-nastroje/\">AI nástroje pro firmy</a></h2>\n      <p>Kurátorský výběr ověřených AI aplikací, které skutečně fungují. Rozdělené do kategorií (text, grafika, audio, video) s praktickými tipy.</p>\n      <a href=\"/materialy/ai-nastroje/\">Otevřít katalog nástrojů </a>\n      <h2><a href=\"/materialy/prompty/\">Knihovna AI promptů</a></h2>\n      <p>Databáze funkčních příkazů (promptů) pro ChatGPT a Copilot. Šablony pro marketing, e-maily, analýzu dat a manažerskou práci.</p>\n      <a href=\"/materialy/prompty/\">Procházet prompty </a>\n      <h3>Další materiály připravuji</h3>\n      <p style=\"max-width: 600px; margin: 0 auto;\">\n        Obsah webu neustále rozšiřuji. Brzy přibudou další sekce, na kterých pracuji.\n      </p>\n        Checklisty pro zavádění AI\n        E-booky\n        Legislativa\n        <a href=\"https://www.linkedin.com/in/pkovarik/\" target=\"_blank\" style=\"justify-content: center; font-size: 1.1rem; text-decoration: none;\">\n           Sledujte novinky na LinkedInu\n        </a>\n<section>\n    <h2>Hledáte způsob, jak AI zavést ve firmě?</h2>\n    <p style=\"font-size: 1.1rem; margin-bottom: 1.5rem;\">\n      Materiály jsou skvělý začátek. Pokud ale chcete ušetřit čas a vyhnout se slepým uličkám, ozvěte se. Provedu vás světem AI prakticky.\n    </p>\n      <a href=\"/kontakt/\">Poptat AI školení</a>\n      <a href=\"/skoleni/\">Nabídka kurzů</a>\n      📞 +420 770 126 519 · ✉️ mail@pavelkovarik.cz\n</section>"
