---
import Base from './Base.astro';
const { frontmatter } = Astro.props;
---

<Base title={`${frontmatter.title} | Pavel Kovařík`} description={frontmatter.description}>
  <article class="article">
    <div class="article-shell">
      <header class="article-header">
        <h1>{frontmatter.title}</h1>
        <time datetime={frontmatter.date}>{new Date(frontmatter.date).toLocaleDateString('cs-CZ')}</time>
        {frontmatter.image && <img class="article-cover" src={frontmatter.image} alt={frontmatter.title} />}
      </header>
      <div class="prose article-content">
        <slot />
      </div>
      <aside class="article-author-box" aria-label="Autor článku">
        <div class="article-author-avatar" aria-hidden="true">PK</div>
        <div class="article-author-meta">
          <div class="article-author-name">Pavel Kovařík</div>
          <p>Školím firmy, jak AI používat prakticky, bezpečně a bez zbytečné teorie. Pomáhám týmům převést AI do každodenní práce.</p>
          <a href="/kdo-jsem/">Více o mně</a>
        </div>
      </aside>
    </div>
  </article>
</Base>
