---
import Base from './Base.astro';
import { importedPosts } from '../data/importedPosts';
import { blogImageAlts } from '../data/blogImageAlts';

const { frontmatter } = Astro.props;

const mdxPosts = Object.values(import.meta.glob('../pages/*.mdx', { eager: true })).map((post: any) => ({
  url: post.url,
  frontmatter: post.frontmatter,
}));

const allPosts = [
  ...mdxPosts,
  ...importedPosts.map((post) => ({
    url: post.url,
    frontmatter: {
      title: post.title,
      description: post.description,
      date: post.date,
      image: post.image,
    },
  })),
].sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const currentUrl = Astro.url?.pathname ?? '';
const relatedPosts = allPosts.filter((post) => post.url !== currentUrl).slice(0, 3);
const displayPosts = relatedPosts.length > 0 ? relatedPosts : allPosts.slice(0, 3);

const getImageAlt = (image: string | undefined, fallbackTitle: string) => {
  if (!image) return fallbackTitle;
  return blogImageAlts[image] ?? fallbackTitle;
};
---

<Base title={frontmatter.metaTitle ?? `${frontmatter.title} | Pavel Kovařík`} description={frontmatter.description}>
  <article class="article">
    <div class="article-shell">
      <header class="article-header">
        <h1>{frontmatter.title}</h1>
        <time datetime={frontmatter.date}>{new Date(frontmatter.date).toLocaleDateString('cs-CZ')}</time>
        {frontmatter.image && (
          <img
            class="article-cover"
            src={frontmatter.image}
            alt={getImageAlt(frontmatter.image, frontmatter.title)}
          />
        )}
      </header>
      <div class="prose article-content">
        <slot />
      </div>
      <aside class="article-author-box" aria-label="Autor článku">
        <div class="article-author-avatar">
          <img src="/images/web/pavel-kovarik-profile.webp" alt="Pavel Kovařík" loading="lazy" />
        </div>
        <div class="article-author-meta">
          <div class="article-author-name">Pavel Kovařík</div>
          <p>Školím firmy, jak AI používat prakticky, bezpečně a bez zbytečné teorie. Pomáhám týmům převést AI do každodenní práce.</p>
          <a href="/kdo-jsem/">Více o mně</a>
        </div>
      </aside>
      {displayPosts.length > 0 && (
        <section class="article-related" aria-label="Doporučené články">
          <h2>Doporučené další články</h2>
          <div class="article-related-grid">
            {displayPosts.map((post) => (
              <a href={post.url} class="article-related-card">
                {post.frontmatter.image && (
                  <img
                    src={post.frontmatter.image}
                    alt={getImageAlt(post.frontmatter.image, post.frontmatter.title)}
                    loading="lazy"
                  />
                )}
                <div class="article-related-body">
                  <time datetime={post.frontmatter.date}>
                    {new Date(post.frontmatter.date).toLocaleDateString('cs-CZ')}
                  </time>
                  <h3>{post.frontmatter.title}</h3>
                  <p>{post.frontmatter.description}</p>
                  <span class="article-related-link">Přečíst článek →</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </article>
</Base>
