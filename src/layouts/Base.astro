---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Lektor umělé inteligence pro firmy. Praktická školení AI nástrojů pro firemní týmy po celé ČR.' } = Astro.props;
const path = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={new URL(path, Astro.site).href} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="shortcut icon" href="/favicon.ico?v=4" type="image/x-icon" />
  <link rel="icon" href="/favicon.ico?v=4" sizes="any" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=4" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=4" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=4" />
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body>
  <header class="pk-header">
    <div class="wrap">
      <a href="/" class="pk-logo">
        <img src="/images/web/logo-pavel-kovarik-flt.webp" alt="Pavel Kovařík – AI školení pro firmy" />
      </a>

      <nav class="pk-nav">
        <ul class="pk-nav-list" id="nav-menu">
          <li class="pk-nav-item"><a href="/">Domů</a></li>
          <li class="pk-nav-item">
            <a href="/skoleni/" class="pk-nav-cta">Školení <span style="font-size:.7em; margin-left:.2rem;">&#9662;</span></a>
            <ul class="pk-dropdown">
              <li><a href="/prakticke-skoleni-ai-pro-firmy/">Praktické školení AI pro firmy</a></li>
              <li><a href="/ai-pro-verejnou-spravu/">AI pro veřejnou správu</a></li>
              <li><a href="/microsoft-copilot-pro-firmy/">Microsoft Copilot</a></li>
              <li><a href="/ai-pro-manazery/">AI pro manažery</a></li>
              <li><a href="/skoleni-na-miru/">Školení na míru</a></li>
              <li><a href="/vibe-coding/">Vibe Coding</a></li>
            </ul>
          </li>
          <li class="pk-nav-item">
            <a href="/materialy/">Materiály <span style="font-size:.7em;">&#9662;</span></a>
            <ul class="pk-dropdown">
              <li><a href="/prompty/">Prompty</a></li>
              <li><a href="/ai-nastroje/">AI nástroje</a></li>
            </ul>
          </li>
          <li class="pk-nav-item"><a href="/blog/">Blog</a></li>
          <li class="pk-nav-item"><a href="/kdo-jsem/">Kdo jsem</a></li>
          <li class="pk-nav-item"><a href="/kontakt/">Kontakt</a></li>
        </ul>

        <a href="tel:+420770126519" class="pk-nav-phone">+420 770 126 519</a>
        <a href="https://www.linkedin.com/in/pkovarik/" target="_blank" rel="noopener" class="pk-nav-phone">LinkedIn</a>

        <button class="pk-nav-toggle" id="nav-toggle" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="pk-footer">
    <div class="wrap">
      <div class="pk-footer-grid">
        <div class="pk-footer-col">
          <h4>Pavel Kovařík</h4>
          <p class="pk-footer-motto">Školím firmy, které chtějí AI používat efektivně, prakticky a bezpečně.</p>
          <p class="pk-footer-contact"><a href="mailto:mail@pavelkovarik.cz">mail@pavelkovarik.cz</a></p>
          <p class="pk-footer-contact"><a href="tel:+420770126519">+420 770 126 519</a></p>
          <p class="pk-footer-contact"><a href="https://www.linkedin.com/in/pkovarik/" target="_blank" rel="noopener">LinkedIn profil</a></p>
          <a href="/kontakt/" class="btn btn-p mt-3">Poptat AI školení</a>
        </div>

        <div class="pk-footer-col">
          <h4>Tematická školení</h4>
          <a href="/skoleni/">AI pro firmy</a>
          <a href="/ai-pro-verejnou-spravu/">AI pro veřejnou správu</a>
          <a href="/marketing-pr-ai/">Marketing &amp; PR s AI</a>
          <a href="/ai-pro-manazery/">AI pro manažery</a>
          <a href="/pravo-v-ai/">AI bezpečnost</a>
          <a href="/skoleni-na-miru/">Školení na míru</a>
        </div>

        <div class="pk-footer-col">
          <h4>Školení na AI nástroje</h4>
          <a href="/chatgpt-pro-firmy/">ChatGPT pro firmy</a>
          <a href="/claude-pro-firmy/">Claude pro firmy</a>
          <a href="/gemini-pro-firmy/">Gemini pro firmy</a>
          <a href="/microsoft-copilot-pro-firmy/">Copilot pro firmy</a>
        </div>

        <div class="pk-footer-col">
          <h4>Rychlé odkazy</h4>
          <a href="/">Domů</a>
          <a href="/kdo-jsem/">Kdo jsem</a>
          <a href="/ai-nastroje/">AI nástroje</a>
          <a href="/prompty/">Knihovna promptů</a>
          <a href="/blog/">Blog</a>
        </div>
      </div>

      <div class="pk-footer-bottom">
        <span>&copy; {new Date().getFullYear()} Ing. Pavel Kovařík</span>
        <span>IČO: 76233006, nejsem plátce DPH</span>
        <a href="/gdpr-ochrana-osobnich-udaju/">Ochrana osobních údajů (GDPR)</a>
      </div>
    </div>
  </footer>

  <button class="scroll-top" id="scroll-top" aria-label="Nahoru">&#9650;</button>

  <script>
    document.getElementById('nav-toggle')?.addEventListener('click', () => {
      document.getElementById('nav-menu')?.classList.toggle('open');
    });

    const scrollBtn = document.getElementById('scroll-top');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        scrollBtn?.classList.add('visible');
      } else {
        scrollBtn?.classList.remove('visible');
      }
    });
    scrollBtn?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  </script>
</body>
</html>
