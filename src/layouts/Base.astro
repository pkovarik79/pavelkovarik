---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Lektor umělé inteligence pro firmy. Praktická školení AI nástrojů pro firemní týmy po celé ČR.' } = Astro.props;
const path = Astro.url.pathname;
const canonicalUrl = new URL(path, Astro.site).href;
---

<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Pavel Kovařík" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />
  <meta name="msapplication-TileImage" content="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#3d5cd9" />
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body>
  <header class="pk-header">
    <div class="pk-header-container">
      <a href="/" class="pk-logo">
        <img src="/images/web/logo-pavel-kovarik-flt.webp" alt="Pavel Kovařík – AI školení pro firmy" />
      </a>

      <nav class="pk-nav" id="pk-mobile-menu">
        <ul class="pk-nav-list">
          <li><a href="/" class="pk-nav-link">Domů</a></li>
          <li class="pk-menu-item-wrapper">
            <a href="/skoleni/" class="pk-btn-training">
              Školení
              <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"></path>
              </svg>
            </a>
            <div class="pk-dropdown-box">
              <a href="/prakticke-skoleni-ai-pro-firmy/" class="pk-dropdown-link">Praktické školení AI pro firmy</a>
              <a href="/ai-pro-verejnou-spravu/" class="pk-dropdown-link">AI pro veřejnou správu</a>
              <a href="/marketing-pr-ai/" class="pk-dropdown-link">Marketing &amp; PR s AI</a>
              <a href="/ai-pro-manazery/" class="pk-dropdown-link">AI pro manažery</a>
              <a href="/pravo-v-ai/" class="pk-dropdown-link">AI - právo, bezpečnost a autorská práva</a>
              <a href="/skoleni-na-miru/" class="pk-dropdown-link">Školení na míru</a>
            </div>
          </li>
          <li class="pk-menu-item-wrapper pk-mobile-collapse">
            <a href="/materialy/" class="pk-nav-link pk-nav-link-dropdown">
              Materiály
              <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"></path>
              </svg>
            </a>
            <div class="pk-dropdown-box">
              <a href="/ai-nastroje/" class="pk-dropdown-link">AI nástroje pro firmy</a>
              <a href="/prompty/" class="pk-dropdown-link">Knihovna promptů</a>
            </div>
          </li>
          <li><a href="/blog/" class="pk-nav-link">Blog</a></li>
          <li><a href="/kdo-jsem/" class="pk-nav-link">Kdo jsem</a></li>
          <li><a href="/kontakt/" class="pk-nav-link">Kontakt</a></li>
        </ul>
      </nav>

      <div class="pk-contact-cta">
        <a href="tel:+420770126519" class="pk-cta-item">+420 770 126 519</a>
        <a href="https://www.linkedin.com/in/pkovarik/" target="_blank" rel="noopener" class="pk-cta-item">LinkedIn</a>
      </div>

      <button class="pk-mobile-toggle" id="pk-mobile-toggle" aria-label="Menu">☰</button>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="pk-footer">
    <div class="wrap">
      <div class="pk-footer-grid">
        <div class="pk-footer-col pk-footer-col-brand">
          <div class="pk-footer-brand-title">Pavel Kovařík</div>
          <p class="pk-footer-motto">Školím firmy, které chtějí AI používat efektivně, prakticky a bezpečně.</p>
          <div class="pk-footer-contacts">
            <a href="mailto:mail@pavelkovarik.cz" class="pk-footer-link pk-footer-contact-link pk-footer-contact-mail">mail@pavelkovarik.cz</a>
            <a href="tel:+420770126519" class="pk-footer-link pk-footer-contact-link pk-footer-contact-phone">+420 770 126 519</a>
            <a href="https://www.linkedin.com/in/pkovarik/" target="_blank" rel="noopener" class="pk-footer-link pk-footer-contact-link pk-footer-contact-linkedin">LinkedIn profil</a>
          </div>
          <a href="/kontakt/" class="btn btn-p mt-3">Poptat AI školení</a>
        </div>

        <div class="pk-footer-col">
          <h4>Tematická školení</h4>
          <div class="pk-footer-nav">
            <a href="/prakticke-skoleni-ai-pro-firmy/" class="pk-footer-link">AI pro firmy</a>
            <a href="/ai-pro-verejnou-spravu/" class="pk-footer-link">AI pro veřejnou správu</a>
            <a href="/marketing-pr-ai/" class="pk-footer-link">Marketing &amp; PR s AI</a>
            <a href="/ai-pro-manazery/" class="pk-footer-link">AI pro manažery</a>
            <a href="/pravo-v-ai/" class="pk-footer-link">AI - právo, bezpečnost a autorská práva</a>
            <a href="/skoleni-na-miru/" class="pk-footer-link">Školení na míru</a>
            <a href="/workshop-vibe-codingu-pro-firmy/" class="pk-footer-link">Workshop vibe codingu</a>
          </div>
        </div>

        <div class="pk-footer-col">
          <h4>Školení na AI nástroje</h4>
          <div class="pk-footer-nav">
            <a href="/chatgpt-pro-firmy/" class="pk-footer-link">ChatGPT pro firmy</a>
            <a href="/claude-pro-firmy/" class="pk-footer-link">Claude pro firmy</a>
            <a href="/gemini-pro-firmy/" class="pk-footer-link">Gemini pro firmy</a>
            <a href="/microsoft-copilot-pro-firmy/" class="pk-footer-link">Copilot pro firmy</a>
          </div>
        </div>

        <div class="pk-footer-col">
          <h4>Rychlé odkazy</h4>
          <div class="pk-footer-nav">
            <a href="/" class="pk-footer-link">Domů</a>
            <a href="/kdo-jsem/" class="pk-footer-link">Kdo jsem</a>
            <a href="/ai-nastroje/" class="pk-footer-link">AI nástroje</a>
            <a href="/prompty/" class="pk-footer-link">Knihovna promptů</a>
            <a href="/blog/" class="pk-footer-link">Blog</a>
          </div>
        </div>
      </div>

      <div class="pk-footer-bottom">
        <div>&copy; <span id="pk-year">{new Date().getFullYear()}</span> Ing. Pavel Kovařík</div>
        <div class="pk-footer-legal">
          <span>IČO: 76233006, nejsem plátce DPH</span>
          <a href="/gdpr-ochrana-osobnich-udaju/" class="pk-footer-link">Ochrana osobních údajů (GDPR)</a>
        </div>
      </div>
    </div>
  </footer>

  <button class="scroll-top" id="scroll-top" aria-label="Nahoru">
    <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 5v14M6 11l6-6 6 6"></path>
    </svg>
  </button>

  <script>
    const mobileMenu = document.getElementById('pk-mobile-menu');
    const mobileToggle = document.getElementById('pk-mobile-toggle');

    mobileToggle?.addEventListener('click', () => {
      const isActive = mobileMenu?.classList.toggle('active');
      if (mobileToggle) {
        mobileToggle.textContent = isActive ? '✕' : '☰';
      }
    });

    document.querySelectorAll('.pk-nav-link, .pk-dropdown-link').forEach((link) => {
      link.addEventListener('click', () => {
        if (mobileMenu?.classList.contains('active')) {
          mobileMenu.classList.remove('active');
          if (mobileToggle) {
            mobileToggle.textContent = '☰';
          }
        }
      });
    });

    const scrollBtn = document.getElementById('scroll-top');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        scrollBtn?.classList.add('visible');
      } else {
        scrollBtn?.classList.remove('visible');
      }
    });
    scrollBtn?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    document.querySelectorAll('[data-faq-group]').forEach((group) => {
      const extraFaq = group.querySelector('[data-faq-extra]');
      const faqToggle = group.querySelector('[data-faq-toggle]');

      if (!(extraFaq instanceof HTMLElement) || !(faqToggle instanceof HTMLElement)) {
        return;
      }

      faqToggle.addEventListener('click', () => {
        const isHidden = extraFaq.hasAttribute('hidden');

        if (isHidden) {
          extraFaq.removeAttribute('hidden');
          faqToggle.textContent = 'Skrýt další otázky';
        } else {
          extraFaq.setAttribute('hidden', '');
          faqToggle.textContent = 'Zobrazit další otázky';
        }
      });
    });
  </script>
</body>
</html>
