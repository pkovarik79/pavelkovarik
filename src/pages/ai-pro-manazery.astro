---
import Base from '../layouts/Base.astro';
import '../styles/global.css';

const overview = [
  ['Kde AI opravdu dává smysl', 'Kde už dnes přináší firmám rychlý efekt a kde jsou očekávání zatím větší než reálný přínos.'],
  ['Aktuální nástroje', 'ChatGPT, Copilot, Claude, Gemini a další. V čem se liší a co od nich čekat v praxi.'],
  ['Automatizace a asistenti', 'Kde lze zrychlit rutinu, opakující se činnosti a interní procesy bez složitých projektů.'],
  ['Data, Excel a predikce', 'Jak AI pomáhá při práci s tabulkami, reportingem, controllingem, scénáři a podklady pro rozhodování.'],
  ['Rizika a odpovědnost ve firmě', 'Data, reputace, GDPR, AI Act, nespolehlivé výstupy a situace, kde je potřeba větší opatrnost.'],
  ['Jednoduché nástroje na míru', 'Co dnes AI zvládne vytvořit rychle – od interních pomocníků po jednoduché aplikace, formuláře nebo kalkulačky.'],
];

const steps = [
  ['Konzultace před školením', 'Krátce si ujasníme, co řešíte, kde potřebujete získat přehled a jaké otázky má vedení firmy na stole.'],
  ['Čtyři hodiny online nebo ve firmě', 'Přehled AI možností pro management se zaměřením na rozhodování, náklady, nástroje a rizika.'],
  ['Navazující konzultace', 'Po školení můžete využít ještě 30 minut na dotazy, které se objeví při dalších interních debatách.'],
];

const impactAreas = [
  ['Finance, controlling a reporting', 'Rychlejší práce s Excelem, reporty, forecasty, scénáři a daty pro rozhodování.'],
  ['Procesy a automatizace', 'Kde lze ušetřit čas bez velkých zásahů do fungování firmy a kde už je potřeba změna procesu.'],
  ['Obchod a CRM', 'Podklady pro obchod, práce s CRM, zákaznická komunikace a opakující se úkoly.'],
  ['Marketing a obsah', 'Texty, rešerše, prezentace, kampaně a rychlejší příprava podkladů pro tým.'],
  ['HR a interní agenda', 'Nábor, onboarding, interní dokumenty a efektivnější práce s informacemi uvnitř firmy.'],
  ['Interní nástroje a data', 'Jednoduché pomocníky, interní aplikace nebo rychlá řešení pro konkrétní potřeby týmu.'],
];

const audiences = [
  ['CEO a majitelé firem', 'Potřebujete vědět, kde AI dává strategický smysl a co od ní čekat při rozhodování o investicích.'],
  ['Top management', 'Řešíte směr firmy, změny procesů, bezpečnost, odpovědnost a prioritizaci toho, co má smysl zavádět.'],
  ['Vedoucí oddělení', 'Chcete pochopit, jak AI ovlivní HR, obchod, finance, operations, marketing nebo zákaznickou péči.'],
  ['Lidé s nedostatkem času', 'Potřebujete rychlý a praktický přehled bez dlouhého studování nebo testování všeho po večerech.'],
];

const fastWins = [
  'Tvorba textů, shrnutí a interních podkladů',
  'Práce s dokumenty, rešeršemi a firemními znalostmi',
  'Rychlejší příprava reportů, prezentací a osnov',
  'Automatizace opakujících se úkolů a rutiny',
  'Práce s Excelem, přehledy a základními scénáři',
  'Hledání souvislostí v datech a rychlejší příprava podkladů pro rozhodnutí',
  'Návrh jednoduchých interních nástrojů, formulářů nebo kalkulaček',
];

const carefulAreas = [
  'Práce s citlivými daty a osobními údaji',
  'Výstupy, které mohou mít právní, reputační nebo obchodní dopad',
  'Rozhodnutí postavená na nepřesných nebo neověřených výstupech',
  'Nákup nástrojů bez jasného cíle, bez určení odpovědnosti a bez pilotního ověření',
  'Složitější automatizace, které zasahují do důležitých firemních procesů',
  'Situace, kdy není jasné, kdo odpovídá za výstup nebo za finální rozhodnutí',
];

const quotes = [
  ['„Přesně to, co jsem potřeboval. Přehled bez zbytečných technických odboček a jasnější představa, co má pro nás smysl řešit dál.“', 'Petr Novotný', 'CEO, výrobní firma'],
  ['„Za čtyři hodiny jsem získala jasnější představu o AI než za měsíce vlastního zkoumání. Pomohlo mi to s rozhodováním i prioritami.“', 'Jana Králová', 'CFO, IT společnost'],
  ['„Oceňuji konkrétní příklady z praxe, orientaci v nástrojích i to, že se mluvilo i o rizicích, ne jen o výhodách.“', 'Martin Dvořák', 'majitel e-commerce'],
];

const includes = [
  'Konzultace před školením',
  '4 hodiny školení pro management',
  'Přehled relevantních AI nástrojů a kategorií',
  'Orientační ceny licencí, nástrojů a služeb',
  'Prostor na dotazy a rozhodovací scénáře',
  'Navazující konzultace do 30 dnů',
];

const faqItems = [
  ['Co je AI školení pro manažery a komu je určené?', 'Je to čtyřhodinové školení pro CEO, majitele firem, top management a vedoucí oddělení, kteří potřebují rychle získat přehled o tom, kde AI dává smysl, co stojí, jaké nástroje má smysl sledovat a kde je potřeba větší opatrnost.'],
  ['Co se manažeři na AI školení konkrétně dozvědí?', 'Získáte přehled, co AI dnes umí, kde pomůže vašemu byznysu, jaké nástroje sledovat, kolik stojí běžné licence a služby, kde může AI pomoct s automatizací, daty, Excelem nebo jednoduchými interními nástroji a co je potřeba hlídat z hlediska bezpečnosti a odpovědnosti.'],
  ['Je školení vhodné i pro CEO, majitele firem a vedoucí oddělení?', 'Ano. Školení je připravené právě pro vedení firmy a manažery, kteří potřebují rychle získat přehled a udělat si jasno v tom, kde AI dává smysl a co od ní čekat.'],
  ['Je možné AI školení pro manažery online i ve firmě?', 'Ano. Školení je možné uspořádat online i ve firmě. Obsah je v obou variantách stejný, liší se jen formátem setkání a způsobem práce během školení.'],
  ['Jak poznáme, která varianta je pro nás vhodnější?', 'Online varianta je vhodná, když potřebujete rychlý a flexibilní přehled bez cestování. Varianta ve firmě dává větší prostor pro společnou diskusi vedení, sladění pohledu týmu a práci s konkrétní situací firmy.'],
  ['Je čtyřhodinový formát dostatečný?', 'Ano. Pro vedení firmy je čtyřhodinový formát ve většině případů ideální, pokud cílem není učit se nástroje do detailu, ale získat pevnější rámec pro rozhodování a další kroky.'],
  ['Jaká témata bezpečnosti a rizik ve školení řešíte?', 'Řešíme práci s daty, citlivé informace, GDPR, AI Act, reputační rizika, ověřování výstupů, odpovědnost za rozhodnutí opřená o AI i situace, kde je potřeba větší opatrnost při zavádění nových nástrojů do firmy.'],
  ['Kolik stojí AI školení pro manažery?', 'Online varianta stojí 9 800 Kč, varianta ve firmě 14 900 Kč. V obou případech jde o čtyřhodinové školení pro skupinu do 10 účastníků a obsah je stejný.'],
];

const visibleFaqItems = faqItems.slice(0, 5);
const extraFaqItems = faqItems.slice(5);
---

<Base title="AI pro manažery | Školení pro vedení firem | Pavel Kovařík" description="Strategické AI školení pro manažery. Rychlý přehled, kde AI pomůže vedení firmy, jaká jsou rizika a jak ji využít v rozhodování.">
  <div class="lp-page">
    <section class="lp-hero">
      <div class="wrap">
        <span class="lp-badge">AI PRO MANAŽERY A VEDENÍ FIREM</span>
        <h1>AI pro manažery: rozhodování, rizika a příležitosti</h1>
        <p class="lp-subtitle"><strong>Rychlý přehled, co AI dnes umí a kde pomůže vašemu byznysu</strong></p>
        <div class="lp-meta">
          <span class="lp-meta-item">
            <i class="lp-meta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
            </i>
            4 hodiny
          </span>
          <span class="lp-meta-item">
            <i class="lp-meta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M16 20v-1.2a3.8 3.8 0 0 0-3.8-3.8H7.8A3.8 3.8 0 0 0 4 18.8V20"></path><circle cx="10" cy="8" r="3"></circle><path d="M20 20v-1.2a3.4 3.4 0 0 0-2.4-3.3"></path><path d="M15.8 5.2A3 3 0 0 1 15.8 11"></path></svg>
            </i>
            Až 10 účastníků
          </span>
          <span class="lp-meta-item">
            <i class="lp-meta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><rect x="4" y="5" width="16" height="10" rx="2"></rect><path d="M8 19h8"></path><path d="M12 15v4"></path></svg>
            </i>
            Online nebo ve firmě
          </span>
        </div>
        <div class="lp-actions">
          <a href="/kontakt/" class="btn btn-p">Domluvit termín</a>
          <a href="#cena" class="btn btn-s">Ukázat varianty školení</a>
        </div>
      </div>
    </section>

    <div class="lp-verified-wrap">
      <div class="lp-verified">
        <div class="lp-stars">★★★★★</div>
        <h3>Strategický přehled bez technických detailů</h3>
        <p>Školení je určené pro majitele firem, CEO, top management a vedoucí oddělení, kteří potřebují rychle pochopit, kde AI dává smysl, co stojí, jaké nástroje má smysl sledovat a kde je naopak potřeba větší opatrnost.</p>
      </div>
    </div>

    <section class="sec">
      <div class="wrap">
        <h2>Co se dozvíte během čtyř hodin</h2>
        <p class="lp-section-intro">Přehled zaměřený na management, rozhodování a řízení rizik. Stručně, prakticky a v souvislostech.</p>
        <div class="lp-card-grid-6">
          {overview.map(([title, text], index) => (
            <div class="lp-card center">
              <div class="lp-icon">{index + 1}</div>
              <h3>{title}</h3>
              <p>{text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec" style="background:#fff;">
      <div class="wrap">
        <h2>Jak školení probíhá</h2>
        <div class="lp-steps">
          {steps.map(([title, text], index) => (
            <div class="lp-step">
              <div class="lp-step-no">{index + 1}</div>
              <h3>{title}</h3>
              <p>{text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="wrap">
        <h2>Kde AI nejčastěji ovlivní rozhodování ve firmě</h2>
        <p class="lp-section-intro">Školení pomáhá pochopit, kde AI zasahuje do fungování firmy a kde bude vedení firmy rozhodovat o prioritách, investicích a odpovědnosti.</p>
        <div class="lp-card-grid-6">
          {impactAreas.map(([title, text], index) => (
            <div class="lp-card center">
              <div class="lp-icon">{index + 1}</div>
              <h3>{title}</h3>
              <p>{text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec" style="background:#fff;">
      <div class="wrap">
        <h2>Pro koho je školení určené</h2>
        <div class="lp-card-grid-4">
          {audiences.map(([title, text]) => (
            <div class="lp-card center">
              <h3>{title}</h3>
              <p>{text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="wrap">
        <h2>Kde AI přináší rychlý efekt a kde je potřeba větší rozvaha</h2>
        <div class="lp-compare">
          <div class="lp-compare-card is-after">
            <h3>Kde se rychle ukáže přínos</h3>
            <ul class="lp-compare-list">
              {fastWins.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="lp-compare-card is-before">
            <h3>Kde je potřeba postupovat opatrněji</h3>
            <ul class="lp-compare-list">
              {carefulAreas.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
        <p class="lp-copy" style="max-width:860px;">
          Cílem školení není slibovat zázračné úspory, ale pomoct managementu rozlišit, kde AI opravdu přinese efekt a kde je potřeba větší rozvaha.
        </p>
      </div>
    </section>

    <section class="sec" style="background:#fff;">
      <div class="wrap">
        <h2>Zkušenosti vedoucích pracovníků</h2>
        <div class="lp-quote-grid">
          {quotes.map(([text, name, role]) => (
            <div class="lp-quote-card">
              <p>{text}</p>
              <strong>{name}</strong>
              <span class="lp-quote-role">{role}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec" id="cena">
      <div class="wrap">
        <div class="lp-pricing-shell">
          <h2 style="margin-bottom:0.55rem;">Varianty školení a cena</h2>
          <p class="lp-section-intro" style="margin-top:0; margin-bottom:0;">Obsah školení je v obou variantách stejný. Liší se jen formátem setkání a způsobem práce během školení.</p>
          <div class="lp-price-grid">
            <div class="lp-price-card">
              <div class="lp-price-tags">
                <span class="lp-price-tag">Ve firmě</span>
                <span class="lp-price-tag">4 hodiny</span>
              </div>
              <div class="lp-price-value">14&nbsp;900&nbsp;Kč</div>
              <p class="lp-price-per">To je 1&nbsp;490&nbsp;Kč na účastníka<span>při 10 účastnících</span></p>
              <p class="lp-price-note">pro skupinu do 10 osob • 4 hodiny • ve firmě</p>
              <div class="lp-price-box">
                <p>V ceně je zahrnuto:</p>
                <ul class="lp-check-list">
                  {includes.map((item) => <li>{item}</li>)}
                </ul>
              </div>
            </div>
            <div class="lp-price-card" style="border-width:3px;">
              <div class="lp-price-tags">
                <span class="lp-price-tag">Online</span>
                <span class="lp-price-tag">4 hodiny</span>
              </div>
              <div class="lp-price-value">9&nbsp;800&nbsp;Kč</div>
              <p class="lp-price-per">To je 980&nbsp;Kč na účastníka<span>při 10 účastnících</span></p>
              <p class="lp-price-note">pro skupinu do 10 osob • 4 hodiny • online</p>
              <div class="lp-price-box">
                <p>V ceně je zahrnuto:</p>
                <ul class="lp-check-list">
                  {includes.map((item) => <li>{item}</li>)}
                </ul>
              </div>
            </div>
          </div>

          <div class="lp-info-box">
            <h3>Jak vybrat vhodnou variantu</h3>
            <p>Online varianta je rychlá, flexibilní a snadná na organizaci. Varianta ve firmě dává větší prostor pro společnou diskusi vedení, práci s konkrétní situací firmy a lepší soustředění týmu. Obsah školení je v obou variantách stejný.</p>
          </div>

          <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-top:1.8rem;">
            <a href="/kontakt/" class="btn btn-p">Domluvit termín</a>
            <a href="/skoleni/" class="btn btn-s" style="background:#fff;">Zobrazit všechna školení</a>
          </div>
          <p class="lp-copy" style="font-size:0.88rem;">Nejsem plátce DPH. Uvedená cena je konečná.</p>
        </div>
      </div>
    </section>

    <section class="sec sec-alt">
      <div class="wrap">
        <div class="sec-head">
          <h2>Časté otázky k AI školení pro manažery</h2>
          <p>To nejdůležitější na jednom místě - délka, cena, formát i to, jak školení přizpůsobuji vašemu managementu.</p>
        </div>
        <div class="lp-faq-wrap" data-faq-group>
          <div class="faq">
            {visibleFaqItems.map(([q, a]) => (
              <details>
                <summary>{q}</summary>
                <div class="faq-body">
                  <div class="faq-body-inner">
                    <p>{a}</p>
                  </div>
                </div>
              </details>
            ))}
            <div class="lp-faq-extra" data-faq-extra hidden>
              {extraFaqItems.map(([q, a]) => (
                <details>
                  <summary>{q}</summary>
                  <div class="faq-body">
                    <div class="faq-body-inner">
                      <p>{a}</p>
                    </div>
                  </div>
                </details>
              ))}
            </div>
          </div>
          <div class="lp-faq-more">
            <button type="button" class="btn btn-p lp-faq-toggle" data-faq-toggle>Zobrazit další otázky</button>
          </div>
        </div>
      </div>
    </section>

    <section class="lp-final-cta">
      <div class="wrap">
        <h2>Získejte jasnější představu, kde AI dává smysl pro vaši firmu</h2>
        <p>Zavolejte mi nebo napište a během krátké konzultace probereme, která varianta školení bude pro vás a váš management nejvhodnější.</p>
        <div class="lp-actions">
          <a href="/kontakt/" class="btn btn-p">Domluvit termín</a>
          <a href="mailto:mail@pavelkovarik.cz" class="btn btn-s">Napsat e-mail</a>
        </div>
        <div class="lp-contact-line">+420&nbsp;770&nbsp;126&nbsp;519 · mail@pavelkovarik.cz</div>
        <div class="lp-contact-note">Odpovídám zpravidla do 24 hodin.</div>
      </div>
    </section>
  </div>
</Base>
