---
import Base from '../layouts/Base.astro';
import '../styles/global.css';

const beforeItems = [
  {
    strong: 'Nejistota a rozdílné postupy.',
    text: 'Lidé nevědí, kdy AI použít, co od ní čekat a každý k ní přistupuje trochu jinak.',
  },
  {
    strong: 'Riziko pro data.',
    text: 'Do nástrojů se někdy dostávají i informace, které by tam vůbec být neměly.',
  },
  {
    strong: 'Obecné nebo nepřesné výstupy.',
    text: 'Část výsledků je potřeba předělávat, upravovat nebo úplně zahodit.',
  },
  {
    strong: 'Záplava nástrojů.',
    text: 'Ve firmě není jasné, co má smysl používat a co je spíš slepá ulička.',
  },
];

const afterItems = [
  {
    strong: 'Větší jistota.',
    text: 'Lidé budou lépe vědět, kde AI dává smysl a co od ní mohou čekat.',
  },
  {
    strong: 'Jasnější pravidla.',
    text: 'Snáz se vyznají v tom, co do AI patří, co už ne a kde je potřeba být opatrný.',
  },
  {
    strong: 'Plynulejší práce.',
    text: 'Podklady, informace i běžné úkoly se dají zpracovat rychleji a s menším tápáním.',
  },
  {
    strong: 'Rozumnější používání.',
    text: 'Lidé budou mít jasněji v tom, kdy je výsledek použitelný a kdy je potřeba ho ještě ověřit nebo upravit.',
  },
];

const toolItems = [
  { title: 'ChatGPT', icon: 'chat' },
  { title: 'Copilot', icon: 'briefcase' },
  { title: 'Gemini', icon: 'sparkles' },
  { title: 'Claude', icon: 'file' },
  { title: 'NotebookLM', icon: 'book' },
  { title: 'Gamma', icon: 'sparkles' },
];

const takeaways = [
  { icon: 'compass', title: 'Strategie' },
  { icon: 'tools', title: 'Dovednosti' },
  { icon: 'shield', title: 'Jistota' },
  { icon: 'chart', title: 'Výsledky' },
];

const pillars = [
  {
    title: 'Bezpečnost a pravidla',
    text: 'Jasné mantinely: co do AI (ne)zadávat a jak neriskovat únik firemních dat nebo citlivých informací.',
  },
  {
    title: 'Praktické nástroje',
    text: 'K čemu se hodí ChatGPT, Copilot, Gemini a Claude, v čem se liší a kdy po kterém sáhnout. Podle potřeby i další užitečné nástroje pro různé role ve firmě.',
  },
  {
    title: 'Kontrola a kvalita',
    text: 'Proč si AI někdy vymýšlí, jak to poznat a jak z ní dostat lepší výstupy. Ukážeme si postupy, které většina lidí vůbec nezná.',
  },
  {
    title: 'Reálné příklady',
    text: 'Konkrétní úkoly a situace z běžné praxe, na kterých si všechno rovnou vyzkoušíte.',
  },
];

const audiences = [
  {
    title: 'Pro firmy, které s AI začínají',
    text: 'Nemusíte mít s AI žádné zkušenost. Vysvětlím vám základy a rychle přejdeme k tomu, co dává smysl v praxi.',
  },
  {
    title: 'Pro firmy, kde už AI používáte',
    text: 'Zaměříme se na praktické postupy, které vás posunou na novou úroveň. Klíčové nástroje probereme do hloubky.',
  },
  {
    title: 'Pro různé role ve firmě',
    text: 'HR, obchod, marketing, administrativa, management a další. Školení přizpůsobím tomu, co lidé ve firmě skutečně řeší.',
  },
];

const quotes = [
  {
    text: '„Dřív jsem v AI viděl jen hračku pro nadšence. Pavel nám ukázal, jak ji můžeme proměnit v reálný obchodní nástroj. Teď nám AI šetří hodiny týdně a našli jsme systém, který dává byznysový smysl a lidi fakt baví.“',
    name: 'Petr Dvořák',
    role: 'obchodní ředitel',
  },
  {
    text: '„Největší přínos pro nás nebyl v tom, že jsme viděli další nástroje. Důležité bylo, že si lidé v oddělení ujasnili, jak s nimi pracovat v běžné práci a co z toho je pro nás opravdu užitečné. Už po krátké době začal náš marketing generovat více poptávek při menším úsilí.“',
    name: 'Lucie Benešová',
    role: 'vedoucí marketingu',
  },
  {
    text: '„Oceňuji, že školení bylo srozumitelné a přizpůsobené tomu, co u nás ve firmě opravdu řešíme. Nepůsobilo to jako obecné povídání o AI, ale jako něco, co se dá hned použít v praxi.“',
    name: 'Eva Procházková',
    role: 'office manažerka',
  },
];

const oneDayIncludes = [
  'Příprava obsahu pro váš obor',
  'Praktická cvičení na vašich úkolech',
  'Knihovna šablon zadání pro typické situace',
  'Kontrolní postup pro ověření výstupů',
  'Následná e-mailová podpora',
  'Doprava po celé ČR zdarma',
];

const twoDayIncludes = [
  'Větší prostor pro vaše konkrétní úkoly a podklady',
  'Více času na zpětnou vazbu a doladění výstupů',
  'Více situací z praxe pro různé role',
  'Více prostoru na to, co lidé ve firmě řeší nejčastěji',
  'Více individuální přístup k účastníkům školení',
];

const faqItems = [
  {
    q: 'Co je firemní školení AI a komu je určené?',
    a: 'Firemní školení AI je prakticky zaměřené školení pro zaměstnance a týmy, které chtějí umět používat umělou inteligenci bezpečně, s rozumem a tak, aby jim opravdu pomáhala v práci. Je určené pro firmy, které s AI teprve začínají, i pro ty, kde už ji lidé používají, ale chtějí si v tom udělat větší pořádek a získat jistotu.',
  },
  {
    q: 'Je školení vhodné i pro úplné začátečníky?',
    a: 'Ano. Školení je vhodné i pro firmy, kde s AI většina lidí teprve začíná nebo s ní zatím nemá větší zkušenost. Všechno vysvětluji srozumitelně a ukazujeme si to na situacích, které dávají smysl v běžné práci.',
  },
  {
    q: 'Bude školení zaměřené prakticky?',
    a: 'Ano. Školení kombinuje srozumitelný výklad s praktickými úkoly a cvičeními. Účastníci se během něj seznámí s možnostmi AI i s nástroji, které mohou využít v každodenní práci. Důležité pro mě je, aby si všechno mohli rovnou vyzkoušet, ptát se na vlastní situace a dostali podporu tam, kde si nejsou jistí.',
  },
  {
    q: 'S jakými nástroji na školení pracujete?',
    a: 'Nejčastěji pracuji s nástroji ChatGPT, Copilot, Gemini a Claude. Ukážeme si, k čemu se jednotlivé nástroje hodí, v čem se liší a co z nich dává smysl právě pro vaši práci. Po dohodě se můžeme zaměřit i podrobněji na jeden vybraný nástroj. Vedle toho obvykle ukazujeme i další užitečné nástroje, například Gamma, NotebookLM nebo nástroje pro tvorbu grafiky a videí.',
  },
  {
    q: 'Přizpůsobíte obsah školení naší práci?',
    a: 'Ano. Při přípravě si společně ujasníme, jaké oblasti by mělo školení pokrýt a co lidé ve firmě skutečně řeší. Pokud budete chtít, můžeme předem udělat i krátký průzkum mezi účastníky, abych lépe poznal jejich zkušenosti s AI i to, co od školení potřebují.',
  },
  {
    q: 'Jak poznáme, jestli nám stačí jednodenní, nebo je lepší dvoudenní varianta?',
    a: 'Jednodenní varianta je ideální, když chcete lidi rychle naučit bezpečné a rozumné používání AI pro běžnou práci. Dvoudenní varianta dává větší prostor na vyzkoušení, více zpětné vazby i více práce s tím, co ve firmě opravdu řešíte.',
  },
  {
    q: 'Musí mít všichni účastníci notebook a zapojovat se do praktických cvičení?',
    a: 'Nemusí. Vždy záleží na dohodě a na tom, jaký typ školení vám bude vyhovovat. Mívám i školení, kde chtějí účastníci spíš poslouchat výklad a dívat se na ukázky. I v takovém případě můžeme společně zkoušet různé úkoly z běžné práce na jednom počítači a vše si ukazovat na promítacím plátně.',
  },
  {
    q: 'Jak řešíte bezpečnost a práci s citlivými údaji?',
    a: 'Bezpečnost je jeden z hlavních pilířů školení. Lidé se naučí, co do AI mohou vkládat, co už ne a jaká rizika jsou spojená s prací s firemními a osobními daty. Dotkneme se také témat, jako je GDPR nebo autorská práva v souvislosti s AI.',
  },
  {
    q: 'Má školení souvislost s AI Act?',
    a: 'Ano. Praktické školení umělé inteligence pro firmy odpovídá požadavkům, které AI Act klade na zvyšování AI gramotnosti zaměstnanců. Tohle školení ale není právní seminář. Pokud chcete jít do problematiky AI Actu víc do hloubky, doporučuji specializované školení AI - právo, bezpečnost a autorská práva.',
  },
  {
    q: 'Potřebujeme placené verze nástrojů?',
    a: 'Nutné to není. Záleží na tom, co od nástrojů čekáte a jak s nimi chcete pracovat. Pokud ale chcete využívat například ChatGPT nebo Copilot naplno, doporučuji alespoň na určitou dobu vyzkoušet placené licence. Oproti bezplatným verzím bývají výrazně schopnější a zpřístupňují i pokročilejší funkce.',
  },
  {
    q: 'Dostanou účastníci po školení nějaké materiály nebo doporučení?',
    a: 'Ano. Po školení dostanou přístup k online stránce s materiály, ke kterým se mohou vracet i později. Najdou tam doporučené nástroje, odkazy na praktické návody, tipy na užitečné zdroje, prompty, frameworky i zásady bezpečného používání AI.',
  },
  {
    q: 'Kolik stojí AI školení pro firmu?',
    a: 'Cena záleží hlavně na délce školení a domluveném rozsahu. Jednodenní varianta stojí 19 900 Kč, dvoudenní 37 900 Kč. Nejsem plátce DPH, takže uvedená cena je konečná.',
  },
];

const visibleFaqItems = faqItems.slice(0, 5);
const extraFaqItems = faqItems.slice(5);
---

<Base title="Praktické školení AI pro firmy | Pavel Kovařík" description="Naučím vaše lidi používat umělou inteligenci bezpečně a efektivně. Zaměřuji se na praktické postupy pro každodenní práci.">
  <div class="lp-page">
    <section class="lp-hero">
      <div class="wrap">
        <span class="lp-badge">Proškoleno přes 1 000 zaměstnanců v ČR</span>
        <h1>Praktické školení AI pro firmy</h1>
        <p class="lp-subtitle">Naučím vaše lidi používat umělou inteligenci bezpečně a efektivně. Zaměřuji se na praktické postupy pro každodenní práci.</p>
        <div class="lp-meta">
          <span class="lp-meta-item">
            <i class="lp-meta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
            </i>
            1 nebo 2 dny školení
          </span>
          <span class="lp-meta-item">
            <i class="lp-meta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M16 20v-1.2a3.8 3.8 0 0 0-3.8-3.8H7.8A3.8 3.8 0 0 0 4 18.8V20"></path><circle cx="10" cy="8" r="3"></circle><path d="M20 20v-1.2a3.4 3.4 0 0 0-2.4-3.3"></path><path d="M15.8 5.2A3 3 0 0 1 15.8 11"></path></svg>
            </i>
            Až 15 účastníků
          </span>
          <span class="lp-meta-item">
            <i class="lp-meta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 4.4-2.9 8.3-7 9.5C7.9 19.3 5 15.4 5 11V6l7-3z"></path></svg>
            </i>
            Bezpečné používání AI
          </span>
        </div>
        <div class="lp-actions">
          <a href="/kontakt/" class="btn btn-p">Domluvit termín</a>
          <a href="#cena" class="btn btn-s">Ukázat varianty školení</a>
        </div>
      </div>
    </section>

    <div class="lp-verified-wrap">
      <div class="lp-verified">
        <div class="lp-stars">★★★★★</div>
        <h3>Školení AI podle doporučených postupů České asociace umělé inteligence</h3>
        <p>Ověřené postupy z praxe. Školím desítky firem, mimo jiné Českou spořitelnu, Ptáček a Partners.</p>
      </div>
    </div>

    <section class="sec">
      <div class="wrap">
        <h2>Nejčastější realita ve firmách a co se změní po školení</h2>
        <p class="lp-section-intro">
          AI je dnes v každé firmě, ale většina lidí ji používá špatně. Bez pravidel a správných postupů se do nástrojů dostávají citlivá data a vznikají zbytečné chyby. Místo aby AI čas šetřila, chybějící systém firmu jen brzdí a okrádá o produktivitu.
        </p>

        <div class="lp-compare">
          <div class="lp-compare-card is-before">
            <h3>Před školením</h3>
            <ul class="lp-compare-list">
              {beforeItems.map((item) => (
                <li><strong>{item.strong}</strong> {item.text}</li>
              ))}
            </ul>
          </div>

          <div class="lp-compare-card is-after">
            <h3>Po školení</h3>
            <ul class="lp-compare-list">
              {afterItems.map((item) => (
                <li><strong>{item.strong}</strong> {item.text}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="sec" style="background:#fff; padding-top: 0.75rem; padding-bottom: 2.2rem;">
      <div class="wrap">
        <h2>Nástroje, které lidé ve vaší firmě opravdu využijí</h2>
        <p class="lp-section-intro" style="max-width: 820px;">
          Na školení se zaměříme na klíčové AI nástroje - ChatGPT, Copilot, Gemini a Claude. Naučíme se s nimi pracovat do hloubky a všechno si vyzkoušíme na konkrétních praktických úkolech. Součástí školení budou i další nástroje, které zrychlí rutinní práci a ušetří čas.
        </p>
        <div class="lp-tools-strip">
          <div class="lp-tools-row">
            {toolItems.slice(0, 4).map((item) => (
              <span class="lp-tool-pill">
                {item.icon === 'chat' && <svg viewBox="0 0 24 24"><path d="M7 10h10"></path><path d="M7 14h6"></path><path d="M5 19l1.6-3.2A7 7 0 1 1 19 16H9a7 7 0 0 1-4-1.3z"></path></svg>}
                {item.icon === 'briefcase' && <svg viewBox="0 0 24 24"><path d="M9 7V5.8A1.8 1.8 0 0 1 10.8 4h2.4A1.8 1.8 0 0 1 15 5.8V7"></path><rect x="3" y="7" width="18" height="12" rx="2"></rect><path d="M3 12h18"></path></svg>}
                {item.icon === 'sparkles' && <svg viewBox="0 0 24 24"><path d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6L12 3z"></path><path d="M19 14l.8 2.2L22 17l-2.2.8L19 20l-.8-2.2L16 17l2.2-.8L19 14z"></path><path d="M5 14l.6 1.4L7 16l-1.4.6L5 18l-.6-1.4L3 16l1.4-.6L5 14z"></path></svg>}
                {item.icon === 'file' && <svg viewBox="0 0 24 24"><path d="M14 3H8a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V9z"></path><path d="M14 3v6h6"></path><path d="M10 13h4"></path><path d="M10 17h4"></path></svg>}
                {item.title}
              </span>
            ))}
          </div>
          <div class="lp-tools-row">
            {toolItems.slice(4).map((item) => (
              <span class="lp-tool-pill">
                {item.icon === 'book' && <svg viewBox="0 0 24 24"><path d="M4 6.5A2.5 2.5 0 0 1 6.5 4H11v16H6.5A2.5 2.5 0 0 0 4 22z"></path><path d="M20 6.5A2.5 2.5 0 0 0 17.5 4H13v16h4.5A2.5 2.5 0 0 1 20 22z"></path></svg>}
                {item.icon === 'sparkles' && <svg viewBox="0 0 24 24"><path d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6L12 3z"></path><path d="M19 14l.8 2.2L22 17l-2.2.8L19 20l-.8-2.2L16 17l2.2-.8L19 14z"></path><path d="M5 14l.6 1.4L7 16l-1.4.6L5 18l-.6-1.4L3 16l1.4-.6L5 14z"></path></svg>}
                {item.title}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="sec" style="background:#fff; padding-top: 1.2rem; padding-bottom: 4.2rem;">
      <div class="wrap">
        <h2>Co si účastníci ze školení odnesou</h2>
        <p class="lp-section-intro" style="max-width: 860px;">
          Cílem mých školení není, aby lidé odcházeli s pocitem, že viděli pár zajímavých ukázek. Důležité je, aby měli jasněji v tom, kde jim AI opravdu pomůže, kde je potřeba větší opatrnost a jak ji používat tak, aby práci ulehčovala, ne přidělávala.
        </p>
        <div class="lp-feature-grid">
          {takeaways.map((item) => (
            <div class="lp-feature-card">
              <div class="lp-icon">
                {item.icon === 'compass' && <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"></circle><path d="M15.5 8.5l-2 5-5 2 2-5 5-2z"></path></svg>}
                {item.icon === 'tools' && <svg viewBox="0 0 24 24"><path d="M14.5 6.5a3 3 0 0 0 4 4L12 17l-4-4 6.5-6.5z"></path><path d="M5 21l4.5-4.5"></path><path d="M3 16l5 5"></path></svg>}
                {item.icon === 'shield' && <svg viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 4.4-2.9 8.3-7 9.5C7.9 19.3 5 15.4 5 11V6l7-3z"></path></svg>}
                {item.icon === 'chart' && <svg viewBox="0 0 24 24"><path d="M4 19V5"></path><path d="M4 19h16"></path><path d="M8 15l3-3 3 2 4-5"></path></svg>}
              </div>
              <h3>{item.title}</h3>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="wrap">
        <h2>Čtyři pilíře každého školení</h2>
        <div class="lp-number-grid">
          {pillars.map((pillar, index) => (
            <div class="lp-number-card">
              <div class="lp-number-badge">{index + 1}</div>
              <h3>{pillar.title}</h3>
              <p>{pillar.text}</p>
            </div>
          ))}
        </div>

        <div class="lp-info-box">
          <h3>Podrobnosti školení (PDF)</h3>
          <p>Chcete si udělat přesnější představu? V PDF najdete ukázku obsahu školení, hlavní témata i vysvětlení, kdy dává větší smysl jednodenní varianta a kdy už dvoudenní.</p>
          <a href="/wp-content/uploads/2026/03/Prakticke-skoleni-AI-pro-firmy-syllabus.pdf" class="btn btn-p" style="margin-top: 1rem;" download>Stáhnout obsah školení (PDF)</a>
        </div>
      </div>
    </section>

    <section class="sec" style="background:#fff;">
      <div class="wrap">
        <h2>Pro koho je školení určeno</h2>
        <div class="lp-card-grid-3">
          {audiences.map((item) => (
            <div class="lp-card center">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="wrap">
        <h2>Co říkají účastníci mých školení</h2>
        <div class="lp-quote-grid">
          {quotes.map((quote) => (
            <div class="lp-quote-card">
              <p>{quote.text}</p>
              <strong>{quote.name}</strong>
              <span class="lp-quote-role">{quote.role}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec" id="cena" style="background:#fff;">
      <div class="wrap">
        <div class="lp-pricing-shell">
          <h2 style="margin-bottom: 0.55rem;">Varianty školení a cena</h2>
          <p class="lp-section-intro" style="margin-top: 0; margin-bottom: 0;">
            Jednodenní varianta je vhodná jako pevný a praktický základ. Dvoudenní varianta dává více prostoru na vyzkoušení, práci s vašimi úkoly a hlubší využití AI v praxi.
          </p>

          <div class="lp-price-grid">
            <div class="lp-price-card">
              <div class="lp-price-tags">
                <span class="lp-price-tag">1 den</span>
                <span class="lp-price-tag">Praktický základ</span>
              </div>
