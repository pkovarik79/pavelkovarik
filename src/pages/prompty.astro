---
import Base from '../layouts/Base.astro';
import '../styles/global.css';

const categories = [
  { name: "Komunikace a dokumenty", icon: "📧", prompts: [
    { title: "Odpověď na dotaz zákazníka", desc: "Profesionální odpověď, která je věcná, srozumitelná a pomáhá zákazníkovi se zorientovat." },
    { title: "Žádost o schůzku", desc: "Profesionální žádost o jednání s jasným účelem a konkrétními termíny." },
    { title: "Profesionální odmítnutí nabídky", desc: "Zdvořilé odmítnutí, které zachová vztah." },
    { title: "Připomínka nesplněného závazku", desc: "Připomínka termínu bez zbytečného tlaku, ale jasně a věcně." },
    { title: "Shrnutí z porady s akčními body", desc: "Strukturovaný zápis z porady: kdo co udělá a do kdy." },
    { title: "Týdenní report pro vedení", desc: "Pravidelný report, který shrne aktivity, výsledky a plány." },
    { title: "Exekutivní shrnutí (1 strana)", desc: "Stručný přehled pro vedení, které potřebuje rychle pochopit situaci." },
    { title: "Analýza trendů z dat", desc: "Rychlá analýza dat: co se děje, kde jsou problémy a co s tím." },
  ]},
  { name: "Marketing a obsah", icon: "📱", prompts: [
    { title: "LinkedIn post: praktický tip ze zkušenosti", desc: "Post, který sdílí konkrétní zkušenost nebo tip bez přehánění a klišé." },
    { title: "LinkedIn post: oznámení", desc: "Post, který informuje o novince stručně a zajímavě." },
    { title: "Produktový popis (přínos místo vlastností)", desc: "Popis, který vysvětlí nejen co to je, ale hlavně proč je to užitečné." },
    { title: "Newsletter: aktuality a tipy", desc: "Pravidelný newsletter, který informuje a přináší hodnotu." },
  ]},
  { name: "LinkedIn a osobní značka", icon: "💼", prompts: [
    { title: "Audit LinkedIn profilu", desc: "Rychlé zhodnocení profilu: co působí dobře a co kazí dojem." },
    { title: "Optimalizace sekce O mně", desc: "Srozumitelná a moderní sekce O mně pro různé profese." },
    { title: "Nadpis profilu (headline)", desc: "Nadpis, který není jen název pozice, ale rychle řekne, v čem jste spolehlivý." },
    { title: "Překlad profilu do angličtiny", desc: "Anglická verze, která zní přirozeně i mimo Česko." },
  ]},
  { name: "Portréty z vlastní fotky", icon: "📸", prompts: [
    { title: "Business LinkedIn fotka", desc: "Profesionální profilová fotka s čistým studiovým pozadím." },
    { title: "Černobílý dramatický portrét", desc: "Seriózní portrét pro rozhovory a osobní web." },
    { title: "Uvolněný venkovní portrét", desc: "Přirozený portrét pro osobní web v teplém světle." },
    { title: "Pracovní portrét (kancelář/provoz)", desc: "Portrét do interních materiálů v autentickém prostředí." },
  ]},
];
---

<Base title="Knihovna AI promptů pro firmy | Pavel Kovařík" description="Praktické AI prompty, které používám ve školeních. Kategorizované podle použití, okamžitě použitelné šablony.">

  <section class="hero hero-center wrap">
    <span class="hero-label">Knihovna promptů</span>
    <h1>Knihovna AI promptů pro firmy</h1>
    <p class="lead">Praktické AI prompty, které používám ve školeních. Kategorizované podle použití — komunikace, analýza, obsah. Okamžitě použitelné šablony.</p>
  </section>

  {categories.map(cat => (
    <section class="sec">
      <div class="wrap">
        <div class="sec-head">
          <h2>{cat.icon} {cat.name}</h2>
        </div>
        <div class="grid grid-2">
          {cat.prompts.map(p => (
            <div class="card">
              <h3>{p.title}</h3>
              <p>{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="sec sec-alt">
    <div class="wrap">
      <div class="cta-box">
        <h2>Chcete se naučit psát prompty, které opravdu fungují?</h2>
        <p>Na školení si to všechno vyzkoušíte na vlastních úkolech.</p>
        <a href="/kontakt/" class="btn btn-p">Poptat školení</a>
      </div>
    </div>
  </section>

</Base>
