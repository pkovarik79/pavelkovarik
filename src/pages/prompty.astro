---
import Base from '../layouts/Base.astro';
import { getPromptLibraryData } from '../lib/wp-materials';

const promptLibrary = getPromptLibraryData();
---

<Base title="Knihovna AI promptů pro firmy | Pavel Kovařík" description="Praktické AI prompty, které používám ve školeních. Kategorizované podle použití, okamžitě použitelné šablony.">
  <div class="lp-page" id="prompt-library-page">
    <section class="lp-hero">
      <div class="wrap">
        <span class="lp-badge">MATERIÁLY</span>
        <h1>Knihovna AI promptů pro firmy</h1>
        <p class="lp-subtitle">Praktické AI prompty které používám ve školeních. Kategorizované podle použití - komunikace, analýza, obsah. Okamžitě použitelné šablony.</p>
      </div>
    </section>

    <section class="prompt-shell" id="prompt-library">
      <div class="wrap">
        <div class="prompt-controls">
          <div class="prompt-search-row">
            <label class="prompt-search-label" for="prompt-search">Hledat</label>
            <input id="prompt-search" class="prompt-search" type="search" placeholder="Název nebo popis promptu..." />
            <button type="button" class="prompt-clear" id="prompt-clear" hidden>Vymazat</button>
          </div>

          <div class="prompt-filters" role="toolbar" aria-label="Filtry promptů">
            {promptLibrary.filters.map((filter, index) => (
              <button
                type="button"
                class:list={['prompt-filter', index === 0 && 'is-active']}
                data-filter={filter.key}
              >
                {filter.label}
              </button>
            ))}
          </div>
        </div>

        <div id="prompt-empty" class="prompt-empty" hidden>
          <p>Pro toto hledání jsem nic nenašel.</p>
        </div>

        <div class="prompt-groups">
          {promptLibrary.categories.map((category) => (
            <section class="prompt-group" data-category={category.slug}>
              <h2 class="prompt-group-title">{category.title}</h2>

              {category.introHtml && (
                <div class="prompt-group-intro prose-lite" set:html={category.introHtml}></div>
              )}

              {category.prompts.map((prompt) => (
                <details class="prompt-card" data-search={[prompt.title, prompt.description, prompt.content, category.title].join(' ')}>
                  <summary>{prompt.title}</summary>
                  <div class="prompt-card-body">
                    {prompt.description && <p class="prompt-card-desc">{prompt.description}</p>}
                    <pre class="prompt-card-content">{prompt.content}</pre>
                    <button type="button" class="prompt-copy" data-copy={prompt.content}>Kopírovat</button>
                  </div>
                </details>
              ))}
            </section>
          ))}
        </div>
      </div>
    </section>
  </div>

  <script>
    const root = document.getElementById('prompt-library');
    if (root) {
      const search = root.querySelector('#prompt-search');
      const clear = root.querySelector('#prompt-clear');
      const filters = Array.from(root.querySelectorAll('.prompt-filter'));
      const groups = Array.from(root.querySelectorAll('.prompt-group'));
      const empty = root.querySelector('#prompt-empty');
      let activeFilter = 'all';

      const normalize = (value) =>
        (value || '')
          .toLowerCase()
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .trim();

      const refresh = () => {
        const query = normalize(search instanceof HTMLInputElement ? search.value : '');
        let visibleCount = 0;

        groups.forEach((group) => {
          const groupKey = group.getAttribute('data-category') || '';
          const filterMatch = activeFilter === 'all' || activeFilter === groupKey;
          let visibleInGroup = 0;

          group.querySelectorAll('.prompt-card').forEach((card) => {
            const haystack = normalize(card.getAttribute('data-search'));
            const visible = filterMatch && (!query || haystack.includes(query));
            card.hidden = !visible;
            if (visible) {
              visibleInGroup += 1;
              visibleCount += 1;
            }
          });

          group.hidden = visibleInGroup === 0;
        });

        if (clear) {
          clear.hidden = !query;
        }

        if (empty) {
          empty.hidden = visibleCount > 0;
        }
      };

      filters.forEach((button) => {
        button.addEventListener('click', () => {
          activeFilter = button.getAttribute('data-filter') || 'all';
          filters.forEach((item) => item.classList.toggle('is-active', item === button));
          refresh();
        });
      });

      search?.addEventListener('input', refresh);

      clear?.addEventListener('click', () => {
        if (search instanceof HTMLInputElement) {
          search.value = '';
          search.focus();
        }
        activeFilter = 'all';
        filters.forEach((item, index) => item.classList.toggle('is-active', index === 0));
        refresh();
      });

      root.querySelectorAll('.prompt-copy').forEach((button) => {
        button.addEventListener('click', async () => {
          const text = button.getAttribute('data-copy') || '';
          try {
            await navigator.clipboard.writeText(text);
            const original = button.textContent;
            button.textContent = 'Zkopírováno';
            button.classList.add('is-copied');
            window.setTimeout(() => {
              button.textContent = original;
              button.classList.remove('is-copied');
            }, 1800);
          } catch {
            button.textContent = 'Kopírování selhalo';
          }
        });
      });

      refresh();
    }
  </script>

  <style>
    .prompt-shell {
      padding: 2.6rem 0 4rem;
      background: var(--pk-bg-alt);
    }

    .prompt-controls {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .prompt-search-row {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.85rem;
      align-items: center;
    }

    .prompt-search-label {
      font-size: 0.85rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--pk-text);
    }

    .prompt-search,
    .prompt-clear {
      height: 3.4rem;
      border-radius: 0.95rem;
      border: 2px solid var(--pk-border);
      font: inherit;
      background: #fff;
    }

    .prompt-search {
      width: 100%;
      padding: 0 1rem;
      color: var(--pk-text);
    }

    .prompt-search:focus {
      outline: none;
      border-color: var(--pk-primary);
      box-shadow: 0 0 0 4px rgba(61, 92, 217, 0.12);
    }

    .prompt-clear {
      padding: 0 1.15rem;
      font-weight: 800;
      color: var(--pk-text);
      cursor: pointer;
    }

    .prompt-filters {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
    }

    .prompt-filter {
      border: 2px solid var(--pk-border);
      background: #fff;
      color: var(--pk-text);
      border-radius: 999px;
      padding: 0.8rem 1.15rem;
      font-weight: 800;
      cursor: pointer;
      transition: 0.2s ease;
    }

    .prompt-filter:hover {
      border-color: var(--pk-primary);
      color: var(--pk-primary);
    }

    .prompt-filter.is-active {
      background: var(--pk-primary);
      border-color: var(--pk-primary);
      color: #fff;
    }

    .prompt-group {
      margin-bottom: 2.8rem;
    }

    .prompt-group-title {
      font-size: 1.42rem;
      color: var(--pk-primary);
      padding-bottom: 0.55rem;
      border-bottom: 3px solid var(--pk-primary);
      margin: 0 0 1.1rem;
    }

    .prompt-group-intro {
      margin-bottom: 1.25rem;
    }

    .prose-lite > *:last-child {
      margin-bottom: 0;
    }

    .prose-lite h4 {
      color: var(--pk-primary);
      margin: 0 0 0.7rem;
      font-size: 1.1rem;
    }

    .prose-lite p,
    .prose-lite ol,
    .prose-lite ul {
      color: var(--pk-text-2);
      margin-bottom: 0.9rem;
    }

    .prose-lite ol,
    .prose-lite ul {
      padding-left: 1.4rem;
    }

    .prose-lite strong {
      color: var(--pk-text);
    }

    .prose-lite {
      background: linear-gradient(135deg, #f0f4ff 0%, #e8eeff 100%);
      border: 2px solid rgba(61, 92, 217, 0.18);
      border-radius: 1rem;
      padding: 1.25rem 1.25rem 1.1rem;
    }

    .prompt-card {
      background: #fff;
      border: 1px solid var(--pk-border);
      border-radius: 1rem;
      margin-bottom: 0.8rem;
      transition: 0.2s ease;
      box-shadow: 0 2px 8px rgba(15, 23, 42, 0.04);
      overflow: hidden;
    }

    .prompt-card:hover {
      border-color: var(--pk-primary);
      box-shadow: 0 8px 20px rgba(15, 23, 42, 0.07);
    }

    .prompt-card summary {
      list-style: none;
      cursor: pointer;
      padding: 1.05rem 1.2rem;
      color: var(--pk-primary);
      font-size: 1.02rem;
      font-weight: 800;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .prompt-card summary::-webkit-details-marker {
      display: none;
    }

    .prompt-card summary::after {
      content: '▼';
      font-size: 0.74rem;
      color: var(--pk-text-3);
      transition: transform 0.2s ease;
    }

    .prompt-card[open] summary::after {
      transform: rotate(180deg);
    }

    .prompt-card-body {
      padding: 0 1.2rem 1.2rem;
    }

    .prompt-card-desc {
      color: var(--pk-text-2);
      font-style: italic;
      margin: 0 0 1rem;
    }

    .prompt-card-content {
      background: #f8fafc;
      border: 1px solid var(--pk-border);
      border-radius: 0.8rem;
      padding: 1rem;
      white-space: pre-wrap;
      line-height: 1.75;
      font-size: 0.92rem;
      color: var(--pk-text);
      overflow-x: auto;
      margin: 0 0 0.85rem;
      font-family: 'SFMono-Regular', 'Consolas', 'Monaco', monospace;
    }

    .prompt-copy {
      border: none;
      background: var(--pk-primary);
      color: #fff;
      border-radius: 0.7rem;
      padding: 0.72rem 1rem;
      font-weight: 800;
      cursor: pointer;
    }

    .prompt-copy.is-copied {
      background: var(--pk-green);
    }

    .prompt-empty {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--pk-text-2);
    }

    @media (max-width: 768px) {
      .prompt-search-row {
        grid-template-columns: 1fr;
      }

      .prompt-search-label {
        display: none;
      }

      .prompt-card summary {
        font-size: 0.96rem;
      }
    }
  </style>
</Base>
