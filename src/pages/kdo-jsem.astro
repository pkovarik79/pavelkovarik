---
import Base from '../layouts/Base.astro';
import '../styles/global.css';

const logos = [
  { src: '/images/loga/ceska-sporitelna.webp', alt: 'Česká spořitelna' },
  { src: '/images/loga/partners.webp', alt: 'Partners' },
  { src: '/images/loga/ptacek.webp', alt: 'Ptáček' },
  { src: '/images/loga/dopravni-podnik-pardubice.webp', alt: 'Dopravní podnik města Pardubice' },
  { src: '/images/loga/broker-consulting.webp', alt: 'Broker Consulting' },
  { src: '/images/loga/proventiacz.webp', alt: 'Proventia CZ' },
  { src: '/images/loga/dt-vyhybkarna.webp', alt: 'DT Výhybkárna a strojírna' },
  { src: '/images/loga/khk-pardubicky-kraj.webp', alt: 'KHK Pardubického kraje' },
  { src: '/images/loga/rubikon.webp', alt: 'Rubikon' },
  { src: '/images/loga/narodni-strojirenskyy-klastr.webp', alt: 'Národní strojírenský klastr' },
  { src: '/images/loga/mm-reality.webp', alt: 'M&M Reality' },
  { src: '/images/loga/matikon.webp', alt: 'Matikon' },
  { src: '/images/loga/vak-hodonin.webp', alt: 'VAK Hodonín' },
  { src: '/images/loga/veacom.webp', alt: 'VEACOM' },
  { src: '/images/loga/ibv-nbs.webp', alt: 'IBV NBS' },
  { src: '/images/loga/makovec.webp', alt: 'Makovec' },
];

const principles = [
  {
    title: 'Prakticky od první chvíle',
    text: 'Neukazuji jen funkce, ale postupy, které lidé opravdu využijí v práci.',
  },
  {
    title: 'Srozumitelně a bez technického balastu',
    text: 'Složité věci vysvětluji tak, aby jim rozuměli i lidé, kteří AI běžně neřeší.',
  },
  {
    title: 'Podle reálné situace ve firmě',
    text: 'Obsah školení přizpůsobuji vašemu oboru, rolím i tomu, co dnes ve firmě opravdu řešíte.',
  },
  {
    title: 'Bezpečně a s rozumem',
    text: 'Ukazuji nejen možnosti AI, ale i limity, rizika a pravidla pro bezpečnější používání.',
  },
];
---

<Base title="Pavel Kovařík – AI lektor a konzultant pro firmy" description="Jsem lektor a konzultant, který učí firmy využívat AI prakticky a bezpečně. Pomáhám lidem ve firmách šetřit čas a zvyšovat produktivitu už od prvního dne.">
  <section class="about-hero">
    <div class="wrap about-hero-inner">
      <span class="about-pill">O MNĚ</span>
      <h1>Pavel Kovařík</h1>
      <p class="about-hero-subtitle">AI lektor, který rozumí lidem i byznysu</p>

      <div class="about-meta-bar">
        <span><i></i>Proškolil 1000+ zaměstnanců</span>
        <span><i></i>20 let v byznysu</span>
        <span><i></i>Denně pracuji s AI</span>
      </div>

      <div class="about-hero-actions">
        <a href="/skoleni/" class="btn about-btn-light">Nabídka školení</a>
        <a href="/kontakt/" class="btn about-btn-outline">Poptat školení</a>
      </div>
    </div>
  </section>

  <section class="about-proof">
    <div class="wrap">
      <div class="about-proof-card">
        <h2>Praktická školení AI pro firmy</h2>
        <p>Proškolil jsem už přes 1 000 zaměstnanců ve firmách a institucích napříč obory. Školím prakticky, srozumitelně a s ohledem na reálný provoz firmy.</p>
        <div class="about-mini-quote">
          <p>„Toto je z kategorie must have.“</p>
          <strong>Ing. Zdeněk Gonsorčík, Ph.D.</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="sec-head">
        <h2>Firmy a instituce, které jsem školil</h2>
      </div>
      <div class="logos-grid about-logos-grid">
        {logos.map((logo) => (
          <div class="about-logo-card">
            <img src={logo.src} alt={logo.alt} loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="sec-head">
        <h2>Jak pracuji s firmami při AI školení</h2>
      </div>
      <div class="grid grid-2">
        {principles.map((item) => (
          <article class="card about-principle-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="about-journey-box">
        <h2>Co si do AI školení přináším z praxe</h2>
        <p>20 let se pohybuji v byznysu – nejprve ve firmách, od roku 2008 jako samostatný konzultant v PR a marketingu. Rozumím tomu, jak ve firmách fungují procesy, komunikace i každodenní provoz.</p>
        <p>Proto AI nevysvětluji jako technologickou novinku, ale jako nástroj, který má lidem ulevit v práci, šetřit čas a dávat smysl v konkrétní firemní realitě.</p>
        <p>Sleduji vývoj nástrojů, testuji je na vlastních projektech a do školení vybírám jen to, co se dá opravdu použít v praxi.</p>

        <div class="about-info-box">
          <h3>Co to znamená pro vaši firmu</h3>
          <p>Dostanete školení od člověka, který rozumí nejen nástrojům, ale i tomu, jak fungují lidé, týmy a změna ve firmě.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="about-cta">
    <div class="wrap about-cta-inner">
      <h2>Chcete zjistit, jak by AI mohla dávat smysl právě u vás ve firmě?</h2>
      <p>Ozvěte se mi. Navrhnu vám školení podle toho, co ve vaší firmě opravdu potřebujete.</p>
      <div class="about-hero-actions">
        <a href="/kontakt/" class="btn about-btn-light">Poptat AI školení</a>
        <a href="tel:+420770126519" class="btn about-btn-outline">Zavolat</a>
      </div>
      <div class="about-cta-contact">+420 770 126 519 · mail@pavelkovarik.cz</div>
      <p class="about-cta-note">Odpovím do 24 hodin · Nezávazná domluva · Školení přizpůsobené vaší firmě</p>
    </div>
  </section>
</Base>

<style>
  .about-hero,
  .about-cta {
    background: linear-gradient(135deg, var(--pk-primary) 0%, var(--pk-primary-dark) 100%);
    color: #fff;
  }

  .about-hero {
    padding: 3.8rem 0 7rem;
    text-align: center;
  }

  .about-hero-inner,
  .about-cta-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .about-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: .5rem 1.2rem;
    border-radius: 999px;
    background: rgba(255,255,255,.15);
    border: 1px solid rgba(255,255,255,.14);
    font-size: .9rem;
    font-weight: 700;
    margin-bottom: 1.3rem;
  }

  .about-hero h1,
  .about-cta h2 {
    color: #fff;
    margin-bottom: .9rem;
  }

  .about-hero-subtitle,
  .about-cta p {
    font-size: clamp(1.05rem, 1.9vw, 1.22rem);
    line-height: 1.65;
    color: rgba(255,255,255,.95);
    max-width: 680px;
    margin: 0 auto 1.5rem;
  }

  .about-meta-bar {
    display: flex;
    justify-content: center;
    gap: 1.35rem 2rem;
    flex-wrap: wrap;
    margin-bottom: 1.65rem;
  }

  .about-meta-bar span {
    display: inline-flex;
    align-items: center;
    gap: .6rem;
    font-weight: 600;
    font-size: .95rem;
    color: rgba(255,255,255,.95);
  }

  .about-meta-bar i {
    width: .55rem;
    height: .55rem;
    border-radius: 999px;
    background: rgba(255,255,255,.78);
    display: inline-block;
  }

  .about-hero-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .about-btn-light {
    background: #fff;
    color: var(--pk-primary);
    box-shadow: 0 8px 26px rgba(0,0,0,.12);
  }

  .about-btn-light:hover {
    color: var(--pk-primary-dark);
    background: #f8fafc;
  }

  .about-btn-outline {
    background: transparent;
    border: 2px solid rgba(255,255,255,.42);
    color: #fff;
  }

  .about-btn-outline:hover {
    border-color: #fff;
    color: #fff;
    background: rgba(255,255,255,.08);
  }

  .about-proof {
    margin-top: -3.2rem;
    position: relative;
    z-index: 2;
  }

  .about-proof-card {
    max-width: 760px;
    margin: 0 auto;
    background: #fff;
    border: 2px solid var(--pk-primary);
    border-radius: 16px;
    padding: 1.65rem 2.1rem;
    text-align: center;
    box-shadow: 0 12px 30px rgba(61,92,217,.14);
  }

  .about-proof-card h2 {
    color: var(--pk-primary);
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    margin-bottom: .65rem;
  }

  .about-proof-card p {
    color: var(--pk-text-2);
    font-size: .98rem;
    line-height: 1.65;
  }

  .about-mini-quote {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(61,92,217,.12);
  }

  .about-mini-quote p {
    font-style: italic;
    color: var(--pk-text);
    margin-bottom: .4rem;
  }

  .about-mini-quote strong {
    color: var(--pk-primary);
    font-size: .98rem;
  }

  .about-logos-grid {
    max-width: 900px;
    margin: 0 auto;
    gap: 1.15rem 1.35rem;
  }

  .about-logo-card {
    width: 100%;
    min-height: 84px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: .95rem;
    background: #fff;
    border: 1px solid var(--pk-border);
    border-radius: 10px;
    box-shadow: none;
    transition: transform .28s ease, border-color .28s ease, box-shadow .28s ease;
  }

  .about-logo-card:hover {
    transform: translateY(-3px);
    border-color: rgba(61,92,217,.35);
    box-shadow: 0 8px 20px rgba(15,23,42,.08);
  }

  .about-logo-card img {
    max-height: 56px;
    width: auto;
    filter: grayscale(1);
    opacity: .72;
    transition: filter .28s ease, opacity .28s ease;
  }

  .about-logo-card:hover img {
    filter: grayscale(0);
    opacity: 1;
  }

  .about-principle-card {
    padding: 1.75rem 1.8rem;
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(15,23,42,.06);
    border-top: 3px solid rgba(61,92,217,.18);
  }

  .about-principle-card h3 {
    font-size: clamp(1.18rem, 1.8vw, 1.34rem);
    margin-bottom: .7rem;
  }

  .about-principle-card p {
    font-size: .99rem;
    line-height: 1.72;
  }

  .about-journey-box {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3rem 2.5rem;
    border-radius: 16px;
    background: linear-gradient(135deg, #f8fbff 0%, #edf4ff 100%);
    border: 1px solid rgba(61,92,217,.12);
  }

  .about-journey-box h2 {
    text-align: center;
    margin-bottom: 1.35rem;
    font-size: clamp(1.8rem, 3vw, 2rem);
  }

  .about-journey-box p {
    font-size: 1.08rem;
    line-height: 1.8;
    max-width: 820px;
    margin: 0 auto 1rem;
  }

  .about-info-box {
    max-width: 650px;
    margin: 1.7rem auto 0;
    padding: 1.6rem 1.75rem;
    border-radius: 16px;
    border: 2px solid rgba(61,92,217,.18);
    background: linear-gradient(135deg, #f5f8ff 0%, #eef3ff 100%);
    text-align: center;
  }

  .about-info-box h3 {
    font-size: clamp(1.2rem, 2vw, 1.45rem);
    margin-bottom: .55rem;
  }

  .about-info-box p {
    margin: 0;
    font-size: 1rem;
  }

  .about-cta {
    margin-top: .75rem;
    padding: 4rem 0;
    text-align: center;
  }

  .about-cta h2 {
    font-size: clamp(1.7rem, 2.8vw, 1.95rem);
  }

  .about-cta-contact {
    font-weight: 700;
    font-size: 1.05rem;
    margin-top: 1.5rem;
    letter-spacing: -.01em;
  }

  .about-cta-note {
    margin-top: .7rem;
    margin-bottom: 0;
    font-size: .98rem;
    color: rgba(255,255,255,.88);
  }

  @media (max-width: 768px) {
    .about-hero {
      padding: 3rem 0 5rem;
    }

    .about-hero h1 {
      font-size: clamp(2.1rem, 10vw, 2.65rem);
    }

    .about-hero-subtitle {
      font-size: 1.02rem;
      line-height: 1.55;
      max-width: 320px;
      margin-bottom: 1.25rem;
    }

    .about-proof-card,
    .about-journey-box,
    .about-cta-inner {
      padding: 1.55rem 1.25rem;
    }

    .about-meta-bar {
      flex-direction: column;
      align-items: center;
      gap: .75rem;
      margin-bottom: 1.35rem;
    }

    .about-meta-bar span {
      width: 100%;
      justify-content: center;
      max-width: 320px;
      font-size: .9rem;
    }

    .about-hero-actions {
      gap: .8rem;
    }

    .about-proof {
      margin-top: -2.6rem;
    }

    .about-proof-card {
      border-radius: 14px;
      padding: 1.35rem 1.15rem;
    }

    .about-proof-card h2 {
      font-size: 1.08rem;
      line-height: 1.35;
    }

    .about-proof-card p,
    .about-mini-quote p,
    .about-mini-quote strong {
      font-size: .95rem;
    }

    .about-principle-card {
      padding: 1.4rem 1.2rem;
    }

    .about-principle-card h3 {
      font-size: 1.1rem;
    }

    .about-principle-card p {
      font-size: .96rem;
      line-height: 1.65;
    }

    .about-logos-grid {
      gap: 1rem;
    }

    .about-logo-card {
      min-height: 76px;
      padding: .8rem;
    }

    .about-logo-card img {
      max-height: 46px;
    }

    .about-journey-box {
      padding: 1.85rem 1.25rem;
      border-radius: 14px;
    }

    .about-journey-box h2 {
      font-size: 1.55rem;
      line-height: 1.2;
      margin-bottom: 1rem;
    }

    .about-journey-box p {
      font-size: 1rem;
      line-height: 1.7;
      margin-bottom: .85rem;
    }

    .about-info-box {
      padding: 1.35rem 1.1rem;
      margin-top: 1.25rem;
    }

    .about-info-box h3 {
      font-size: 1.08rem;
    }

    .about-info-box p {
      font-size: .95rem;
      line-height: 1.6;
    }

    .about-cta {
      padding: 3.2rem 0;
    }

    .about-cta h2 {
      font-size: 1.6rem;
      line-height: 1.2;
    }

    .about-cta p {
      font-size: 1rem;
      line-height: 1.6;
      max-width: 320px;
    }

    .about-cta-contact {
      font-size: .98rem;
      line-height: 1.5;
    }

    .about-cta-note {
      font-size: .92rem;
      line-height: 1.55;
    }
  }
</style>
