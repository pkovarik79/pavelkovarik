---
import Base from '../layouts/Base.astro';
import '../styles/global.css';

const trainingOptions = [
  'Praktické školení AI pro firmy',
  'AI pro manažery',
  'AI pro veřejnou správu',
  'Microsoft Copilot',
  'Školení na míru nebo jiný typ',
  'Chci něco jiného',
];
---

<Base title="Kontakt a poptávka školení | Pavel Kovařík" description="Do 24 hodin se Vám ozvu s návrhem obsahu školení a možnými termíny.">
  <section class="contact-hero">
    <div class="wrap contact-hero-inner">
      <span class="contact-pill">KONTAKT</span>
      <h1>Kontakt a poptávka školení</h1>
      <p class="contact-hero-lead">Do 24 hodin se Vám ozvu s návrhem obsahu školení a možnými termíny.</p>

      <div class="contact-stat-pills">
        <span>🕒 Odpověď do 24 hodin</span>
        <span>🏢 On-line i u vás ve firmě</span>
        <span>✔️ Nezávazná poptávka</span>
      </div>
    </div>
  </section>

  <section class="contact-cards-section">
    <div class="wrap">
      <div class="grid grid-3 contact-cards-grid">
        <article class="card contact-card">
          <div class="contact-card-icon">📞</div>
          <h3>Zavolejte mi</h3>
          <p>Nejrychlejší cesta pro domluvu termínu nebo rychlý dotaz.</p>
          <a href="tel:+420770126519" class="btn btn-p contact-card-button">+420 770 126 519</a>
          <div class="contact-card-meta">Po–Pá 9:00 - 17:00</div>
        </article>

        <article class="card contact-card">
          <div class="contact-card-icon">✉️</div>
          <h3>Napište e-mail</h3>
          <p>Preferujete písemnou komunikaci? Napište mi své požadavky.</p>
          <a href="mailto:mail@pavelkovarik.cz" class="btn btn-p contact-card-button">mail@pavelkovarik.cz</a>
          <div class="contact-card-meta">Odpovídám do 24 hodin</div>
        </article>

        <article class="card contact-card">
          <div class="contact-card-icon">in</div>
          <h3>Spojme se</h3>
          <p>Sledujte novinky ze světa AI nebo mi napište zprávu přímo tam.</p>
          <a href="https://www.linkedin.com/in/pkovarik/" target="_blank" rel="noopener" class="btn btn-p contact-card-button">Profil LinkedIn</a>
          <div class="contact-card-meta">Profesní síť</div>
        </article>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="contact-form-shell">
        <div class="sec-head">
          <h2>Nezávazná poptávka školení AI</h2>
          <p>Stačí stručně. Detaily doladíme později.</p>
        </div>

        <form class="contact-form" id="contact-form" novalidate>
          <div class="contact-form-grid">
            <div class="form-group">
              <label for="name">Jméno a příjmení (povinné)</label>
              <input type="text" id="name" name="name" required placeholder="Jan Novák" />
            </div>

            <div class="form-group">
              <label for="email">E-mail (povinné)</label>
              <input type="email" id="email" name="email" required placeholder="jan.novak@firma.cz" />
            </div>

            <div class="form-group">
              <label for="phone">Telefon (povinné)</label>
              <input type="tel" id="phone" name="phone" required placeholder="+420 770 126 519" />
            </div>

            <div class="form-group">
              <label for="company">Firma / Organizace (povinné)</label>
              <input type="text" id="company" name="company" required placeholder="Název vaší firmy" />
            </div>

            <div class="form-group form-group-full">
              <label for="teamSize">Kolik lidí chcete proškolit?</label>
              <select id="teamSize" name="teamSize">
                <option value="">Vyberte velikost skupiny</option>
                <option value="1 až 6 osob">1 až 6 osob</option>
                <option value="7 až 15 osob">7 až 15 osob</option>
                <option value="16 až 30 osob">16 až 30 osob</option>
                <option value="31 až 60 osob">31 až 60 osob</option>
                <option value="60+ osob">60+ osob</option>
              </select>
            </div>

            <fieldset class="form-group form-group-full contact-checklist">
              <legend>O jaké školení máte zájem? (můžete vybrat více možností)</legend>
              <div class="contact-checklist-grid">
                {trainingOptions.map((option) => (
                  <label class="contact-check-item">
                    <input type="checkbox" name="interests" value={option} />
                    <span>{option}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <div class="form-group form-group-full">
              <label for="message">Poznámka nebo dotaz</label>
              <textarea
                id="message"
                name="message"
                rows="6"
                placeholder="Například: Preferujeme školení v dubnu, chceme se zaměřit na marketing, Copilot a konkrétní interní workflow..."
              ></textarea>
            </div>

            <div class="form-group form-honeypot" aria-hidden="true">
              <label for="website">Webová stránka</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
            </div>
          </div>

          <button type="submit" class="btn btn-p contact-submit-button" id="contact-submit">Odeslat nezávaznou poptávku</button>
          <p class="form-note">Odesláním formuláře souhlasíte se <a href="/gdpr-ochrana-osobnich-udaju/">zpracováním osobních údajů</a>.</p>
          <p class="form-note form-note-secondary">Formulář je chráněný jednoduchou antispam kontrolou. Odeslané údaje použiji pouze pro vyřízení poptávky.</p>
          <p class="contact-billing"><strong>Fakturační údaje:</strong> Ing. Bc. Pavel Kovařík, IČO: 76233006, Hromádkova 4020/22, 636 00 Brno</p>
          <h3 class="form-message form-message-success" aria-live="polite">Děkuji, zpráva byla odeslána. Ozvu se co nejdříve.</h3>
          <h3 class="form-message form-message-error" aria-live="polite">Nepodařilo se odeslat formulář.</h3>
        </form>
      </div>
    </div>
  </section>

  <section class="contact-cta">
    <div class="wrap contact-cta-inner">
      <h2>Nenašli jste, co hledáte?</h2>
      <p>Podívejte se na kompletní přehled školení, která nabízím.</p>
      <a href="/skoleni/" class="btn contact-btn-light">Zobrazit nabídku školení</a>
    </div>
  </section>
</Base>

<style>
  .contact-hero,
  .contact-cta {
    background: linear-gradient(135deg, var(--pk-primary) 0%, var(--pk-primary-dark) 100%);
    color: #fff;
  }

  .contact-hero {
    text-align: center;
    padding: 4.8rem 0 8rem;
  }

  .contact-hero-inner,
  .contact-cta-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .contact-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: .55rem 1.25rem;
    border-radius: 999px;
    background: rgba(255,255,255,.14);
    border: 1px solid rgba(255,255,255,.16);
    font-size: .9rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

  .contact-hero h1,
  .contact-cta h2 {
    color: #fff;
    margin-bottom: 1rem;
  }

  .contact-hero-lead,
  .contact-cta p {
    color: rgba(255,255,255,.94);
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    max-width: 760px;
    line-height: 1.7;
    margin: 0 auto 1.7rem;
  }

  .contact-stat-pills {
    display: flex;
    justify-content: center;
    gap: .85rem;
    flex-wrap: wrap;
  }

  .contact-stat-pills span {
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    padding: .8rem 1.2rem;
    border-radius: 999px;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.18);
    font-weight: 700;
    font-size: .95rem;
  }

  .contact-cards-section {
    margin-top: -5rem;
    position: relative;
    z-index: 2;
  }

  .contact-cards-grid {
    gap: 1.8rem;
  }

  .contact-card {
    text-align: center;
    padding: 2.5rem 2rem;
    box-shadow: 0 18px 42px rgba(61,92,217,.16);
  }

  .contact-card-icon {
    width: 76px;
    height: 76px;
    margin: 0 auto 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 22px;
    background: linear-gradient(135deg, #eef3ff 0%, #e7efff 100%);
    color: var(--pk-primary);
    font-size: 2rem;
    font-weight: 800;
  }

  .contact-card h3 {
    font-size: clamp(1.35rem, 2.2vw, 1.65rem);
    margin-bottom: .6rem;
  }

  .contact-card p {
    font-size: 1rem;
    line-height: 1.75;
    min-height: 5.2rem;
  }

  .contact-card-button {
    width: 100%;
    justify-content: center;
    margin-top: .9rem;
  }

  .contact-card-meta {
    margin-top: 1rem;
    color: var(--pk-text-3);
    font-size: .95rem;
  }

  .contact-form-shell {
    max-width: 930px;
    margin: 0 auto;
    background: #fff;
    border: 1px solid var(--pk-border);
    border-radius: 22px;
    padding: 2.4rem 2.5rem;
    box-shadow: 0 4px 20px rgba(15,23,42,.05);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .contact-form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: .45rem;
  }

  .form-group-full {
    grid-column: 1 / -1;
  }

  .form-group label,
  .contact-checklist legend {
    font-size: .98rem;
    font-weight: 700;
    color: var(--pk-text);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: .95rem 1.1rem;
    border: 1px solid #d1d5db;
    border-radius: 12px;
    background: #f9fafb;
    color: var(--pk-text);
    font-size: 1rem;
    font-family: inherit;
    transition: border-color .2s, box-shadow .2s, background-color .2s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--pk-primary);
    background: #fff;
    box-shadow: 0 0 0 4px rgba(61,92,217,.1);
  }

  .contact-checklist {
    border: 0;
    padding: 0;
    margin: 0;
  }

  .contact-checklist-grid {
    display: grid;
    gap: .9rem;
    margin-top: .4rem;
  }

  .contact-check-item {
    display: flex;
    align-items: center;
    gap: .8rem;
    font-size: 1rem;
    color: var(--pk-text);
  }

  .contact-check-item input {
    width: 22px;
    height: 22px;
    accent-color: var(--pk-primary);
    flex-shrink: 0;
  }

  .form-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .contact-submit-button {
    width: 100%;
    justify-content: center;
    min-width: 0;
  }

  .form-message {
    display: none;
    font-size: 1rem;
    margin: .25rem 0 0;
  }

  .form-message-success {
    color: #0f8a45;
  }

  .form-message-error {
    color: #c53030;
  }

  .form-note {
    font-size: .95rem;
    color: var(--pk-text-3);
    text-align: center;
    margin-top: .25rem;
  }

  .form-note-secondary {
    margin-top: -.5rem;
  }

  .contact-billing {
    text-align: center;
    color: var(--pk-text-2);
    font-size: .98rem;
    margin-top: .2rem;
  }

  .contact-cta {
    margin-top: 2rem;
    padding: 4.6rem 0;
    text-align: center;
  }

  .contact-btn-light {
    background: #fff;
    color: var(--pk-primary);
    box-shadow: 0 8px 26px rgba(0,0,0,.12);
  }

  .contact-btn-light:hover {
    color: var(--pk-primary-dark);
    background: #f8fafc;
  }

  @media (max-width: 900px) {
    .contact-form-grid {
      grid-template-columns: 1fr;
    }

    .contact-card p {
      min-height: 0;
    }
  }

  @media (max-width: 768px) {
    .contact-hero {
      padding: 3.8rem 0 6.6rem;
    }

    .contact-stat-pills {
      flex-direction: column;
      align-items: center;
    }

    .contact-stat-pills span {
      width: 100%;
      justify-content: center;
      max-width: 360px;
    }

    .contact-form-shell {
      padding: 1.5rem 1.2rem;
    }

    .contact-card {
      padding: 2rem 1.4rem;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form');
  const submitButton = document.getElementById('contact-submit');
  const successMessage = form?.querySelector('.form-message-success');
  const errorMessage = form?.querySelector('.form-message-error');

  const setMessage = (type, text) => {
    if (successMessage) successMessage.textContent = type === 'success' ? text : '';
    if (errorMessage) errorMessage.textContent = type === 'error' ? text : '';
    successMessage?.setAttribute('style', type === 'success' ? 'display:block;' : 'display:none;');
    errorMessage?.setAttribute('style', type === 'error' ? 'display:block;' : 'display:none;');
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const formData = new FormData(form);
    const name = String(formData.get('name') ?? '').trim();
    const email = String(formData.get('email') ?? '').trim();
    const phone = String(formData.get('phone') ?? '').trim();
    const company = String(formData.get('company') ?? '').trim();
    const teamSize = String(formData.get('teamSize') ?? '').trim();
    const message = String(formData.get('message') ?? '').trim();
    const website = String(formData.get('website') ?? '').trim();
    const interests = formData.getAll('interests').map((value) => String(value).trim()).filter(Boolean);

    const isValid = name && email && phone && company;
    setMessage('', '');

    if (!isValid) {
      setMessage('error', 'Vyplňte prosím jméno, e-mail, telefon a firmu.');
      return;
    }

    submitButton?.setAttribute('disabled', 'disabled');
    submitButton?.setAttribute('aria-busy', 'true');

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          name,
          email,
          phone,
          company,
          teamSize,
          interests,
          message,
          website,
        }),
      });

      const result = await response.json();

      if (!response.ok || !result.ok) {
        throw new Error(result.error || 'Nepodařilo se odeslat formulář.');
      }

      form.reset();
      setMessage('success', 'Děkuji, zpráva byla odeslána. Ozvu se co nejdříve.');
    } catch (error) {
      setMessage('error', error instanceof Error ? error.message : 'Nepodařilo se odeslat formulář.');
    } finally {
      submitButton?.removeAttribute('disabled');
      submitButton?.removeAttribute('aria-busy');
    }
  });
</script>
