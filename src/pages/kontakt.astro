---
import Base from '../layouts/Base.astro';
import '../styles/global.css';

const trainingOptions = [
  'Praktické školení AI pro firmy',
  'AI pro manažery',
  'AI pro veřejnou správu',
  'Microsoft Copilot',
  'Školení na míru nebo jiný typ',
  'Chci něco jiného',
];
---

<Base title="Kontakt – Pavel Kovařík, lektor a konzultant AI" description="Potřebujete školení nebo konzultaci o AI pro vaši firmu? Ozvěte se. Domluvíme si termín a společně vybereme formu, která vám dává smysl.">
  <section class="contact-hero">
    <div class="wrap contact-hero-inner">
      <span class="contact-pill">KONTAKT</span>
      <h1>Kontakt a poptávka školení</h1>
      <p class="contact-hero-lead">Do 24 hodin se Vám ozvu s návrhem obsahu školení a možnými termíny.</p>

      <div class="contact-stat-pills">
        <span>Odpověď do 24 hodin</span>
        <span>On-line i u vás ve firmě</span>
        <span>Nezávazná poptávka</span>
      </div>
    </div>
  </section>

  <section class="contact-cards-section">
    <div class="wrap">
      <div class="grid grid-3 contact-cards-grid">
        <article class="card contact-card">
          <div class="contact-card-icon">01</div>
          <h3>Zavolejte mi</h3>
          <p>Nejrychlejší cesta pro domluvu termínu nebo rychlý dotaz.</p>
          <a href="tel:+420770126519" class="btn btn-p contact-card-button">+420 770 126 519</a>
          <div class="contact-card-meta">Po-Pá 9:00 - 17:00</div>
        </article>

        <article class="card contact-card">
          <div class="contact-card-icon">02</div>
          <h3>Napište e-mail</h3>
          <p>Preferujete písemnou komunikaci? Napište mi své požadavky.</p>
          <a href="mailto:mail@pavelkovarik.cz" class="btn btn-p contact-card-button">mail@pavelkovarik.cz</a>
          <div class="contact-card-meta">Odpovídám do 24 hodin</div>
        </article>

        <article class="card contact-card">
          <div class="contact-card-icon">03</div>
          <h3>Spojme se</h3>
          <p>Sledujte novinky ze světa AI nebo mi napište zprávu přímo tam.</p>
          <a href="https://www.linkedin.com/in/pkovarik/" target="_blank" rel="noopener" class="btn btn-p contact-card-button">Profil LinkedIn</a>
          <div class="contact-card-meta">Profesní síť</div>
        </article>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="contact-form-shell">
        <div class="sec-head">
          <h2>Nezávazná poptávka školení AI</h2>
          <p>Stačí stručně. Detaily doladíme později.</p>
        </div>

        <form class="contact-form" id="contact-form" novalidate>
          <div class="contact-form-grid">
            <div class="form-group">
              <label for="name">Jméno a příjmení (povinné)</label>
              <input type="text" id="name" name="name" required placeholder="Jan Novák" />
            </div>

            <div class="form-group">
              <label for="email">E-mail (povinné)</label>
              <input type="email" id="email" name="email" required placeholder="jan.novak@firma.cz" />
            </div>

            <div class="form-group">
              <label for="phone">Telefon (povinné)</label>
              <input type="tel" id="phone" name="phone" required placeholder="+420 770 126 519" />
            </div>

            <div class="form-group">
              <label for="company">Firma / Organizace (povinné)</label>
              <input type="text" id="company" name="company" required placeholder="Název vaší firmy" />
            </div>

            <div class="form-group form-group-full">
              <label for="teamSize">Počet lidí</label>
              <select id="teamSize" name="teamSize">
                <option value="">Vyberte počet lidí</option>
                <option value="1 až 6 osob">1 až 6 osob</option>
                <option value="7 až 15 osob">7 až 15 osob</option>
                <option value="16 až 30 osob">16 až 30 osob</option>
                <option value="31 až 60 osob">31 až 60 osob</option>
                <option value="60+ osob">60+ osob</option>
              </select>
            </div>

            <fieldset class="form-group form-group-full contact-checklist">
              <legend>O jaké školení máte zájem? (Můžete vybrat více možností.)</legend>
              <div class="contact-checklist-grid">
                {trainingOptions.map((option) => (
                  <label class="contact-check-item">
                    <input type="checkbox" name="interests" value={option} />
                    <span>{option}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <div class="form-group form-group-full">
              <label for="message">Poznámka nebo dotaz</label>
              <textarea
                id="message"
                name="message"
                rows="6"
                placeholder="Například: Preferujeme školení v dubnu, chceme se zaměřit na marketing, Copilot a konkrétní interní workflow..."
              ></textarea>
            </div>

            <div class="form-group form-honeypot" aria-hidden="true">
              <label for="website">Webová stránka</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
            </div>
          </div>

          <button type="submit" class="btn btn-p contact-submit-button" id="contact-submit">Odeslat nezávaznou poptávku</button>
          <p class="form-note">Odesláním formuláře souhlasíte se <a href="/gdpr-ochrana-osobnich-udaju/">zpracováním osobních údajů</a>.</p>
          <p class="form-note form-note-secondary">Formulář je chráněný jednoduchou antispam kontrolou. Odeslané údaje použiji pouze pro vyřízení poptávky.</p>
          <p class="contact-billing"><strong>Fakturační údaje:</strong> Ing. Bc. Pavel Kovařík, IČO: 76233006, Hromádkova 4020/22, 636 00 Brno</p>
        </form>
      </div>
    </div>
  </section>

  <section class="contact-cta">
    <div class="wrap contact-cta-inner">
      <h2>Nenašli jste, co hledáte?</h2>
      <p>Podívejte se na kompletní přehled školení, která nabízím.</p>
      <a href="/skoleni/" class="btn contact-btn-light">Zobrazit nabídku školení</a>
    </div>
  </section>

  <div class="pk-modal" id="pkSuccessModal" aria-hidden="true">
    <div class="pk-modal-content" role="dialog" aria-modal="true" aria-labelledby="pk-success-title">
      <span class="pk-modal-icon" aria-hidden="true">✓</span>
      <h3 id="pk-success-title">Odesláno!</h3>
      <p>Díky! Vaši objednávku jsem obdržel.<br />Ozvu se vám do 24 hodin.</p>
      <button type="button" class="btn btn-p pk-modal-button" data-modal-close="pkSuccessModal">Skvělé, zavřít</button>
    </div>
  </div>

  <div class="pk-modal" id="pkErrorModal" aria-hidden="true">
    <div class="pk-modal-content" role="dialog" aria-modal="true" aria-labelledby="pk-error-title">
      <span class="pk-modal-icon" aria-hidden="true">!</span>
      <h3 id="pk-error-title">Chybí údaje</h3>
      <p id="pk-error-text">Zkontrolujte prosím formulář. Některá povinná pole nejsou vyplněna.</p>
      <button type="button" class="btn btn-p pk-modal-button" data-modal-close="pkErrorModal">Zkontrolovat formulář</button>
    </div>
  </div>
</Base>

<style>
  .contact-hero,
  .contact-cta {
    background: linear-gradient(135deg, var(--pk-primary) 0%, var(--pk-primary-dark) 100%);
    color: #fff;
  }

  .contact-hero {
    text-align: center;
    padding: 4.8rem 0 8rem;
  }

  .contact-hero-inner,
  .contact-cta-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .contact-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: .55rem 1.25rem;
    border-radius: 999px;
    background: rgba(255,255,255,.14);
    border: 1px solid rgba(255,255,255,.16);
    font-size: .9rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

  .contact-hero h1,
  .contact-cta h2 {
    color: #fff;
    margin-bottom: 1rem;
  }

  .contact-hero-lead,
  .contact-cta p {
    color: rgba(255,255,255,.94);
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    max-width: 760px;
    line-height: 1.7;
    margin: 0 auto 1.7rem;
  }

  .contact-stat-pills {
    display: flex;
    justify-content: center;
    gap: .85rem;
    flex-wrap: wrap;
  }

  .contact-stat-pills span {
    display: inline-flex;
    align-items: center;
    padding: .8rem 1.2rem;
    border-radius: 999px;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.18);
    font-weight: 700;
    font-size: .95rem;
  }

  .contact-cards-section {
    margin-top: -5rem;
    position: relative;
    z-index: 2;
  }

  .contact-cards-grid {
    gap: 1.35rem;
  }

  .contact-card {
    text-align: center;
    padding: 2rem 1.55rem;
    box-shadow: 0 12px 28px rgba(61,92,217,.13);
  }

  .contact-card-icon {
    width: 62px;
    height: 62px;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 18px;
    background: #f8fafc;
    border: 1px solid var(--pk-border);
    color: var(--pk-text);
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: .04em;
  }

  .contact-card h3 {
    font-size: clamp(1.2rem, 2vw, 1.4rem);
    margin-bottom: .45rem;
  }

  .contact-card p {
    font-size: .98rem;
    line-height: 1.65;
    min-height: 4.3rem;
  }

  .contact-card-button {
    width: 100%;
    justify-content: center;
    margin-top: .65rem;
    min-height: 48px;
    padding-inline: 1rem;
    font-size: .96rem;
  }

  .contact-card-meta {
    margin-top: .8rem;
    color: var(--pk-text-3);
    font-size: .92rem;
  }

  .contact-form-shell {
    max-width: 840px;
    margin: 0 auto;
    background: #fff;
    border: 1px solid var(--pk-border);
    border-radius: 18px;
    padding: 2rem 2rem;
    box-shadow: 0 4px 20px rgba(15,23,42,.05);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: .85rem;
  }

  .contact-form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem 1.15rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: .38rem;
  }

  .form-group-full {
    grid-column: 1 / -1;
  }

  .form-group label,
  .contact-checklist legend {
    font-size: .94rem;
    font-weight: 700;
    color: var(--pk-text);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: .82rem 1rem;
    border: 1px solid #d1d5db;
    border-radius: 10px;
    background: #f9fafb;
    color: var(--pk-text);
    font-size: .98rem;
    font-family: inherit;
    transition: border-color .2s, box-shadow .2s, background-color .2s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--pk-primary);
    background: #fff;
    box-shadow: 0 0 0 4px rgba(61,92,217,.1);
  }

  .contact-checklist {
    border: 0;
    padding: 0;
    margin: 0;
  }

  .contact-checklist-grid {
    display: grid;
    gap: .65rem;
    margin-top: .7rem;
  }

  .contact-check-item {
    display: flex;
    align-items: center;
    gap: .72rem;
    font-size: .96rem;
    color: var(--pk-text);
  }

  .contact-check-item span {
    font-weight: 500;
  }

  .contact-check-item input {
    width: 20px;
    height: 20px;
    accent-color: var(--pk-primary);
    flex-shrink: 0;
  }

  .form-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .contact-submit-button {
    width: 100%;
    justify-content: center;
    min-width: 0;
    min-height: 50px;
    font-size: .98rem;
  }

  .form-note {
    font-size: .9rem;
    color: var(--pk-text-3);
    text-align: center;
    margin-top: .15rem;
  }

  .form-note-secondary {
    margin-top: -.4rem;
  }

  .contact-billing {
    text-align: center;
    color: var(--pk-text-2);
    font-size: .93rem;
    margin-top: 0;
  }

  .contact-cta {
    margin-top: 2rem;
    padding: 4.6rem 0;
    text-align: center;
  }

  .contact-btn-light {
    background: #fff;
    color: var(--pk-primary);
    box-shadow: 0 8px 26px rgba(0,0,0,.12);
  }

  .contact-btn-light:hover {
    color: var(--pk-primary-dark);
    background: #f8fafc;
  }

  .pk-modal {
    position: fixed;
    inset: 0;
    z-index: 99999;
    display: none;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, .6);
    backdrop-filter: blur(5px);
    padding: 1.5rem;
  }

  .pk-modal.is-open {
    display: flex;
  }

  .pk-modal-content {
    width: min(100%, 450px);
    background: #fff;
    border-radius: 16px;
    padding: 2.5rem;
    text-align: center;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, .25);
  }

  .pk-modal-content h3 {
    margin-bottom: .65rem;
    font-size: 1.6rem;
  }

  .pk-modal-content p {
    margin-bottom: 1.6rem;
    color: var(--pk-text-2);
    font-size: 1.05rem;
  }

  .pk-modal-icon {
    display: block;
    margin-bottom: 1rem;
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1;
  }

  #pkSuccessModal .pk-modal-icon,
  #pkSuccessModal h3 {
    color: #10b981;
  }

  #pkErrorModal .pk-modal-icon,
  #pkErrorModal h3 {
    color: #ef4444;
  }

  .pk-modal-button {
    min-width: 0;
  }

  @media (max-width: 900px) {
    .contact-form-grid {
      grid-template-columns: 1fr;
    }

    .contact-card p {
      min-height: 0;
    }
  }

  @media (max-width: 768px) {
    .contact-hero {
      padding: 3.8rem 0 6.6rem;
    }

    .contact-stat-pills {
      flex-direction: column;
      align-items: center;
    }

    .contact-stat-pills span {
      width: 100%;
      justify-content: center;
      max-width: 360px;
    }

    .contact-form-shell {
      padding: 1.35rem 1rem;
    }

    .contact-form-grid {
      gap: .95rem;
    }

    .contact-card {
      padding: 1.65rem 1.2rem;
    }

    .contact-card p {
      min-height: 0;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form');
  const submitButton = document.getElementById('contact-submit');
  const successModal = document.getElementById('pkSuccessModal');
  const errorModal = document.getElementById('pkErrorModal');
  const errorText = document.getElementById('pk-error-text');

  const openModal = (modal) => {
    modal?.classList.add('is-open');
    modal?.setAttribute('aria-hidden', 'false');
  };

  const closeModal = (modal) => {
    modal?.classList.remove('is-open');
    modal?.setAttribute('aria-hidden', 'true');
  };

  document.querySelectorAll('[data-modal-close]').forEach((button) => {
    button.addEventListener('click', () => {
      const modalId = button.getAttribute('data-modal-close');
      if (!modalId) return;
      closeModal(document.getElementById(modalId));
    });
  });

  [successModal, errorModal].forEach((modal) => {
    modal?.addEventListener('click', (event) => {
      if (event.target === modal) {
        closeModal(modal);
      }
    });
  });

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeModal(successModal);
      closeModal(errorModal);
    }
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const formData = new FormData(form);
    const name = String(formData.get('name') ?? '').trim();
    const email = String(formData.get('email') ?? '').trim();
    const phone = String(formData.get('phone') ?? '').trim();
    const company = String(formData.get('company') ?? '').trim();
    const teamSize = String(formData.get('teamSize') ?? '').trim();
    const message = String(formData.get('message') ?? '').trim();
    const website = String(formData.get('website') ?? '').trim();
    const interests = formData.getAll('interests').map((value) => String(value).trim()).filter(Boolean);

    const isValid = name && email && phone && company;
    closeModal(successModal);
    closeModal(errorModal);

    if (!isValid) {
      if (errorText) {
        errorText.textContent = 'Zkontrolujte prosím formulář. Některá povinná pole nejsou vyplněna.';
      }
      openModal(errorModal);
      return;
    }

    submitButton?.setAttribute('disabled', 'disabled');
    submitButton?.setAttribute('aria-busy', 'true');

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          name,
          email,
          phone,
          company,
          teamSize,
          interests,
          message,
          website,
        }),
      });

      const result = await response.json();

      if (!response.ok || !result.ok) {
        throw new Error(result.error || 'Nepodařilo se odeslat formulář.');
      }

      form.reset();
      openModal(successModal);
    } catch (error) {
      if (errorText) {
        errorText.textContent = error instanceof Error ? error.message : 'Nepodařilo se odeslat formulář.';
      }
      openModal(errorModal);
    } finally {
      submitButton?.removeAttribute('disabled');
      submitButton?.removeAttribute('aria-busy');
    }
  });
</script>
