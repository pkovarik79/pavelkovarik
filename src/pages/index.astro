---
import Base from '../layouts/Base.astro';
import { importedPosts } from '../data/importedPosts';
import '../styles/global.css';

const mdxPosts = Object.values(import.meta.glob('./*.mdx', { eager: true })).map((post: any) => ({
  url: post.url,
  frontmatter: post.frontmatter,
}));

const allPosts = [
  ...mdxPosts,
  ...importedPosts.map((post) => ({
    url: post.url,
    frontmatter: {
      title: post.title,
      description: post.description,
      date: post.date,
      image: post.image,
    },
  })),
];

const sortedPosts = allPosts
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const featuredPost = allPosts.find(p => p.url?.includes('jak-vybrat-ai-skoleni-pro-firmy'));
const smallPosts = sortedPosts.filter(p => p !== featuredPost).slice(0, 3);
