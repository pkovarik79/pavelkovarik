---
import Base from '../layouts/Base.astro';
import '../styles/global.css';

const beforeItems = [
  'Úředníci nevědí, co mohou do AI zadat',
  'Riziko práce s osobními údaji občanů',
  'Rutina a administrativa berou čas občanům i kolegům',
  'Nejasné očekávání a obavy z nových nástrojů',
];

const afterItems = [
  'Jasná pravidla pro bezpečné používání AI',
  'Lepší orientace v tom, co do AI patří a co už ne',
  'Rychlejší práce s podklady, texty a informacemi',
  'AI jako pomocník pro každodenní praxi úřadu',
];

const skills = [
  {
    title: 'Bezpečnost a pravidla',
    subtitle: 'Pevný základ pro bezpečné používání AI ve veřejné správě.',
    items: [
      'Co smí a nesmí úředník zadat do AI',
      'Jak přemýšlet o osobních údajích, GDPR a citlivých informacích',
      'Jak si hlídat kvalitu výstupů a nenechat se zmást nepřesností',
      'Jak nastavit rozumný rámec používání AI na úřadě',
    ],
  },
  {
    title: 'Dokumenty, podklady a informace',
    subtitle: 'Rychlejší práce s texty, podklady a interními materiály.',
    items: [
      'Shrnutí dokumentů a orientace ve větším množství podkladů',
      'Příprava podkladů pro porady, radu nebo zastupitelstvo',
      'Osnovy, přehledy a interní texty',
      'Rychlejší práce s informacemi v každodenní agendě',
    ],
  },
  {
    title: 'Komunikace a každodenní agenda',
    subtitle: 'Postupy, které mohou lidé používat hned v běžné práci.',
    items: [
      'Odpovědi na opakující se dotazy a e-maily',
      'Úprava textů pro občany i interní komunikaci',
      'Srozumitelnější formulace a rychlejší příprava výstupů',
      'Využití AI tam, kde opravdu šetří čas',
    ],
  },
  {
    title: 'Asistenti, automatizace a interní nástroje',
    subtitle: 'Pokročilejší možnosti pro úřady, které chtějí jít dál.',
    items: [
      'Kde dává smysl využít AI asistenty',
      'Automatizace opakujících se činností a rutiny',
      'Jednoduché interní nástroje nebo rychlá řešení pro konkrétní agendy',
      'Inspirace, kde může AI pomoci i nad rámec běžného promptování',
    ],
  },
];

const keyBenefits = [
  {
    title: 'Více času pro občany',
    text: 'Rutinní úkoly zvládnou rychleji a zůstane více prostoru na komunikaci s lidmi.',
  },
  {
    title: 'Rychlejší administrativa',
    text: 'Odpovědi, podklady, shrnutí a interní texty vznikají svižněji a s větším přehledem.',
  },
  {
    title: 'Lepší práce s informacemi',
    text: 'Dokážou zpracovat větší množství podkladů, vytáhnout podstatné body a pracovat s nimi dál.',
  },
  {
    title: 'Bezpečnější používání AI',
    text: 'Budou vědět, co do AI patří, co už ne a kde je potřeba větší opatrnost.',
  },
];

const audiences = [
  {
    title: 'Pro úřady, které s AI začínají',
    text: 'Žádné předchozí zkušenosti nejsou potřeba. Všechno vysvětlím srozumitelně a bez technického žargonu.',
  },
  {
    title: 'Pro úřady, které chtějí jít víc do hloubky',
    text: 'Pokud už AI někdo zkouší, školení pomůže udělat si v tom pořádek a posunout využití do praxe.',
  },
  {
    title: 'Pro různé odbory a agendy',
    text: 'Vedení úřadu, komunikace, sociální oblast, administrativa i další odbory. Obsah přizpůsobím tomu, co lidé skutečně řeší.',
  },
];

const quotes = [
  {
    text: '„Bála jsem se, že AI je moc složitá na to, abych se to naučila. Pavel mi ukázal, že to zvládnu i já a že to vlastně není žádná věda.“',
    name: 'Jana Dvořáková (58 let)',
    role: 'pracovnice matričního úřadu',
  },
  {
    text: '„Oceňuji, že Pavel neříká, že budeme nahrazeni. Naopak ukázal, jak AI ušetří čas a jak se můžeme víc věnovat lidem.“',
    name: 'Petr Novák (52 let)',
    role: 'vedoucí odboru obecního úřadu',
  },
  {
    text: '„Konečně školení, kde lektor rozumí prostředí úřadů. Všechny příklady byly z praxe, kterou skutečně řešíme.“',
    name: 'Markéta Svobodová (44 let)',
    role: 'pracovnice sociálního odboru',
  },
];

const oneDayIncludes = [
  'Příprava obsahu přímo pro vaše agendy',
  'Praktická cvičení na situacích z veřejné správy',
  'Kontrolní postup pro bezpečnou práci s AI',
  'Následná e-mailová podpora',
  'Doprava po celé ČR zdarma',
];

const twoDayIncludes = [
  'Více prostoru pro konkrétní agendy a podklady úřadu',
  'Více času pro různé odbory a specifické situace',
  'Hlubší nácvik bezpečné práce s AI a kontroly výstupů',
  'Více prostoru na dotazy, zpětnou vazbu a doladění postupů',
  'Lepší přenos do každodenní praxe úřadu',
];

const faqItems = [
  ['Je AI školení vhodné pro obce, města a úřady různé velikosti?', 'Ano. Školení přizpůsobuji velikosti instituce i tomu, co konkrétní úřad řeší. Jinak bude vypadat pro menší obec, jinak pro větší město nebo magistrát.'],
  ['Přizpůsobíte obsah školení našim agendám a odborům?', 'Ano. Před školením si zjistím, jaké agendy a odbory chcete pokrýt, a připravím praktické ukázky přímo z vašeho prostředí, ať už jde o komunikaci, administrativu, sociální oblast, vedení úřadu nebo další agendy.'],
  ['Co se během školení konkrétně naučíme?', 'Naučíte se, co do AI patří a co už ne, jak bezpečně pracovat s daty, jak si hlídat kvalitu výstupů a jak AI využít v běžné práci úřadu. Všechno si ukážeme na konkrétních situacích z veřejné správy. Podrobnější osnovu najdete v PDF s obsahem školení.'],
  ['Co smí a nesmí úředník zadat do AI?', 'Právě tohle je jedna z hlavních částí školení. Účastníci se naučí, jak přemýšlet o osobních údajích, citlivých informacích, GDPR a dalších rizicích tak, aby se AI používala bezpečně a s rozumem.'],
  ['Jak poznáme, jestli nám stačí jednodenní, nebo je lepší dvoudenní varianta?', 'Jednodenní varianta je ideální, když chcete rychle získat přehled, nastavit bezpečný základ a ukázat lidem praktické využití AI v běžné práci. Dvoudenní varianta dává větší prostor na konkrétní agendy, různé odbory, práci s vlastními podklady a hlubší přenos do praxe.'],
  ['Je školení vhodné i pro větší úřady nebo větší kolektivy?', 'Ano. Pro větší úřady, magistráty a větší kolektivy připravuji individuální nabídku. Může jít o více běhů školení, rozdělení podle odborů nebo po domluvě i jiný vhodný formát pro širší kolektiv.'],
  ['Kdy uvidíme výsledky v praxi?', 'Většina účastníků začne nové postupy používat hned po školení. Nejrychleji se to projeví u rutinních úkolů, práce s podklady, interních textů a opakujících se dotazů.'],
  ['Jaké vybavení potřebujeme připravit?', 'Stačí, aby každý účastník měl notebook a přístup k internetu. Pokud školíme u vás, ideální je zasedací místnost s projektorem nebo větší obrazovkou.'],
];

const visibleFaqItems = faqItems.slice(0, 5);
const extraFaqItems = faqItems.slice(5);
---

<Base title="Praktické školení AI pro města, obce a veřejnou správu | Pavel Kovařík" description="Proškolil jsem přes 1 000 zaměstnanců. Jako bývalý tiskový mluvčí znám prostředí úřadů zevnitř.">
  <div class="lp-page">
    <section class="lp-hero">
      <div class="wrap">
        <span class="lp-badge">Proškoleno přes 1 000 zaměstnanců v ČR</span>
        <h1>Praktické školení AI pro města, obce a veřejnou správu</h1>
        <p class="lp-subtitle"><strong>Konečně máte čas na to, co vás na práci skutečně naplňuje – pomáhat občanům ještě lépe.</strong></p>
        <div class="lp-meta">
          <span class="lp-meta-item">
            <i class="lp-meta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
            </i>
            1 nebo 2 dny školení
          </span>
          <span class="lp-meta-item">
            <i class="lp-meta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M16 20v-1.2a3.8 3.8 0 0 0-3.8-3.8H7.8A3.8 3.8 0 0 0 4 18.8V20"></path><circle cx="10" cy="8" r="3"></circle><path d="M20 20v-1.2a3.4 3.4 0 0 0-2.4-3.3"></path><path d="M15.8 5.2A3 3 0 0 1 15.8 11"></path></svg>
            </i>
            Až 15 účastníků
          </span>
          <span class="lp-meta-item">
            <i class="lp-meta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 4.4-2.9 8.3-7 9.5C7.9 19.3 5 15.4 5 11V6l7-3z"></path></svg>
            </i>
            Bezpečné používání AI na úřadě
          </span>
        </div>
        <div class="lp-actions">
          <a href="/kontakt/" class="btn btn-p">Domluvit termín</a>
          <a href="#cena" class="btn btn-s">Ukázat varianty školení</a>
        </div>
      </div>
    </section>

    <div class="lp-verified-wrap">
      <div class="lp-verified">
        <div class="lp-stars">★★★★★</div>
        <h3>Školení AI podle doporučených postupů České asociace umělé inteligence</h3>
        <p>Proškolil jsem přes 1 000 zaměstnanců v ČR. Jako bývalý tiskový mluvčí města a vedoucí oddělení vnějších vztahů znám prostředí úřadů zevnitř. Obsah školení proto stavím na reálných situacích z veřejné správy, ne na obecných ukázkách.</p>
      </div>
    </div>

    <section class="sec">
      <div class="wrap">
        <h2>Proč úřady potřebují školení AI</h2>
        <p class="lp-section-intro">
          Na úřadech dnes AI nejčastěji naráží na dvě věci: nejistotu, co je ještě bezpečné, a nejasnou představu, kde může opravdu pomoct. Když se s ní pracuje bez pravidel, vznikají zbytečné chyby. Když se používá správně, dokáže ulevit od rutiny a zrychlit práci s podklady, dokumenty i opakujícími se dotazy.
        </p>
        <div class="lp-compare">
          <div class="lp-compare-card is-before">
            <h3>Bez školení</h3>
            <ul class="lp-compare-list">
              {beforeItems.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
          <div class="lp-compare-card is-after">
            <h3>Po školení</h3>
            <ul class="lp-compare-list">
              {afterItems.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="sec" style="background:#fff;">
      <div class="wrap">
        <h2>Co se naučí lidé z vašeho úřadu</h2>
        <p class="lp-section-intro">
          Nejde o to, aby lidé viděli pár zajímavých ukázek. Důležité je, aby po školení věděli, kde jim AI opravdu pomůže, co je potřeba hlídat a jak ji používat tak, aby práci ulehčovala, ne komplikovala.
        </p>
        <div class="lp-card-grid-2">
          {skills.map((skill, index) => (
            <div class="lp-card">
              <div class="lp-icon">{index + 1}</div>
              <h3 style="color:var(--pk-primary);">{skill.title}</h3>
              <p>{skill.subtitle}</p>
              <ul class="lp-bullet-list">
                {skill.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <p class="lp-copy">
          Školení přizpůsobuji tomu, kdo se ho účastní – od starostů, radních, tajemníků a vedoucích odborů přes referenty, podatelnu, personalistiku a finance až po stavební úřady, městskou policii, krizové řízení nebo pracovníky komunikace a tiskových oddělení.
        </p>

        <p class="lp-copy" style="max-width:860px;">
          Jednodenní varianta dává pevný základ. Ve dvoudenní variantě je více prostoru pro konkrétní agendy, různé odbory, vlastní podklady a hlubší přenos do praxe úřadu.
        </p>

        <div class="lp-info-box">
          <h3>Podrobnosti školení (PDF)</h3>
          <p>Chcete si udělat přesnější představu? V PDF najdete ukázku obsahu školení, hlavní témata i vysvětlení, kdy dává větší smysl jednodenní varianta a kdy už dvoudenní.</p>
          <a href="https://pavelkovarik.cz/wp-content/uploads/2026/03/Prakticke-skoleni-AI-pro-urady-syllabus.pdf" class="btn btn-p" style="margin-top:1rem;" download>Stáhnout obsah školení (PDF)</a>
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="wrap">
        <h2>Klíčové dovednosti pro práci s AI na úřadě</h2>
        <div class="lp-card-grid-4">
          {keyBenefits.map((item, index) => (
            <div class="lp-card center">
              <div class="lp-icon">{index + 1}</div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec" style="background:#fff;">
      <div class="wrap">
        <h2>Pro koho je školení určeno</h2>
        <div class="lp-card-grid-3">
          {audiences.map((item) => (
            <div class="lp-card center">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="wrap">
        <h2>Reálné zkušenosti z úřadů</h2>
        <div class="lp-quote-grid">
          {quotes.map((quote) => (
            <div class="lp-quote-card">
              <p>{quote.text}</p>
              <strong>{quote.name}</strong>
              <span class="lp-quote-role">{quote.role}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec" id="cena" style="background:#fff;">
      <div class="wrap">
        <div class="lp-pricing-shell">
          <h2 style="margin-bottom:0.55rem;">Varianty školení a cena</h2>
          <p class="lp-section-intro" style="margin-top:0; margin-bottom:0;">
            Jednodenní varianta je vhodná jako pevný a praktický základ. Dvoudenní varianta dává více prostoru na vyzkoušení, práci s vašimi agendami a hlubší využití AI v praxi veřejné správy.
          </p>

          <div class="lp-price-grid">
            <div class="lp-price-card">
              <div class="lp-price-tags">
                <span class="lp-price-tag">1 den</span>
                <span class="lp-price-tag">Praktický základ</span>
              </div>
              <div class="lp-price-value">19&nbsp;900&nbsp;Kč</div>
              <p class="lp-price-per">To je 1&nbsp;330&nbsp;Kč na účastníka<span>při 15 účastnících</span></p>
              <p class="lp-price-note">pro skupinu do 15 osob • 1 den • 8 hodin</p>
              <p class="lp-price-desc">Vhodná volba pro úřady, které chtějí rychle získat přehled, naučit lidi základy a ukázat jim, jak AI používat bezpečně a s rozumem v každodenní práci.</p>
              <div class="lp-price-box">
                <p>V ceně je zahrnuto:</p>
                <ul class="lp-check-list">
                  {oneDayIncludes.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="lp-price-card" style="border-width:3px;">
              <div class="lp-price-tags">
                <span class="lp-price-tag">2 dny</span>
                <span class="lp-price-tag">Více prostoru na vyzkoušení</span>
              </div>
              <div class="lp-price-value">37&nbsp;900&nbsp;Kč</div>
              <p class="lp-price-per">To je 2&nbsp;530&nbsp;Kč na účastníka<span>při 15 účastnících</span></p>
              <p class="lp-price-note">pro skupinu do 15 osob • 2 dny • 16 hodin</p>
              <p class="lp-price-desc">Vhodná volba pro úřady, které chtějí jít víc do hloubky, dát lidem větší prostor na vyzkoušení a pracovat i s vlastními úkoly, dokumenty a situacemi z praxe.</p>
              <div class="lp-price-box">
                <p>Dvoudenní varianta obsahuje vše z jednodenní a navíc:</p>
                <ul class="lp-check-list">
                  {twoDayIncludes.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>

          <p class="lp-copy" style="max-width:820px;">
            Uvedené ceny platí pro standardní skupinu do 15 účastníků. Pro větší úřady a větší kolektivy připravím individuální řešení podle počtu lidí, agend a cíle školení.
          </p>

          <div class="lp-card" style="max-width:760px; margin:1.6rem auto 0; border-left:4px solid var(--pk-primary); text-align:left;">
            <h3 style="font-size:1.05rem; margin-bottom:0.45rem;">Větší úřady a větší kolektivy</h3>
            <p>Pro větší úřady, magistráty a širší týmy připravuji individuální nabídku. Může jít o více běhů školení, rozdělení podle odborů nebo po domluvě i jiný vhodný formát pro širší kolektiv (např. dvouhodinová přednáška s úvodem do AI a představením klíčových nástrojů). <a href="/kontakt/">Napište mi a podíváme se na vhodné řešení</a>.</p>
          </div>

          <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-top:1.8rem;">
            <a href="/kontakt/" class="btn btn-p">Poptat termín školení</a>
            <a href="/skoleni/" class="btn btn-s" style="background:#fff;">Zobrazit všechna školení</a>
          </div>
          <p class="lp-copy" style="font-size:0.88rem;">Nejsem plátce DPH. Uvedená cena je konečná.</p>
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="wrap">
        <div class="lp-dashed-box" style="max-width: 600px;">
          <h3>AI školení pro firmy a komerční sektor</h3>
          <p>Mám připravené firemní kurzy AI přizpůsobené potřebám podnikatelského sektoru.</p>
          <a href="/prakticke-skoleni-ai-pro-firmy/" class="btn btn-p" style="margin-top:1rem;">Školení pro firmy</a>
        </div>
      </div>
    </section>

    <section class="sec sec-alt">
      <div class="wrap">
        <div class="sec-head">
          <h2>Časté otázky k AI školení pro úřady a veřejnou správu</h2>
          <p>To nejdůležitější na jednom místě - délka, cena, formát i to, jak školení přizpůsobuji vašemu úřadu.</p>
        </div>
        <div class="lp-faq-wrap" data-faq-group>
          <div class="faq">
            {visibleFaqItems.map(([q, a]) => (
              <details>
                <summary>{q}</summary>
                <div class="faq-body">
                  <div class="faq-body-inner">
                    <p>{a}</p>
                  </div>
                </div>
              </details>
            ))}
            <div class="lp-faq-extra" data-faq-extra hidden>
              {extraFaqItems.map(([q, a]) => (
                <details>
                  <summary>{q}</summary>
                  <div class="faq-body">
                    <div class="faq-body-inner">
                      <p>{a}</p>
                    </div>
                  </div>
                </details>
              ))}
            </div>
          </div>
          <div class="lp-faq-more">
            <button type="button" class="btn btn-p lp-faq-toggle" data-faq-toggle>Zobrazit další otázky</button>
          </div>
        </div>
      </div>
    </section>

    <section class="lp-final-cta">
      <div class="wrap">
        <h2>Nastartujte bezpečné a praktické využití AI na vašem úřadě</h2>
        <p>Zavolejte mi nebo napište a během krátké konzultace zjistíme, která varianta školení bude pro váš úřad dávat největší smysl.</p>
        <div class="lp-actions">
          <a href="/kontakt/" class="btn btn-p">Domluvit termín školení</a>
