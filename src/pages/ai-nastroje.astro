---
import Base from '../layouts/Base.astro';
import { getAiToolsData } from '../lib/wp-materials';

const toolCatalog = getAiToolsData();
---

<Base title="AI nástroje pro firmy | Pavel Kovařík" description="Kurátorovaný přehled ověřených AI nástrojů, které používám ve školeních. Kategorizované podle využití.">
  <section class="pk-page-hero tools-hero">
    <div class="wrap">
      <span class="pk-hero-label">Materiály</span>
      <h1>AI nástroje pro firmy</h1>
      <p>Kurátorovaný přehled ověřených AI nástrojů které používám ve školeních. Kategorizované podle využití s praktickými tipy.</p>
    </div>
  </section>

  <section class="tools-shell" id="tools-library">
    <div class="wrap">
      <div class="tools-controls">
        <div class="tools-search-row">
          <label class="tools-search-label" for="tool-search">Hledat</label>
          <input id="tool-search" class="tools-search" type="search" placeholder="Název nebo popis, třeba titulky, PDF, grafy..." />
          <button type="button" class="tools-clear" id="tool-clear">Vymazat</button>
        </div>

        <div class="tools-filters" role="toolbar" aria-label="Filtry AI nástrojů">
          {toolCatalog.filters.map((filter, index) => (
            <button
              type="button"
              class:list={['tools-filter', index === 0 && 'is-active']}
              data-filter={filter.key}
            >
              {filter.label}
            </button>
          ))}
        </div>
      </div>

      <div id="tool-empty" class="tools-empty" hidden>
        <h2>Pro toto hledání jsem nic nenašel.</h2>
        <p>Zkuste jiné slovo nebo jinou kategorii.</p>
      </div>

      <div class="tools-grid">
        {toolCatalog.tools.map((tool) => (
          <article class="tool-card" data-category={tool.category} data-search={[tool.title, tool.description, tool.badge].join(' ')}>
            <span class="tool-badge">{tool.badge}</span>
            <h2><a href={tool.href} target="_blank" rel="noopener">{tool.title}</a></h2>
            <p>{tool.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <script>
    const root = document.getElementById('tools-library');
    if (root) {
      const search = root.querySelector('#tool-search');
      const clear = root.querySelector('#tool-clear');
      const filters = Array.from(root.querySelectorAll('.tools-filter'));
      const cards = Array.from(root.querySelectorAll('.tool-card'));
      const empty = root.querySelector('#tool-empty');
      let activeFilter = 'all';

      const normalize = (value) =>
        (value || '')
          .toLowerCase()
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '');

      const refresh = () => {
        const query = normalize(search instanceof HTMLInputElement ? search.value : '');
        let visibleCount = 0;

        cards.forEach((card) => {
          const category = card.getAttribute('data-category') || '';
          const haystack = normalize(card.getAttribute('data-search'));
          const filterMatch = activeFilter === 'all' || activeFilter === category;
          const searchMatch = !query || haystack.includes(query);
          const visible = filterMatch && searchMatch;
          card.hidden = !visible;
          if (visible) {
            visibleCount += 1;
          }
        });

        if (empty) {
          empty.hidden = visibleCount !== 0;
        }
      };

      filters.forEach((button) => {
        button.addEventListener('click', () => {
          activeFilter = button.getAttribute('data-filter') || 'all';
          filters.forEach((item) => item.classList.toggle('is-active', item === button));
          refresh();
        });
      });

      search?.addEventListener('input', refresh);
      clear?.addEventListener('click', () => {
        if (search instanceof HTMLInputElement) {
          search.value = '';
          search.focus();
        }
        activeFilter = 'all';
        filters.forEach((item, index) => item.classList.toggle('is-active', index === 0));
        refresh();
      });

      refresh();
    }
  </script>

  <style>
    .tools-shell {
      background: var(--pk-bg-alt);
      padding: 3rem 0 4rem;
    }

    .tools-controls {
      margin-bottom: 2rem;
    }

    .tools-search-row {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.9rem;
      align-items: center;
      margin-bottom: 1rem;
    }

    .tools-search-label {
      font-size: 0.85rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--pk-text);
    }

    .tools-search,
    .tools-clear {
      height: 3.6rem;
      border-radius: 1rem;
      border: 2px solid var(--pk-border);
      font: inherit;
    }

    .tools-search {
      width: 100%;
      padding: 0 1.1rem;
      background: #fff;
    }

    .tools-search:focus {
      outline: none;
      border-color: var(--pk-primary);
      box-shadow: 0 0 0 4px rgba(61, 92, 217, 0.12);
    }

    .tools-clear {
      padding: 0 1.25rem;
      background: #fff;
      font-weight: 700;
      cursor: pointer;
    }

    .tools-filters {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .tools-filter {
      border: 2px solid var(--pk-border);
      background: #fff;
      color: var(--pk-text);
      border-radius: 999px;
      padding: 0.8rem 1.1rem;
      font-weight: 700;
      cursor: pointer;
      transition: 0.2s ease;
    }

    .tools-filter.is-active {
      background: var(--pk-primary);
      border-color: var(--pk-primary);
      color: #fff;
    }

    .tools-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem;
    }

    .tool-card {
      position: relative;
      background: #fff;
      border: 1px solid var(--pk-border);
      border-radius: 1.1rem;
      box-shadow: 0 2px 8px rgba(15, 23, 42, 0.04);
      padding: 1.6rem;
      min-height: 14.5rem;
    }

    .tool-card h2 {
      margin: 0 0 0.8rem;
      font-size: 1.8rem;
      letter-spacing: -0.03em;
      padding-right: 5rem;
    }

    .tool-card p {
      margin: 0;
      color: var(--pk-text-2);
      font-size: 1.05rem;
      line-height: 1.65;
    }

    .tool-badge {
      position: absolute;
      top: 1rem;
      right: 1rem;
      padding: 0.45rem 0.8rem;
      border-radius: 999px;
      background: rgba(61, 92, 217, 0.1);
      color: var(--pk-primary);
      border: 1px solid rgba(61, 92, 217, 0.22);
      font-size: 0.75rem;
      font-weight: 800;
      text-transform: uppercase;
    }

    .tools-empty {
      text-align: center;
      padding: 3rem 1rem;
    }

    .tools-empty h2 {
      margin-bottom: 0.6rem;
    }

    .tools-empty p {
      color: var(--pk-text-2);
    }

    @media (max-width: 1100px) {
      .tools-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 768px) {
      .tools-search-row {
        grid-template-columns: 1fr;
      }

      .tools-search-label {
        display: none;
      }

      .tools-grid {
        grid-template-columns: 1fr;
      }

      .tool-card h2 {
        font-size: 1.5rem;
        padding-right: 0;
      }
    }
  </style>
</Base>
