---
import Base from '../layouts/Base.astro';
import { getAiToolsData } from '../lib/wp-materials';

const toolCatalog = getAiToolsData();
---

<Base
  title="AI nástroje pro firmy – Pavel Kovařík"
  description="Kurátorovaný přehled ověřených AI nástrojů které používám ve školeních. Kategorizované podle využití s praktickými tipy."
>
  <div id="ai-nastroje" class="ai-tools-page">
    <section class="hero">
      <div class="container">
        <span class="badge">MATERIÁLY</span>
        <h1>AI nástroje pro firmy</h1>
        <p class="hero-subtitle">
          Kurátorovaný přehled ověřených AI nástrojů které používám ve školeních.
          Kategorizované podle využití s praktickými tipy.
        </p>
      </div>
    </section>

    <section class="controls-section" id="tools-library">
      <div class="container">
        <div class="controls">
          <div class="search-box">
            <span class="search-label">Hledat</span>
            <input
              id="tool-search"
              class="search-input"
              type="search"
              placeholder="Název nebo popis, třeba titulky, PDF, grafy..."
              aria-label="Hledat nástroje"
            />
            <button id="tool-clear" class="search-clear" type="button" hidden>Vymazat</button>
          </div>

          <div class="filters" role="toolbar" aria-label="Filtry AI nástrojů">
            {toolCatalog.filters.map((filter, index) => (
              <button
                id={index === 0 ? 'tool-filter-all' : undefined}
                type="button"
                class:list={['filter-btn', index === 0 && 'active']}
                data-cat={filter.key}
              >
                {filter.label}
              </button>
            ))}
          </div>
        </div>

        <div class="tools-grid">
          {toolCatalog.tools.map((tool) => (
            <article
              class="tool-card"
              data-cat={tool.category}
              data-search={[tool.title, tool.description, tool.badge].join(' ')}
            >
              <span class="tool-badge">{tool.badge}</span>
              <h4>
                <a href={tool.href} target="_blank" rel="noopener">{tool.title}</a>
              </h4>
              <p>{tool.description}</p>
            </article>
          ))}
        </div>

        <div id="tool-empty" class="empty-state" hidden>
          <p>Pro toto hledání jsem nic nenašel.</p>
        </div>
      </div>
    </section>
  </div>

  <script>
    const root = document.querySelector('#ai-nastroje');
    if (root && !root.dataset.init) {
      root.dataset.init = '1';

      const grid = root.querySelector('.tools-grid');
      const cards = Array.from(root.querySelectorAll('.tool-card'));
      const filters = root.querySelectorAll('.filter-btn');
      const searchInput = root.querySelector('#tool-search');
      const searchClear = root.querySelector('#tool-clear');
      const emptyState = root.querySelector('#tool-empty');

      const collator = new Intl.Collator('cs', { sensitivity: 'base' });

      cards
        .sort((a, b) => {
          const nameA = a.querySelector('h4 a')?.textContent?.trim() || '';
          const nameB = b.querySelector('h4 a')?.textContent?.trim() || '';
          return collator.compare(nameA, nameB);
        })
        .forEach((card) => grid?.appendChild(card));

      const normalize = (value) =>
        (value || '')
          .toString()
          .toLowerCase()
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .trim();

      const getActiveCat = () => {
        const active = root.querySelector('.filter-btn.active');
        return active ? active.getAttribute('data-cat') || 'all' : 'all';
      };

      const apply = (cat, query) => {
        const qNorm = normalize(query);
        let visible = 0;

        cards.forEach((card) => {
          const inCat = cat === 'all' || card.getAttribute('data-cat') === cat;
          const haystack = normalize(card.getAttribute('data-search'));
          const inQuery = !qNorm || haystack.includes(qNorm);
          const show = inCat && inQuery;
          card.style.display = show ? '' : 'none';
          if (show) visible += 1;
        });

        if (searchClear) {
          searchClear.hidden = !qNorm;
        }

        if (emptyState) {
          emptyState.hidden = visible > 0;
        }
      };

      filters.forEach((button) => {
        button.addEventListener('click', () => {
          filters.forEach((item) => item.classList.remove('active'));
          button.classList.add('active');
          apply(button.getAttribute('data-cat') || 'all', searchInput instanceof HTMLInputElement ? searchInput.value : '');
        });
      });

      if (searchInput instanceof HTMLInputElement) {
        let timeoutId = null;
        searchInput.addEventListener('input', () => {
          const category = getActiveCat();
          const value = searchInput.value || '';

          if (searchClear) {
            searchClear.hidden = !normalize(value);
          }

          if (timeoutId) {
            clearTimeout(timeoutId);
          }

          timeoutId = setTimeout(() => {
            apply(category, value);
          }, 80);
        });
      }

      searchClear?.addEventListener('click', () => {
        if (searchInput instanceof HTMLInputElement) {
          searchInput.value = '';
          searchInput.focus();
        }
        apply(getActiveCat(), '');
      });

      apply('all', '');
    }
  </script>

  <style>
    #ai-nastroje {
      --brand: #3d5cd9;
      --brand-dark: #2a49c7;
      --text: #1f2937;
      --text-light: #4b5563;
      --bg: #f8fafc;
      --surface: #ffffff;
      --line: #e5e7eb;
      --radius-lg: 16px;
      --radius-md: 12px;
      --shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
      --shadow-lg: 0 12px 36px rgba(61, 92, 217, 0.15);
      background: var(--bg);
      color: var(--text);
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    #ai-nastroje .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
    }

    #ai-nastroje h1,
    #ai-nastroje h2,
    #ai-nastroje h3,
    #ai-nastroje h4 {
      color: var(--text);
      font-weight: 800;
      line-height: 1.25;
      margin: 0 0 1rem;
    }

    #ai-nastroje h1 {
      color: #fff;
      font-size: 2.5rem;
    }

    #ai-nastroje p {
      margin: 0 0 1rem;
      font-weight: 400;
    }

    #ai-nastroje .hero {
      background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);
      color: #fff;
      padding: 50px 24px;
      text-align: center;
    }

    #ai-nastroje .badge {
      display: inline-block;
      margin-bottom: 1.2rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.15);
      padding: 6px 16px;
      font-size: 0.85rem;
      font-weight: 700;
    }

    #ai-nastroje .hero-subtitle {
      max-width: 680px;
      margin: 0 auto;
      color: #fff;
      font-size: 1.15rem;
      opacity: 0.95;
    }

    #ai-nastroje .controls-section {
      background: var(--bg);
      padding: 40px 0 50px;
    }

    #ai-nastroje .controls {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-bottom: 30px;
    }

    #ai-nastroje .search-box {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    #ai-nastroje .search-label {
      min-width: 60px;
      color: var(--text);
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    #ai-nastroje .search-input {
      flex: 1;
      border: 2px solid var(--line);
      border-radius: var(--radius-md);
      background: #fff;
      padding: 12px 16px;
      color: var(--text);
      font-size: 0.95rem;
      outline: 0;
    }

    #ai-nastroje .search-input:focus {
      border-color: var(--brand);
      box-shadow: 0 0 0 3px rgba(61, 92, 217, 0.1);
    }

    #ai-nastroje .search-clear {
      cursor: pointer;
      border: 2px solid var(--line);
      border-radius: var(--radius-md);
      background: #fff;
      padding: 10px 16px;
      color: var(--text);
      font-size: 0.85rem;
      font-weight: 700;
      transition: all 0.2s ease;
    }

    #ai-nastroje .search-clear:hover {
      border-color: var(--brand);
      background: var(--bg);
    }

    #ai-nastroje .filters {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    #ai-nastroje .filter-btn {
      cursor: pointer;
      user-select: none;
      border: 2px solid var(--line);
      border-radius: 999px;
      background: #fff;
      padding: 10px 18px;
      color: var(--text);
      font-size: 0.85rem;
      font-weight: 700;
      text-decoration: none;
      transition: all 0.2s ease;
    }

    #ai-nastroje .filter-btn:hover {
      border-color: var(--brand);
      background: var(--bg);
    }

    #ai-nastroje .filter-btn.active {
      border-color: var(--brand);
      background: var(--brand);
      color: #fff;
    }

    #ai-nastroje .tools-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    #ai-nastroje .tool-card {
      position: relative;
      display: flex;
      flex-direction: column;
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: #fff;
      padding: 20px;
      transition: all 0.3s ease;
    }

    #ai-nastroje .tool-card:hover {
      transform: translateY(-3px);
      border-color: var(--brand);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
    }

    #ai-nastroje .tool-card h4 {
      margin-bottom: 10px;
      color: var(--brand);
      font-size: 1.1rem;
      font-weight: 800;
    }

    #ai-nastroje .tool-card h4 a {
      color: var(--brand);
      text-decoration: none;
    }

    #ai-nastroje .tool-card h4 a:hover {
      text-decoration: underline;
    }

    #ai-nastroje .tool-card p {
      margin: 0;
      flex-grow: 1;
      color: var(--text-light);
      font-size: 0.9rem;
      line-height: 1.5;
    }

    #ai-nastroje .tool-badge {
      position: absolute;
      top: 15px;
      right: 15px;
      border: 1px solid rgba(61, 92, 217, 0.2);
      border-radius: 999px;
      background: rgba(61, 92, 217, 0.1);
      padding: 4px 10px;
      color: var(--brand);
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    #ai-nastroje .empty-state {
      padding: 60px 20px;
      text-align: center;
      color: var(--text-light);
    }

    @media (max-width: 768px) {
      #ai-nastroje .tools-grid {
        grid-template-columns: 1fr;
      }

      #ai-nastroje h1 {
        font-size: 1.9rem;
      }

      #ai-nastroje .search-box {
        flex-direction: column;
        align-items: stretch;
      }

      #ai-nastroje .search-label {
        display: none;
      }
    }

    @media (min-width: 769px) and (max-width: 1024px) {
      #ai-nastroje .tools-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>
</Base>
