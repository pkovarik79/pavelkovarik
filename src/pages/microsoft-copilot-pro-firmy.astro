---
import Base from '../layouts/Base.astro';
import '../styles/global.css';

const beforeItems = [
  'Copilot licence zůstávají nevyužité nebo se používají jen okrajově',
  'Zaměstnanci nevědí, jak s Copilotem pracovat v běžné agendě',
  'Výstupy jsou nevyrovnané a každý postupuje jinak',
  'Část práce v Microsoft 365 zůstává stejně pomalá jako dřív',
];

const afterItems = [
  'Lidé vědí, kde Copilot opravdu pomáhá a jak ho používat',
  'Ve firmě vzniknou jasnější a praktičtější postupy',
  'Dokumenty, tabulky, e-maily i prezentace vznikají rychleji',
  'Investice do licencí začne dávat větší smysl i v praxi',
];

const learnBlocks = [
  {
    title: 'Základy práce s Copilotem a Copilot Chatem',
    subtitle: 'Jak s Copilotem pracovat tak, aby byl opravdu užitečný, ne jen efektní.',
    items: [
      'Jak Copilot a Copilot Chat fungují a co od nich čekat',
      'Jak zadávat úkoly, aby byly výstupy lepší',
      'Kde Copilot šetří čas a kde má limity',
      'Jak pracovat s firemními daty rozumně a bezpečně',
    ],
  },
  {
    title: 'Copilot v aplikacích Microsoft 365',
    subtitle: 'Praktické využití v nástrojích, se kterými lidé ve firmách pracují každý den.',
    items: [
      'Word a PowerPoint – tvorba dokumentů a prezentací',
      'Excel – práce s tabulkami, daty, vzorci a grafy',
      'Outlook a Teams – e-maily, schůzky, shrnutí a úkoly',
      'Praktická cvičení na situacích z vaší firmy',
    ],
  },
];

const appAreas = [
  ['Word', 'Psaní, úpravy a zkracování dokumentů'],
  ['Excel', 'Práce s tabulkami, daty, vzorci a grafy'],
  ['PowerPoint', 'Příprava prezentací z podkladů a rychlejší úpravy slidů'],
  ['Outlook', 'E-maily, shrnutí konverzací a návrhy odpovědí'],
  ['Teams', 'Shrnutí schůzek, zápisy a úkoly'],
  ['Copilot Chat', 'Práce s firemními soubory, podklady a interní znalostní bází'],
];

const audiences = [
  ['Firmy s aktivními Copilot licencemi', 'Máte Microsoft 365 Copilot a chcete, aby ho zaměstnanci začali skutečně používat.'],
  ['Týmy, které chtějí pracovat rychleji', 'Chcete zrychlit práci v dokumentech, tabulkách, e-mailech, schůzkách i prezentacích.'],
  ['Firmy, které chtějí větší přínos z licencí', 'Potřebujete, aby investice do Copilotu dávala větší smysl i v každodenní firemní praxi.'],
];

const appreciated = [
  ['Práce na vlastních podkladech', 'Cvičení vycházejí z dokumentů, tabulek a situací, které lidé ve firmě skutečně řeší.'],
  ['Využití hned další den', 'Účastníci si odnášejí postupy, které mohou začít používat v běžné práci okamžitě.'],
  ['Postupy pro každodenní práci', 'Nejde o obecné ukázky, ale o konkrétní využití Copilotu v reálném firemním prostředí.'],
];

const quotes = [
  ['„Analýzu, na kterou jsem dřív potřeboval celé dopoledne, teď zvládnu výrazně rychleji. Copilot mi šetří spoustu času hlavně v Excelu.“', 'Martin Kovář', 'finanční analytik'],
  ['„Konečně využíváme licence naplno. Příprava prezentací i dokumentů je rychlejší a tým má jasnější postupy.“', 'Petra Svobodová', 'projektová manažerka'],
  ['„Oceňuji praktický přístup. Cvičili jsme na našich podkladech, takže jsme mohli hned druhý den začít nové postupy používat.“', 'Jan Novotný', 'vedoucí týmu'],
];

const includes = [
  'Příprava obsahu na míru vašemu prostředí',
  'Praktická cvičení na vašich dokumentech a datech',
  'Šablony a návody pro práci v aplikacích Microsoft 365',
  'Certifikát o absolvování pro účastníky',
  'Následná e-mailová podpora',
  'Doprava po celé ČR zdarma',
];

const faqItems = [
  ['Co je školení Microsoft Copilot pro firmy a komu je určené?', 'Jde o jednodenní praktické školení pro firmy, které chtějí využívat Microsoft 365 Copilot ve Wordu, Excelu, Outlooku, Teams, PowerPointu i Copilot Chatu smysluplněji a efektivněji. Je určené pro týmy, které už Copilot mají nebo se na jeho využití připravují.'],
  ['Kolik stojí školení Microsoft Copilot pro firmy?', 'Školení stojí 24 900 Kč pro skupinu do 15 účastníků. To je 1 660 Kč na osobu při plném počtu účastníků. V ceně je příprava obsahu, praktická cvičení, materiály, certifikáty i doprava po celé ČR zdarma.'],
  ['Co se zaměstnanci na školení Microsoft Copilot naučí?', 'Naučí se, jak s Copilotem pracovat v běžné firemní agendě, jak zadávat úkoly, co od něj čekat, kde má limity a jak ho využít v dokumentech, tabulkách, e-mailech, schůzkách, prezentacích i při práci s firemními soubory a interními podklady.'],
  ['Co umí Microsoft Copilot Chat ve firmě?', 'Copilot Chat slouží jako chatové rozhraní pro práci s úkoly, otázkami, souhrny a podklady. V praxi pomáhá rychleji dohledávat informace, shrnovat obsah, připravovat první návrhy textů a pracovat s firemními soubory a interními znalostmi napříč prostředím Microsoft 365.'],
  ['Umí Microsoft Copilot pracovat s firemními soubory a interními podklady?', 'Ano. Právě to je jedna z jeho hlavních výhod. Na školení si ukazujeme, jak Copilot a Copilot Chat pomáhají při práci s firemními soubory, podklady, dokumenty a dalšími informacemi uloženými v prostředí Microsoft 365.'],
  ['Potřebujeme před školením aktivní licence Microsoft 365 Copilot?', 'Ano. Každý účastník by měl mít aktivní licenci Microsoft 365 Copilot, aby mohl během školení pracovat přímo ve svém prostředí a vše si prakticky vyzkoušet.'],
  ['Co je potřeba mít před školením připravené?', 'Stačí, když firma používá Microsoft 365, účastníci mají aktivní licenci Microsoft 365 Copilot a každý pracuje na vlastním počítači. Pro praktickou část je výhodou mít připravené i vlastní dokumenty, tabulky nebo jiné podklady.'],
  ['Je školení vhodné i pro začátečníky?', 'Ano. Stačí běžná znalost aplikací Microsoft 365. Se samotným Copilotem nemusí mít účastníci předchozí zkušenost. Začínáme od základů a postupně přecházíme k praktičtějšímu využití.'],
  ['Přizpůsobíte obsah školení našemu prostředí a dokumentům?', 'Ano. Před školením si zjistím, jaké typy dokumentů, tabulek a situací ve firmě řešíte, a podle toho upravím ukázky i praktická cvičení. Cílem je, aby si lidé odnesli postupy použitelné v jejich každodenní práci.'],
  ['Jak na školení řešíte bezpečnost a práci s firemními daty?', 'Součástí školení je i to, co od Copilotu čekat, kde má limity a jak s ním pracovat rozumně a bezpečně ve firemním prostředí. Ukazujeme si také, kdy je vhodné být opatrnější při práci s citlivými informacemi nebo důležitými výstupy.'],
];

const visibleFaqItems = faqItems.slice(0, 5);
const extraFaqItems = faqItems.slice(5);
---

<Base title="Microsoft Copilot školení pro firmy | Pavel Kovařík" description="Naučím váš tým využívat Microsoft 365 Copilot ve Wordu, Excelu, Outlooku, Teams, PowerPointu i při práci s firemními soubory.">
  <div class="lp-page">
    <section class="lp-hero">
      <div class="wrap">
        <span class="lp-badge">Praktické firemní školení</span>
        <h1>Microsoft Copilot školení pro firmy</h1>
        <p class="lp-subtitle"><strong>Naučím váš tým využívat Microsoft 365 Copilot a Copilot Chat ve Wordu, Excelu, Outlooku, Teams, PowerPointu i při práci s firemními soubory tak, aby opravdu šetřil čas v každodenní práci.</strong></p>
        <div class="lp-meta">
          <span class="lp-meta-item">
            <i class="lp-meta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
            </i>
            8 hodin
          </span>
          <span class="lp-meta-item">
            <i class="lp-meta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M16 20v-1.2a3.8 3.8 0 0 0-3.8-3.8H7.8A3.8 3.8 0 0 0 4 18.8V20"></path><circle cx="10" cy="8" r="3"></circle><path d="M20 20v-1.2a3.4 3.4 0 0 0-2.4-3.3"></path><path d="M15.8 5.2A3 3 0 0 1 15.8 11"></path></svg>
            </i>
            Až 15 účastníků
          </span>
          <span class="lp-meta-item">
            <i class="lp-meta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M5 7h11l3 3v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2z"></path><path d="M15 7v4h4"></path><path d="M9 12h6"></path></svg>
            </i>
            24&nbsp;900 Kč
          </span>
        </div>
        <div class="lp-actions">
          <a href="/kontakt/" class="btn btn-p">Objednat školení</a>
          <a href="#cena" class="btn btn-s">Zjistit cenu</a>
        </div>
      </div>
    </section>

    <div class="lp-verified-wrap">
      <div class="lp-verified">
        <div class="lp-stars">★★★★★</div>
        <h3>Školení Microsoft Copilot postavené na firemní praxi</h3>
        <p>Jednodenní školení zaměřené na praktické využití Microsoft 365 Copilot a Copilot Chatu ve firemní praxi. Účastníci se naučí pracovat s dokumenty, tabulkami, e-maily, schůzkami, prezentacemi i s firemními podklady a soubory napříč Microsoft 365.</p>
      </div>
    </div>

    <section class="sec">
      <div class="wrap">
        <h2>Proč firmy investují do školení Copilotu</h2>
        <div class="lp-compare">
          <div class="lp-compare-card is-before">
            <h3>Bez školení</h3>
            <ul class="lp-compare-list">
              {beforeItems.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="lp-compare-card is-after">
            <h3>Po školení</h3>
            <ul class="lp-compare-list">
              {afterItems.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="sec" style="background:#fff;">
      <div class="wrap">
        <h2>Co se na školení naučíte</h2>
        <div class="lp-card-grid-2">
          {learnBlocks.map((block, index) => (
            <div class="lp-card">
              <div class="lp-icon">{index + 1}</div>
              <h3 style="color:var(--pk-primary);">{block.title}</h3>
              <p>{block.subtitle}</p>
              <ul class="lp-bullet-list">
                {block.items.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          ))}
        </div>

        <div class="lp-info-box">
          <h3>Detailní obsah školení</h3>
          <p>Chcete vidět přesný harmonogram a příklady cvičení? Stáhněte si modelový program.</p>
          <a href="/wp-content/uploads/harmonogram-skoleni-copilot.pdf" class="btn btn-p" style="margin-top:1rem;" download>Stáhnout harmonogram (PDF)</a>
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="wrap">
        <h2>Copilot v klíčových částech Microsoft 365</h2>
        <div class="lp-card-grid-6">
          {appAreas.map(([title, text], index) => (
            <div class="lp-card center">
              <div class="lp-icon">{index + 1}</div>
              <h3>{title}</h3>
              <p>{text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec" style="background:#fff;">
      <div class="wrap">
        <h2>Pro koho je školení určeno</h2>
        <div class="lp-card-grid-3">
          {audiences.map(([title, text]) => (
            <div class="lp-card center">
              <h3>{title}</h3>
              <p>{text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="wrap">
        <h2>Co firmy na školení oceňují</h2>
        <div class="lp-card-grid-3">
          {appreciated.map(([title, text], index) => (
            <div class="lp-card center">
              <div class="lp-icon">{index + 1}</div>
              <h3>{title}</h3>
              <p>{text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec" style="background:#fff;">
      <div class="wrap">
        <h2>Zkušenosti z absolvovaných školení</h2>
        <div class="lp-quote-grid">
          {quotes.map(([text, name, role]) => (
            <div class="lp-quote-card">
              <p>{text}</p>
              <strong>{name}</strong>
              <span class="lp-quote-role">{role}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec" id="cena">
      <div class="wrap">
        <div class="lp-pricing-shell">
          <h2 style="margin-bottom:0.55rem;">Cena školení</h2>
          <p class="lp-section-intro" style="margin-top:0; margin-bottom:0;">Jednodenní praktické školení pro firmy, které chtějí využívat Microsoft 365 Copilot naplno.</p>
          <div style="max-width: 470px; margin: 1.8rem auto 0;">
            <div class="lp-price-card">
              <div class="lp-price-value">24&nbsp;900 Kč</div>
              <p class="lp-price-per">To je 1&nbsp;660 Kč na zaměstnance</p>
              <p class="lp-price-note">pro skupinu do 15 osob • 8 hodin školení</p>
              <p class="lp-price-desc" style="font-style:italic;">Menší tým? <a href="/kontakt/">Připravím vám kalkulaci na míru.</a></p>
              <div class="lp-price-box">
                <p>V ceně je zahrnuto:</p>
                <ul class="lp-check-list">
                  {includes.map((item) => <li>{item}</li>)}
                </ul>
              </div>
              <p class="lp-copy" style="margin-top:1rem;">Po školení budete mít k dispozici také praktické šablony a doporučené postupy pro efektivnější využití Microsoft 365 Copilot ve firmě.</p>
            </div>
          </div>
          <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-top:1.8rem;">
            <a href="/kontakt/" class="btn btn-p">Objednat školení</a>
            <a href="/skoleni/" class="btn btn-s" style="background:#fff;">Zobrazit všechna školení</a>
          </div>
          <p class="lp-copy" style="font-size:0.88rem;">Nejsem plátce DPH. Uvedená cena je konečná.</p>
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="wrap">
        <div class="lp-dashed-box" style="max-width: 600px;">
          <h3>Praktické školení AI pro firmy</h3>
          <p>Kromě Microsoft Copilotu nabízím i praktické školení AI pro firmy zaměřené na využití umělé inteligence v běžné práci napříč týmy a rolemi.</p>
          <a href="/prakticke-skoleni-ai-pro-firmy/" class="btn btn-p" style="margin-top:1rem;">Školení AI pro firmy</a>
        </div>
      </div>
    </section>

    <section class="sec sec-alt">
      <div class="wrap">
        <div class="sec-head">
          <h2>Časté otázky k Microsoft Copilot školení</h2>
          <p>To nejdůležitější na jednom místě - licence, průběh školení, cena i to, jak vše přizpůsobuji vašemu prostředí Microsoft 365.</p>
        </div>
        <div class="lp-faq-wrap" data-faq-group>
          <div class="faq">
            {visibleFaqItems.map(([q, a]) => (
              <details>
                <summary>{q}</summary>
                <div class="faq-body">
                  <div class="faq-body-inner">
                    <p>{a}</p>
                  </div>
                </div>
              </details>
            ))}
            <div class="lp-faq-extra" data-faq-extra hidden>
              {extraFaqItems.map(([q, a]) => (
                <details>
                  <summary>{q}</summary>
                  <div class="faq-body">
                    <div class="faq-body-inner">
                      <p>{a}</p>
                    </div>
                  </div>
                </details>
              ))}
            </div>
          </div>
          <div class="lp-faq-more">
            <button type="button" class="btn btn-p lp-faq-toggle" data-faq-toggle>Zobrazit další otázky</button>
          </div>
        </div>
      </div>
    </section>

    <section class="lp-final-cta">
      <div class="wrap">
        <h2>Využijte Copilot licence naplno</h2>
        <p>Zavolejte mi nebo napište a během krátké konzultace zjistíme, jak nejlépe využít Microsoft 365 Copilot ve vaší firmě.</p>
        <div class="lp-actions">
          <a href="/kontakt/" class="btn btn-p">Objednat školení</a>
          <a href="mailto:mail@pavelkovarik.cz" class="btn btn-s">Napsat e-mail</a>
        </div>
        <div class="lp-contact-line">+420&nbsp;770&nbsp;126&nbsp;519 · mail@pavelkovarik.cz</div>
        <div class="lp-contact-note">Odpovídám zpravidla do 24 hodin. První konzultace je zdarma.</div>
      </div>
    </section>
  </div>
</Base>
