---
import Base from '../../layouts/Base.astro';
import '../../styles/global.css';

const allPosts = await Astro.glob('./*.mdx');
const posts = allPosts.sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
---

<Base title="Blog | Pavel Kovařík" description="Návody, trendy a zkušenosti ze zavádění umělé inteligence v českých firmách.">
  <section class="sec">
    <div class="wrap">
      <div class="sec-head">
        <h1 style="font-size: clamp(1.7rem,4vw,2.4rem);">AI blog pro firmy</h1>
        <p>Návody, trendy a zkušenosti ze zavádění umělé inteligence v českých firmách.</p>
      </div>
      <div class="blog-list narrow">
        {posts.map((post) => (
          <a href={post.url} class="blog-card">
            {post.frontmatter.image && <img src={post.frontmatter.image} alt={post.frontmatter.title} style="width:100%; border-radius:var(--radius); margin-bottom:.8rem;" />}
            <time datetime={post.frontmatter.date}>{new Date(post.frontmatter.date).toLocaleDateString('cs-CZ', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            <h3>{post.frontmatter.title}</h3>
            <p>{post.frontmatter.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
