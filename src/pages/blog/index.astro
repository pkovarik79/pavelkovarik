---
import Base from '../../layouts/Base.astro';
import { importedPosts } from '../../data/importedPosts';
import '../../styles/global.css';

const mdxPosts = Object.values(import.meta.glob('../*.mdx', { eager: true })).map((post: any) => ({
  url: post.url,
  frontmatter: post.frontmatter,
}));

const posts = [...mdxPosts, ...importedPosts.map((post) => ({
  url: post.url,
  frontmatter: {
    title: post.title,
    description: post.description,
    date: post.date,
    image: post.image,
  },
}))].sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
const featuredLinks = [
  {
    kicker: '01',
    title: 'Nejlepší AI asistent v roce 2026',
    description: 'Srovnání ChatGPT, Gemini a Claude. Vyberte si model podle toho, co reálně potřebujete vyřešit.',
    href: '/nejlepsi-ai-asistent-2026-srovnani-chatgpt-gemini-claude-a-dalsich/',
  },
  {
    kicker: '02',
    title: 'Jak zavést AI do praxe v roce 2026',
    description: 'Konec experimentování. Praktický návod, jak zavést AI do firmy tak, aby měla měřitelný dopad a jasnou návratnost.',
    href: '/zavedeni-ai-2026/',
  },
  {
    kicker: '03',
    title: 'Seznam AI nástrojů',
    description: 'Aplikace, které sám používám a testuji. Jen to, co dává smysl, průběžně aktualizováno.',
    href: '/ai-nastroje/',
  },
];
const featuredPosts = featuredLinks.map((item) => ({
  ...item,
  post: posts.find((post) => post.url === item.href),
}));
---

<Base title="Blog o AI a umělé inteligenci | Pavel Kovařík" description="Blog o AI: jak ji používat v práci i v běžném životě. Návody, zkušenosti, nástroje a věci, na které si dát pozor (data, soukromí, důvěra).">
  <section class="pk-page-hero pk-blog-hero">
    <div class="wrap">
      <span class="pk-hero-label">BLOG</span>
      <h1>Blog o AI (umělé inteligenci)</h1>
    </div>
  </section>

  <section class="sec pk-blog-hub">
    <div class="wrap">
      <div class="pk-blog-start">
        <h2>Doporučené články</h2>
        <div class="pk-blog-start-grid">
          {featuredPosts.map((item) => (
            <article class="pk-blog-start-card">
              <a class="pk-blog-start-media" href={item.href} aria-label={item.title}>
                {item.post?.frontmatter.image ? (
                  <img src={item.post.frontmatter.image} alt={item.title} loading="lazy" />
                ) : (
                  <div class="pk-blog-start-thumb">{item.kicker}</div>
                )}
              </a>
              <div class="pk-blog-start-body">
                <div class="pk-blog-start-meta">
                  <span class="pk-blog-kicker">{item.kicker}</span>
                  <span class="pk-blog-tag">Doporučený článek</span>
                  {item.post?.frontmatter.date && (
                    <time datetime={item.post.frontmatter.date}>
                      {new Date(item.post.frontmatter.date).toLocaleDateString('cs-CZ')}
                    </time>
                  )}
                </div>
                <h3><a href={item.href}>{item.title}</a></h3>
                <p>{item.description}</p>
                <a class="pk-blog-start-cta" href={item.href}>Přečíst článek →</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="sec-head">
        <h2 style="font-size: clamp(1.7rem,4vw,2.4rem);">Všechny články</h2>
        <p>Kompletní archiv článků o AI pro firmy, management i každodenní praxi.</p>
      </div>
      <div class="blog-grid pk-blog-grid">
        {posts.map((post) => (
          <a href={post.url} class="blog-card">
            {post.frontmatter.image && <img src={post.frontmatter.image} alt={post.frontmatter.title} />}
            <div class="blog-card-body">
              <h3>{post.frontmatter.title}</h3>
              <time datetime={post.frontmatter.date}>{new Date(post.frontmatter.date).toLocaleDateString('cs-CZ')}</time>
              <p>{post.frontmatter.description}</p>
              <span class="read-more">Přečíst článek »</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="pk-blog-cta">
        <span class="pk-blog-cta-badge">CHCETE TO VYZKOUŠET?</span>
        <h2>Ukážu vašemu týmu, jak AI skutečně funguje v praxi</h2>
        <p>Praktické školení AI pro firmy. Bez zbytečné teorie, jen nástroje které váš tým začne používat hned druhý den.</p>
        <div class="pk-blog-cta-actions">
          <a href="/kontakt/" class="btn btn-p">Nezávazná konzultace</a>
          <a href="tel:+420770126519" class="btn btn-s pk-blog-cta-phone">Zavolat: +420 770 126 519</a>
        </div>
        <div class="pk-blog-cta-contact">
          <span class="pk-blog-cta-contact-icon" aria-hidden="true">☎</span>
          <span>+420 770 126 519</span>
          <span class="pk-blog-cta-contact-sep" aria-hidden="true">·</span>
          <span class="pk-blog-cta-contact-icon" aria-hidden="true">✉</span>
          <span>mail@pavelkovarik.cz</span>
        </div>
        <div class="pk-blog-cta-note">Odpovím do 24 hodin · Školení přizpůsobené vašemu týmu · Proškolil jsem 1000+ zaměstnanců</div>
      </div>
    </div>
  </section>
</Base>
