---
import Base from '../layouts/Base.astro';
import { getMaterialHubData } from '../lib/wp-materials';

const hub = getMaterialHubData();

const iconPaths: Record<string, string> = {
  layers: 'M12 4 3 8l9 4 9-4-9-8Zm0 10L3 10v4l9 4 9-4v-4l-9 4Zm0 6-9-4v4l9 4 9-4v-4l-9 4Z',
  terminal: 'M5 6h14a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Zm2.2 3.1L10 12l-2.8 2.9 1.3 1.2 4-4.1-4-4.1-1.3 1.2Zm5.8 6.9h5v-2h-5v2Z',
  fileText: 'M7 3h7l5 5v11a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm6 1.5V9h4.5M8.5 12h7M8.5 15h7M8.5 18H14',
  search: 'M10.5 4a6.5 6.5 0 1 0 4.03 11.6l4.43 4.43 1.41-1.41-4.43-4.43A6.5 6.5 0 0 0 10.5 4Zm0 2a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9Z',
  bulb: 'M12 2a6.5 6.5 0 0 0-3.98 11.64c.52.4.83 1 .83 1.65V16a1 1 0 0 0 1 1h4.3a1 1 0 0 0 1-1v-.71c0-.64.3-1.24.82-1.64A6.5 6.5 0 0 0 12 2Zm-1.5 16h3a2 2 0 0 1-3 0Zm-.5-3.03c0-1.03-.47-2.01-1.29-2.66A4.5 4.5 0 1 1 15.3 12.3c-.83.65-1.3 1.63-1.3 2.67h-4Z',
  linkedin: 'M6.94 8.5V19H3.56V8.5h3.38ZM5.25 3A2 2 0 1 1 5.2 7a2 2 0 0 1 .05-4ZM20.44 19h-3.37v-5.1c0-1.22-.02-2.8-1.7-2.8-1.7 0-1.97 1.33-1.97 2.7V19H10V8.5h3.23v1.43h.04c.45-.85 1.55-1.74 3.2-1.74 3.42 0 4.05 2.25 4.05 5.18V19Z',
  phone: 'M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24c1.1.36 2.27.56 3.49.56a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.3 21 3 13.7 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.22.19 2.39.56 3.49a1 1 0 0 1-.25 1.01l-2.19 2.29Z',
  mail: 'M4 6h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1Zm8 5.2L4.8 7.8h14.4L12 11.2Zm7 6.8V9.1l-6.46 3.03a1.2 1.2 0 0 1-1.08 0L5 9.1V18h14Z',
};
---

<Base title="Materiály a zdroje k AI | Pavel Kovařík" description="Praktické nástroje, prompty a návody, které využívám na školeních. Vše na jednom místě a zdarma pro vaše použití.">
  <section class="pk-page-hero materials-hero">
    <div class="wrap">
      <span class="materials-hero-badge">KNOW-HOW</span>
      <h1>Materiály a zdroje k AI</h1>
      <p>Praktické nástroje, prompty a návody, které využívám na školeních. Vše na jednom místě a zdarma pro vaše použití.</p>
    </div>
  </section>

  <section class="materials-shell">
    <div class="wrap">
      <div class="materials-grid">
        {hub.cards.map((card) => (
          <article class="materials-card">
            <div class="materials-card-icon">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d={iconPaths[card.icon]} />
              </svg>
            </div>
            <h2><a href={card.href}>{card.title}</a></h2>
            <p>{card.description}</p>
            <a href={card.href} class="materials-card-link">
              {card.linkLabel}
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>

      <section class="materials-coming">
        <div class="materials-coming-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d={iconPaths.bulb} />
          </svg>
        </div>
        <h2>{hub.upcomingTitle}</h2>
        <p>{hub.upcomingDescription}</p>
        <div class="materials-tags">
          {hub.upcomingTags.map((tag) => <span>{tag}</span>)}
        </div>
        <a href={hub.linkedinHref} target="_blank" rel="noopener" class="materials-linkedin">
          <span aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d={iconPaths.linkedin} />
            </svg>
          </span>
          Sledujte novinky na LinkedInu
        </a>
      </section>
    </div>
  </section>

  <section class="materials-cta">
    <div class="wrap">
      <h2>Hledáte způsob, jak AI zavést ve firmě?</h2>
      <p>Materiály jsou skvělý začátek. Pokud ale chcete ušetřit čas a vyhnout se slepým uličkám, ozvěte se. Provedu vás světem AI prakticky.</p>
      <div class="materials-cta-actions">
        <a href="/kontakt/" class="btn btn-white">Poptat AI školení</a>
        <a href="/skoleni/" class="btn btn-outline">Nabídka kurzů</a>
      </div>
      <div class="materials-cta-contact">
        <a href="tel:+420770126519">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d={iconPaths.phone} /></svg>
          +420 770 126 519
        </a>
        <span>·</span>
        <a href="mailto:mail@pavelkovarik.cz">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d={iconPaths.mail} /></svg>
          mail@pavelkovarik.cz
        </a>
      </div>
    </div>
  </section>

  <style>
    .materials-hero {
      padding: 3.75rem 0 5rem;
    }

    .materials-hero-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.3rem;
      padding: 0.56rem 1.38rem;
      border-radius: 999px;
      background: rgba(255,255,255,.14);
      color: #fff;
      font-size: .92rem;
      font-weight: 800;
      letter-spacing: .08em;
    }

    .materials-shell {
      background: var(--pk-bg-alt);
      padding: 0 0 3.2rem;
    }

    .materials-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem;
      max-width: 1000px;
      margin: -2.5rem auto 3.1rem;
      position: relative;
      z-index: 2;
    }

    .materials-card,
    .materials-coming {
      background: #fff;
      border: 1px solid rgba(15,23,42,.09);
      border-radius: 1rem;
      box-shadow: 0 4px 16px rgba(0,0,0,.08);
    }

    .materials-card {
      padding: 2rem;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: .95rem;
      min-height: 100%;
      transition: transform .3s ease, box-shadow .3s ease, border-color .3s ease;
    }

    .materials-card:hover {
      transform: translateY(-5px);
      border-color: var(--pk-primary);
      box-shadow: 0 15px 35px rgba(61,92,217,.15);
    }

    .materials-card:hover .materials-card-icon {
      background: var(--pk-primary);
    }

    .materials-card:hover .materials-card-icon svg {
      fill: #fff;
    }

    .materials-card:hover h2 a,
    .materials-card:hover .materials-card-link {
      color: var(--pk-primary);
    }

    .materials-card h2 {
      font-size: 1.35rem;
      margin: 0;
      text-align: left;
    }

    .materials-card h2 a {
      color: var(--pk-text);
      text-decoration: none;
      transition: color .24s ease;
    }

    .materials-card p {
      font-size: 1rem;
      color: var(--pk-text-2);
      line-height: 1.72;
      margin: 0;
    }

    .materials-card-link {
      margin-top: auto;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1rem;
      font-weight: 700;
      color: var(--pk-primary);
      text-decoration: none;
      transition: color .24s ease;
    }

    .materials-card-link span {
      transition: transform .2s ease;
    }

    .materials-card:hover .materials-card-link span {
      transform: translateX(5px);
    }

    .materials-card-icon {
      width: 4.375rem;
      height: 4.375rem;
      border-radius: 1rem;
      background: linear-gradient(135deg, #f0f4ff 0%, #e8f0fe 100%);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: .2rem;
      transition: background .3s ease;
    }

    .materials-card-icon svg {
      width: 2rem;
      height: 2rem;
      fill: var(--pk-primary);
      transition: fill .3s ease;
    }

    .materials-coming {
      padding: 3.15rem 2rem;
      text-align: center;
      max-width: 1000px;
      margin: 0 auto;
    }

    .materials-coming-icon {
      width: 2.5rem;
      height: 2.5rem;
      margin: 0 auto 1rem;
      color: #f59e0b;
      opacity: 1;
    }

    .materials-coming-icon svg {
      width: 100%;
      height: 100%;
      fill: currentColor;
    }

    .materials-coming h2 {
      font-size: clamp(1.34rem, 2vw, 1.72rem);
      margin: 0 0 .65rem;
    }

    .materials-coming p {
      max-width: 36rem;
      margin: 0 auto;
      color: var(--pk-text-2);
      font-size: 0.98rem;
      line-height: 1.65;
    }

    .materials-tags {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.65rem;
      margin: 1.25rem 0 0;
    }

    .materials-tags span {
      padding: 0.48rem .82rem;
      border-radius: 999px;
      background: #f1f5f9;
      color: #64748b;
      font-weight: 600;
      font-size: .88rem;
    }

    .materials-linkedin {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      justify-content: center;
      margin-top: 1.8rem;
      font-size: 1.05rem;
      font-weight: 700;
      text-decoration: none;
    }

    .materials-linkedin span {
      width: 1.2rem;
      height: 1.2rem;
      color: var(--pk-primary);
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .materials-linkedin svg {
      width: 100%;
      height: 100%;
      fill: currentColor;
    }

    .materials-cta {
      background: linear-gradient(135deg, var(--pk-primary) 0%, var(--pk-primary-dark) 100%);
      color: #fff;
      text-align: center;
      padding: 3.75rem 0;
      margin-top: 2.5rem;
    }

    .materials-cta h2 {
      color: #fff;
      font-size: clamp(1.58rem, 2.5vw, 2.05rem);
      margin: 0 0 .75rem;
    }

    .materials-cta p {
      max-width: 41rem;
      margin: 0 auto 1.5rem;
      color: rgba(255, 255, 255, 0.92);
      font-size: 1.1rem;
      line-height: 1.65;
    }

    .materials-cta-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 1.2rem;
    }

    .materials-cta-contact {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
      margin-top: 1.55rem;
      font-size: 1.05rem;
      font-weight: 700;
    }

    .materials-cta-contact a {
      display: inline-flex;
      align-items: center;
      gap: .42rem;
      color: #fff;
    }

    .materials-cta-contact svg {
      width: 1.02rem;
      height: 1.02rem;
      fill: currentColor;
      flex-shrink: 0;
    }

    @media (max-width: 900px) {
      .materials-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 768px) {
      .materials-hero {
        padding: 3.75rem 0 4.6rem;
      }

      .materials-grid {
        margin-top: -1.9rem;
      }

      .materials-card,
      .materials-coming {
        padding: 1.85rem;
      }

      .materials-card {
        min-height: auto;
      }

      .materials-cta-actions {
        flex-direction: column;
      }

      .materials-cta-actions a {
        width: 100%;
      }

      .materials-cta-contact {
        flex-direction: column;
      }

      .materials-cta-contact span {
        display: none;
      }

      .materials-coming {
        margin-bottom: 1.8rem;
      }

      .materials-cta {
        padding: 2.9rem 0 3rem;
      }
    }
  </style>
</Base>
