---
import Base from '../layouts/Base.astro';
import { getMaterialHubData } from '../lib/wp-materials';

const hub = getMaterialHubData();

const iconPaths: Record<string, string> = {
  layers: 'M12 4 3 8l9 4 9-4-9-8Zm0 10L3 10v4l9 4 9-4v-4l-9 4Zm0 6-9-4v4l9 4 9-4v-4l-9 4Z',
  terminal: 'M5 6h14a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Zm2.2 3.1L10 12l-2.8 2.9 1.3 1.2 4-4.1-4-4.1-1.3 1.2Zm5.8 6.9h5v-2h-5v2Z',
  fileText: 'M7 3h7l5 5v11a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm6 1.5V9h4.5M8.5 12h7M8.5 15h7M8.5 18H14',
  search: 'M10.5 4a6.5 6.5 0 1 0 4.03 11.6l4.43 4.43 1.41-1.41-4.43-4.43A6.5 6.5 0 0 0 10.5 4Zm0 2a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9Z',
  bulb: 'M12 2a6.5 6.5 0 0 0-3.98 11.64c.52.4.83 1 .83 1.65V16a1 1 0 0 0 1 1h4.3a1 1 0 0 0 1-1v-.71c0-.64.3-1.24.82-1.64A6.5 6.5 0 0 0 12 2Zm-1.5 16h3a2 2 0 0 1-3 0Zm-.5-3.03c0-1.03-.47-2.01-1.29-2.66A4.5 4.5 0 1 1 15.3 12.3c-.83.65-1.3 1.63-1.3 2.67h-4Z',
  linkedin: 'M6.94 8.5V19H3.56V8.5h3.38ZM5.25 3A2 2 0 1 1 5.2 7a2 2 0 0 1 .05-4ZM20.44 19h-3.37v-5.1c0-1.22-.02-2.8-1.7-2.8-1.7 0-1.97 1.33-1.97 2.7V19H10V8.5h3.23v1.43h.04c.45-.85 1.55-1.74 3.2-1.74 3.42 0 4.05 2.25 4.05 5.18V19Z',
  phone: 'M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24c1.1.36 2.27.56 3.49.56a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.3 21 3 13.7 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.22.19 2.39.56 3.49a1 1 0 0 1-.25 1.01l-2.19 2.29Z',
  mail: 'M4 6h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1Zm8 5.2L4.8 7.8h14.4L12 11.2Zm7 6.8V9.1l-6.46 3.03a1.2 1.2 0 0 1-1.08 0L5 9.1V18h14Z',
};
---

<Base title="Materiály a AI nástroje zdarma – Pavel Kovařík" description="Praktické AI materiály pro firmy i jednotlivce na jednom místě. Objevte ověřené AI nástroje, knihovnu funkčních promptů a návody z mých školení. Vše zdarma.">
  <div id="materialy-hub" class="ai-page">
    <section class="hero">
      <div class="container">
        <span class="badge">Know-how</span>
        <h1>Materiály a zdroje k AI</h1>
        <p class="hero-subtitle">Praktické nástroje, prompty a návody, které využívám na školeních. Vše na jednom místě a zdarma pro vaše použití.</p>
      </div>
    </section>

    <div class="container">
      <div class="main-grid">
        {hub.cards.map((card) => (
          <article class="hub-card">
            <div class="card-icon-wrapper">
              <svg viewBox="0 0 24 24" class="card-icon" aria-hidden="true">
                <path d={iconPaths[card.icon]} />
              </svg>
            </div>
            <h2><a href={card.href}>{card.title}</a></h2>
            <p>{card.description}</p>
            <a href={card.href} class="card-link">
              {card.linkLabel}
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>

      <div class="newsletter-section">
        <div class="newsletter-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d={iconPaths.bulb} />
          </svg>
        </div>
        <h3>{hub.upcomingTitle}</h3>
        <p>{hub.upcomingDescription}</p>
        <div class="tags">
          {hub.upcomingTags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <div class="newsletter-link">
          <a href={hub.linkedinHref} target="_blank" rel="noopener" class="card-link">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d={iconPaths.linkedin} />
            </svg>
            Sledujte novinky na LinkedInu
          </a>
        </div>
      </div>
    </div>

    <section class="cta-final">
      <div class="container">
        <h2>Hledáte způsob, jak AI zavést ve firmě?</h2>
        <p>Materiály jsou skvělý začátek. Pokud ale chcete ušetřit čas a vyhnout se slepým uličkám, ozvěte se. Provedu vás světem AI prakticky.</p>
        <div class="btn-group">
          <a href="/kontakt/" class="btn btn-white">Poptat AI školení</a>
          <a href="/skoleni/" class="btn btn-outline">Nabídka kurzů</a>
        </div>
        <div class="cta-contact">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d={iconPaths.phone} /></svg>
          +420 770 126 519
          <span>·</span>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d={iconPaths.mail} /></svg>
          mail@pavelkovarik.cz
        </div>
      </div>
    </section>
  </div>

  <style>
    #materialy-hub {
      --brand: #3d5cd9;
      --brand-dark: #2a49c7;
      --text: #1f2937;
      --text-light: #4b5563;
      --bg: #f8fafc;
      --surface: #ffffff;
      --line: #e5e7eb;
      --radius-lg: 16px;
      --radius-md: 12px;
      --shadow: 0 4px 16px rgba(0,0,0,0.08);
      --shadow-lg: 0 12px 36px rgba(61,92,217,0.15);
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    #materialy-hub .container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 24px;
    }

    #materialy-hub h1,
    #materialy-hub h2,
    #materialy-hub h3 {
      line-height: 1.25;
      font-weight: 800;
      margin-bottom: 1rem;
      color: var(--text);
    }

    #materialy-hub h1 {
      font-size: 2.4rem;
      color: #fff;
    }

    #materialy-hub h2 {
      font-size: 1.9rem;
      text-align: center;
      margin-bottom: 1.5rem;
    }

    #materialy-hub h3 {
      font-size: 1.5rem;
    }

    #materialy-hub p {
      font-weight: 400;
      margin-bottom: 1rem;
      color: var(--text-light);
    }

    #materialy-hub .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 200px;
      height: 52px;
      padding: 0 32px;
      border-radius: var(--radius-md);
      font-weight: 700;
      text-decoration: none;
      font-size: 1rem;
      border: 2px solid transparent;
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.3s ease;
    }

    #materialy-hub .btn-white {
      background: #fff;
      color: var(--brand);
      box-shadow: var(--shadow);
    }

    #materialy-hub .btn-white:hover {
      background: #f1f5f9;
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0,0,0,0.12);
    }

    #materialy-hub .btn-outline {
      border: 2px solid #fff;
      color: #fff;
      background: transparent;
    }

    #materialy-hub .btn-outline:hover {
      background: rgba(255,255,255,0.1);
      transform: translateY(-2px);
    }

    #materialy-hub .btn-group {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 1.5rem;
    }

    #materialy-hub .hero {
      background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);
      color: #fff;
      padding: 60px 24px 80px;
      text-align: center;
    }

    #materialy-hub .badge {
      display: inline-block;
      background: rgba(255,255,255,0.15);
      padding: 6px 16px;
      border-radius: 50px;
      font-size: 0.85rem;
      font-weight: 700;
      margin-bottom: 1.2rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    #materialy-hub .hero-subtitle {
      font-size: 1.2rem;
      max-width: 700px;
      margin: 0 auto;
      opacity: 0.95;
      color: #fff;
    }

    #materialy-hub .main-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: -40px;
      margin-bottom: 50px;
      position: relative;
      z-index: 10;
    }

    #materialy-hub .hub-card {
      background: #fff;
      border-radius: var(--radius-lg);
      padding: 32px;
      border: 1px solid var(--line);
      box-shadow: var(--shadow);
      transition: all 0.3s ease;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      height: 100%;
    }

    #materialy-hub .hub-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 35px rgba(61,92,217,0.15);
      border-color: var(--brand);
    }

    #materialy-hub .card-icon-wrapper {
      width: 70px;
      height: 70px;
      background: linear-gradient(135deg, #f0f4ff 0%, #e8f0fe 100%);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 25px;
      transition: background 0.3s;
    }

    #materialy-hub .hub-card:hover .card-icon-wrapper {
      background: var(--brand);
    }

    #materialy-hub .card-icon {
      width: 32px;
      height: 32px;
      fill: var(--brand);
      transition: fill 0.3s;
    }

    #materialy-hub .hub-card:hover .card-icon {
      fill: #fff;
    }

    #materialy-hub .hub-card h2 {
      text-align: left;
      font-size: 1.35rem;
    }

    #materialy-hub .hub-card h2 a {
      color: var(--text);
      text-decoration: none;
      transition: color 0.2s;
    }

    #materialy-hub .hub-card:hover h2 a {
      color: var(--brand);
    }

    #materialy-hub .card-link {
      font-weight: 700;
      color: var(--brand);
      font-size: 1rem;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      margin-top: auto;
    }

    #materialy-hub .card-link svg {
      width: 18px;
      height: 18px;
      fill: currentColor;
    }

    #materialy-hub .card-link span {
      transition: transform 0.2s;
    }

    #materialy-hub .hub-card:hover .card-link span {
      transform: translateX(5px);
    }

    #materialy-hub .newsletter-section {
      background: #fff;
      border-radius: var(--radius-lg);
      padding: 50px;
      text-align: center;
      border: 1px solid var(--line);
      margin-bottom: 0;
    }

    #materialy-hub .newsletter-icon {
      width: 40px;
      height: 40px;
      margin: 0 auto 20px;
      color: #f59e0b;
    }

    #materialy-hub .newsletter-icon svg {
      width: 100%;
      height: 100%;
      fill: currentColor;
    }

    #materialy-hub .tags {
      display: flex;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 20px;
    }

    #materialy-hub .tag {
      background: #f1f5f9;
      color: #64748b;
      padding: 6px 14px;
      border-radius: 50px;
      font-size: 0.85rem;
      font-weight: 600;
    }

    #materialy-hub .newsletter-link {
      margin-top: 30px;
    }

    #materialy-hub .newsletter-link .card-link {
      justify-content: center;
      font-size: 1.05rem;
    }

    #materialy-hub .cta-final {
      background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);
      color: #fff;
      padding: 60px 24px;
      text-align: center;
      margin-top: 40px;
    }

    #materialy-hub .cta-final h2 {
      color: #fff;
      font-size: 1.8rem;
    }

    #materialy-hub .cta-final p {
      color: rgba(255,255,255,0.9);
      font-size: 1.05rem;
    }

    #materialy-hub .cta-contact {
      margin-top: 25px;
      font-weight: 700;
      font-size: 1.05rem;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: center;
    }

    #materialy-hub .cta-contact svg {
      width: 18px;
      height: 18px;
      fill: currentColor;
    }

    @media (max-width: 768px) {
      #materialy-hub h1 { font-size: 2rem; }
      #materialy-hub .main-grid { grid-template-columns: 1fr; margin-top: -30px; }
      #materialy-hub .hub-card { padding: 30px; }
      #materialy-hub .btn { width: 100%; }
      #materialy-hub .btn-group { flex-direction: column; }
    }
  </style>
</Base>
