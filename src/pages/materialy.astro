---
import Base from '../layouts/Base.astro';
import { getMaterialHubData } from '../lib/wp-materials';

const hub = getMaterialHubData();

const iconPaths: Record<string, string> = {
  layers: 'M12 4 3 8l9 4 9-4-9-8Zm0 10L3 10v4l9 4 9-4v-4l-9 4Zm0 6-9-4v4l9 4 9-4v-4l-9 4Z',
  terminal: 'M5 6h14a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Zm2.2 3.1L10 12l-2.8 2.9 1.3 1.2 4-4.1-4-4.1-1.3 1.2Zm5.8 6.9h5v-2h-5v2Z',
};
---

<Base title="Materiály a AI nástroje zdarma – Pavel Kovařík" description="Praktické nástroje, prompty a návody, které využívám na školeních. Vše na jednom místě a zdarma.">
  <section class="pk-page-hero materials-hero">
    <div class="wrap">
      <h1>Materiály a zdroje k AI</h1>
      <p>Praktické nástroje, prompty a návody, které využívám na školeních. Vše na jednom místě a zdarma pro vaše použití.</p>
    </div>
  </section>

  <section class="materials-shell">
    <div class="wrap">
      <div class="materials-grid">
        {hub.cards.map((card) => (
          <article class={`materials-card ${card.title.includes('prompty') ? 'materials-card-accent' : ''}`}>
            <div class="materials-card-icon">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d={iconPaths[card.icon]} />
              </svg>
            </div>
            <h2>{card.title}</h2>
            <p>{card.description}</p>
            <a href={card.href} class="materials-card-link">
              {card.linkLabel}
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>

      <section class="materials-coming">
        <div class="materials-coming-icon" aria-hidden="true">💡</div>
        <h2>{hub.upcomingTitle}</h2>
        <p>{hub.upcomingDescription}</p>
        <div class="materials-tags">
          {hub.upcomingTags.map((tag) => <span>{tag}</span>)}
        </div>
        <a href={hub.linkedinHref} target="_blank" rel="noopener" class="materials-linkedin">
          <span aria-hidden="true">in</span>
          Sledujte novinky na LinkedInu
        </a>
      </section>
    </div>
  </section>

  <section class="materials-cta">
    <div class="wrap">
      <h2>Hledáte způsob, jak AI zavést ve firmě?</h2>
      <p>Materiály jsou skvělý začátek. Pokud ale chcete ušetřit čas a vyhnout se slepým uličkám, ozvěte se. Provedu vás světem AI prakticky.</p>
      <div class="materials-cta-actions">
        <a href="/kontakt/" class="btn btn-white">Poptat AI školení</a>
        <a href="/skoleni/" class="btn btn-outline">Nabídka kurzů</a>
      </div>
      <div class="materials-cta-contact">
        <a href="tel:+420770126519">+420 770 126 519</a>
        <span>·</span>
        <a href="mailto:mail@pavelkovarik.cz">mail@pavelkovarik.cz</a>
      </div>
    </div>
  </section>

  <style>
    .materials-hero {
      padding: 4.3rem 0 5.4rem;
    }

    .materials-shell {
      background: var(--pk-bg-alt);
      padding: 0 0 3.6rem;
    }

    .materials-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.4rem;
      max-width: 980px;
      margin: -3.15rem auto 2.35rem;
      position: relative;
      z-index: 2;
    }

    .materials-card,
    .materials-coming {
      background: #fff;
      border: 1px solid rgba(15,23,42,.09);
      border-radius: 1.35rem;
      box-shadow: 0 10px 26px rgba(15,23,42,.05);
    }

    .materials-card {
      padding: 2.2rem 2.15rem;
      display: flex;
      flex-direction: column;
      gap: .85rem;
      min-height: 20rem;
    }

    .materials-card-accent {
      border-color: rgba(61,92,217,.75);
    }

    .materials-card h2 {
      font-size: clamp(1.28rem, 2vw, 1.9rem);
      letter-spacing: -0.02em;
      margin: 0;
    }

    .materials-card p {
      font-size: 1rem;
      color: var(--pk-text-2);
      line-height: 1.72;
      margin: 0;
    }

    .materials-card-link {
      margin-top: auto;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1rem;
      font-weight: 700;
    }

    .materials-card-icon {
      width: 4.25rem;
      height: 4.25rem;
      border-radius: 1rem;
      background: linear-gradient(135deg, #eef3ff 0%, #dfe8ff 100%);
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .materials-card-icon svg {
      width: 1.8rem;
      height: 1.8rem;
      fill: var(--pk-primary);
    }

    .materials-coming {
      padding: 2.4rem 2rem;
      text-align: center;
      max-width: 980px;
      margin: 0 auto 2.4rem;
    }

    .materials-coming-icon {
      font-size: 2rem;
      margin-bottom: .85rem;
    }

    .materials-coming h2 {
      font-size: clamp(1.45rem, 2.2vw, 2rem);
      margin: 0 0 .85rem;
    }

    .materials-coming p {
      max-width: 38rem;
      margin: 0 auto;
      color: var(--pk-text-2);
      font-size: 1rem;
      line-height: 1.72;
    }

    .materials-tags {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin: 1.35rem 0;
    }

    .materials-tags span {
      padding: 0.58rem .95rem;
      border-radius: 999px;
      background: var(--pk-bg-alt2);
      color: var(--pk-text-2);
      font-weight: 600;
      font-size: .92rem;
    }

    .materials-linkedin {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 1rem;
      font-weight: 700;
    }

    .materials-linkedin span {
      width: 1.45rem;
      height: 1.45rem;
      border-radius: 0.3rem;
      background: var(--pk-primary);
      color: #fff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 0.9rem;
      font-weight: 800;
    }

    .materials-cta {
      background: linear-gradient(135deg, var(--pk-primary) 0%, var(--pk-primary-dark) 100%);
      color: #fff;
      text-align: center;
      padding: 4rem 0;
    }

    .materials-cta h2 {
      color: #fff;
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      margin: 0 0 .85rem;
    }

    .materials-cta p {
      max-width: 46rem;
      margin: 0 auto 1.5rem;
      color: rgba(255, 255, 255, 0.92);
      font-size: 1.08rem;
      line-height: 1.72;
    }

    .materials-cta-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 1.5rem;
    }

    .materials-cta-contact {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
      font-size: 1.1rem;
      font-weight: 700;
    }

    .materials-cta-contact a {
      color: #fff;
    }

    @media (max-width: 900px) {
      .materials-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 768px) {
      .materials-hero {
        padding: 3.5rem 0 4.6rem;
      }

      .materials-grid {
        margin-top: -2.35rem;
      }

      .materials-card,
      .materials-coming {
        padding: 1.65rem 1.4rem;
      }

      .materials-card {
        min-height: auto;
      }

      .materials-cta-contact {
        flex-direction: column;
      }

      .materials-cta-contact span {
        display: none;
      }
    }
  </style>
</Base>
