---
import fs from 'node:fs';
import path from 'node:path';
import { importedPosts } from '../data/importedPosts';

interface Props {
  filePath: string;
}

const { filePath } = Astro.props;

const root = process.cwd();
const fullPath = path.isAbsolute(filePath) ? filePath : path.join(root, filePath);
const data = JSON.parse(fs.readFileSync(fullPath, 'utf8'));
const isHomepage = fullPath.endsWith('homepage-full.json');

const logoMap: Record<string, string> = {
  'https://pavelkovarik.cz/wp-content/uploads/2025/04/pavel-kovarik-profile.webp': '/images/web/pavel-kovarik-profile.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2025/07/Jak-vybrat-AI-skoleni-pro-firmy-ktere-prinese-realne-vysledky.webp': '/images/blog/Jak-vybrat-AI-skoleni-pro-firmy-ktere-prinese-realne-vysledky.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/ceska-sporitelna.jpg': '/images/loga/ceska-sporitelna.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/partners.jpg': '/images/loga/partners.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/ptacek.jpg': '/images/loga/ptacek.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/dopravni-podnik-pardubice.jpg': '/images/loga/dopravni-podnik-pardubice.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/broker-consulting.jpg': '/images/loga/broker-consulting.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/proventiacz.jpg': '/images/loga/proventiacz.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/dt-vyhybkarna.jpg': '/images/loga/dt-vyhybkarna.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/khk-pardubicky-kraj.jpg': '/images/loga/khk-pardubicky-kraj.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/rubikon.jpg': '/images/loga/rubikon.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/narodni-strojirenskyy-klastr.jpg': '/images/loga/narodni-strojirenskyy-klastr.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/mm-reality.jpg': '/images/loga/mm-reality.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/matikon.jpg': '/images/loga/matikon.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/vak-hodonin.jpg': '/images/loga/vak-hodonin.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/veacom.jpg': '/images/loga/veacom.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/ibv-nbs.jpg': '/images/loga/ibv-nbs.webp',
  'https://pavelkovarik.cz/wp-content/uploads/2026/02/makovec.jpg': '/images/loga/makovec.webp',
};

const routeMap: Record<string, string> = {
  'https://pavelkovarik.cz/': '/',
  'https://pavelkovarik.cz/blog/': '/blog/',
  'https://pavelkovarik.cz/ai-nastroje/': '/ai-nastroje/',
  'https://pavelkovarik.cz/prompty/': '/prompty/',
  'https://pavelkovarik.cz/materialy/ai-nastroje/': '/ai-nastroje/',
  'https://pavelkovarik.cz/materialy/prompty/': '/prompty/',
  'https://pavelkovarik.cz/materialy/': '/materialy/',
  'https://pavelkovarik.cz/skoleni/': '/skoleni/',
  'https://pavelkovarik.cz/kontakt/': '/kontakt/',
  'https://pavelkovarik.cz/prakticke-skoleni-ai-pro-firmy/': '/prakticke-skoleni-ai-pro-firmy/',
  'https://pavelkovarik.cz/microsoft-copilot-pro-firmy/': '/microsoft-copilot-pro-firmy/',
  'https://pavelkovarik.cz/marketing-pr-s-ai/': '/marketing-pr-ai/',
  'https://pavelkovarik.cz/skoleni-marketing-pr-s-ai/': '/marketing-pr-ai/',
  'https://pavelkovarik.cz/marketing-pr-ai/': '/marketing-pr-ai/',
  'https://pavelkovarik.cz/linkedin-byznys-osobni-znacka-ai/': '/marketing-pr-ai/',
  'https://pavelkovarik.cz/ai-pro-verejnou-spravu/': '/ai-pro-verejnou-spravu/',
  'https://pavelkovarik.cz/skoleni-na-miru/': '/skoleni-na-miru/',
  'https://pavelkovarik.cz/pravo-v-ai/': '/pravo-v-ai/',
  'https://pavelkovarik.cz/gdpr/': '/gdpr-ochrana-osobnich-udaju/',
  'https://pavelkovarik.cz/gdpr-ochrana-osobnich-udaju/': '/gdpr-ochrana-osobnich-udaju/',
  '/materialy/ai-nastroje/': '/ai-nastroje/',
  '/materialy/prompty/': '/prompty/',
  '/marketing-pr-s-ai/': '/marketing-pr-ai/',
  '/skoleni-marketing-pr-s-ai/': '/marketing-pr-ai/',
  '/linkedin-byznys-osobni-znacka-ai/': '/marketing-pr-ai/',
  '/blog': '/blog/',
  '/kontakt': '/kontakt/',
  '/skoleni': '/skoleni/',
  '/microsoft-copilot/': '/microsoft-copilot-pro-firmy/',
  '/gdpr/': '/gdpr-ochrana-osobnich-udaju/',
};

let content = String(data.content ?? '');

const escapeHtml = (value: string) =>
  value
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;');

const formatCzDate = (dateString: string) =>
  new Intl.DateTimeFormat('cs-CZ', {
    day: 'numeric',
    month: 'numeric',
    year: 'numeric',
  }).format(new Date(dateString));

if (isHomepage) {
  const latestPostsHtml = importedPosts
    .slice(0, 2)
    .map(
      (post) => `
        <a href="${post.url}" class="pk-blog-card">
          <img decoding="async" src="${post.image}" class="pk-blog-card-img" alt="${escapeHtml(post.title)}">
          <div class="pk-blog-card-content">
            <span class="pk-blog-card-date">${formatCzDate(post.date)}</span>
            <h3 class="pk-blog-card-title">${escapeHtml(post.title)}</h3>
          </div>
        </a>
      `.trim(),
    )
    .join('');

  content = content.replace(
    '<div class="pk-blog-grid" id="pk-blog-latest"></div>',
    `<div class="pk-blog-grid" id="pk-blog-latest">${latestPostsHtml}</div>`,
  );
}

content = content.replace(/<link\b[^>]*>/gi, '');
content = content.replace(/<script\b[^>]*\bsrc="[^"]*"[^>]*>\s*<\/script>/gi, '');
content = content.replace(/<a([^>]*?)href="\/cdn-cgi\/l\/email-protection[^"]*"([^>]*)>/gi, '<a$1href="mailto:mail@pavelkovarik.cz"$2>');
content = content.replace(/<a([^>]*?)class="__cf_email__"([^>]*)data-cfemail="[^"]*"([^>]*)>\[[^\]]+\]<\/a>/gi, '<a$1$2$3>mail@pavelkovarik.cz</a>');

for (const [from, to] of Object.entries(logoMap)) {
  content = content.replaceAll(from, to);
}

for (const [from, to] of Object.entries(routeMap)) {
  content = content.replaceAll(from, to);
}

content = content.replaceAll('https://pavelkovarik.cz', '');

const scripts: Array<{ body: string; type?: string }> = [];
content = content.replace(/<script\b([^>]*)>([\s\S]*?)<\/script>/gi, (_match, attrs, scriptBody) => {
  const cleanedScript = scriptBody.trim();
  if (
    cleanedScript.length > 0 &&
    !cleanedScript.includes('cloudflare-static/email-decode') &&
    !cleanedScript.includes('/wp-json/wp/v2/posts')
  ) {
    const typeMatch = attrs.match(/\btype=(["'])(.*?)\1/i);
    scripts.push({ body: cleanedScript, type: typeMatch?.[2] });
  }
  return '';
});
---

<main class="imported-wp-page">
  <div class="page-content imported-wp-page__content">
    <Fragment set:html={content} />
  </div>
</main>

{scripts.map(({ body, type }) =>
  type ? <script is:inline type={type} set:html={body}></script> : <script is:inline set:html={body}></script>,
)}
