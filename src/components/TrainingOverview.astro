---
import { trainingCourses, trainingFaqs, trainingLogos } from '../data/trainingOverview';

const primaryCourses = trainingCourses.filter((course) => course.category === 'primary');
const workshopCourses = trainingCourses.filter((course) => course.category === 'workshop');
const supplementCourses = trainingCourses.filter((course) => course.category === 'supplement');
const toolCourses = trainingCourses.filter((course) => course.category === 'tool');
---

<div class="pk-rozcestnik">
  <section class="hero">
    <div class="container">
      <span class="badge">PŘEHLED ŠKOLENÍ</span>
      <h1>AI školení pro firmy a organizace</h1>
      <p class="hero-subtitle">Vyberte si školení podle role, cíle nebo tématu. Hlavní nabídku tvoří tři pilíře, doplněné o specializované workshopy a další formáty.</p>
      <div class="btn-group">
        <a href="#kurzy" class="btn btn-white">Vybrat školení</a>
        <a href="/kontakt/" class="btn btn-outline">Nechat si doporučit školení</a>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="verified-card">
      <div class="stars">★★★★★</div>
      <h3>Školení v souladu s doporučeními České asociace umělé inteligence</h3>
      <p>Obsah vychází z ověřených postupů, respektuje pravidla GDPR i nařízení AI Act a zároveň je postavený na reálných úkolech z firemní praxe.</p>
    </div>
  </div>

  <section class="section pk-overview-intro">
    <div class="container">
      <div class="intro-text">
        <p>Na této stránce najdete jasnou mapu nabídky: 3 hlavní pilíře, 2 specializované workshopy, 3 doplňkové formáty a SEO stránky podle nástroje.</p>
      </div>
    </div>
  </section>

  <section class="section pk-courses" id="kurzy">
    <div class="container">
      <div class="pk-courses-divider" aria-hidden="true"></div>

      <div class="pk-course-group">
        <h3 class="pk-course-group-title">Hlavní školení</h3>
        <div class="training-list">
          {primaryCourses.map((course) => (
            <article class:list={['training-list-item', course.featured && 'is-featured']}>
              <div class="training-list-main">
                <div class:list={['course-badge', course.badgeClass]}>{course.badge}</div>
                <h3 class="course-title">
                  <a href={course.href} class="course-title-link">{course.title}</a>
                </h3>
                <div class="course-subtitle">{course.subtitle}</div>
                <div class="course-description">{course.description}</div>
                {course.note && <div class="bonus-box">{course.note}</div>}
                <div class="course-footer">
                  <div class="course-meta">
                    {course.meta.map((item) => <span>{item}</span>)}
                  </div>
                  <div class="training-list-side">
                    <a href={course.href} class="course-link course-link-primary">Zjistit více</a>
                    <a href="/kontakt/" class="course-link">Poptat školení</a>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="pk-course-group">
        <h3 class="pk-course-group-title">Specializované workshopy</h3>
        <div class="training-list">
          {workshopCourses.map((course) => (
          <article class:list={['training-list-item', course.featured && 'is-featured']}>
            <div class="training-list-main">
              <div class:list={['course-badge', course.badgeClass]}>{course.badge}</div>
              <h3 class="course-title">
                <a href={course.href} class="course-title-link">{course.title}</a>
              </h3>
              <div class="course-subtitle">{course.subtitle}</div>
              <div class="course-description">{course.description}</div>
              {course.note && <div class="bonus-box">{course.note}</div>}
              <div class="course-footer">
                <div class="course-meta">
                  {course.meta.map((item) => <span>{item}</span>)}
                </div>
                <div class="training-list-side">
                  <a href={course.href} class="course-link course-link-primary">Zjistit více</a>
                </div>
              </div>
            </div>
          </article>
          ))}
        </div>
      </div>

      <div class="pk-course-group">
        <h3 class="pk-course-group-title">Doplňkové formáty</h3>
        <div class="training-list">
          {supplementCourses.map((course) => (
            <article class:list={['training-list-item', course.featured && 'is-featured']}>
              <div class="training-list-main">
                <div class:list={['course-badge', course.badgeClass]}>{course.badge}</div>
                <h3 class="course-title">
                  <a href={course.href} class="course-title-link">{course.title}</a>
                </h3>
                <div class="course-subtitle">{course.subtitle}</div>
                <div class="course-description">{course.description}</div>
                <div class="course-footer">
                  <div class="course-meta">
                    {course.meta.map((item) => <span>{item}</span>)}
                  </div>
                  <div class="training-list-side">
                    {course.title === 'Školení na míru' ? (
                      <>
                        <a href="/kontakt/" class="course-link course-link-primary">Nechat si doporučit školení</a>
                        <a href="/kontakt/" class="course-link">Poptat školení</a>
                      </>
                    ) : (
                      <a href={course.href} class="course-link course-link-primary">Zjistit více</a>
                    )}
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="pk-course-group">
        <h3 class="pk-course-group-title">Podle nástroje</h3>
        <div class="training-list pk-tool-list">
          {toolCourses.map((course) => (
            <article class="training-list-item pk-tool-item">
              <div class="training-list-main">
                <div class:list={['course-badge', course.badgeClass]}>{course.badge}</div>
                <h3 class="course-title">
                  <a href={course.href} class="course-title-link">{course.title}</a>
                </h3>
                <div class="course-subtitle">{course.subtitle}</div>
                <div class="course-description">{course.description}</div>
                <div class="course-footer">
                  <div class="course-meta">
                    {course.meta.map((item) => <span>{item}</span>)}
                  </div>
                  <div class="training-list-side">
                    <a href={course.href} class="course-link course-link-primary">Zjistit více</a>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section pk-custom-training">
    <div class="container">
      <div class="custom-box">
        <div class="custom-badge">✓ INDIVIDUÁLNÍ PŘÍSTUP</div>
        <h3>Potřebujete školení přesně pro vaši firmu?</h3>
        <p>Školení na míru kombinuje témata podle vašich potřeb. Zaměřím se na vaše konkrétní procesy, nástroje a cíle. Obsah i délku nastavíme podle toho, co potřebujete.</p>
        <div class="btn-group">
          <a href="/kontakt/" class="btn btn-primary">Nechat si doporučit školení</a>
          <a href="/kontakt/" class="btn btn-secondary">Poptat školení</a>
        </div>
      </div>
    </div>
  </section>

  <div class="logos-section">
    <div class="container">
      <h2 class="logos-title">Proškolil jsem zaměstnance těchto firem</h2>
      <div class="logos-grid">
        {trainingLogos.map((logo) => (
          <div class="logo-item">
            <img src={logo.src} alt={logo.alt} loading="lazy" decoding="async" />
          </div>
        ))}
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <h2>Časté otázky o školení AI</h2>
      <div class="faq-section">
        <div class="faq">
          {trainingFaqs.map((item) => (
            <details>
              <summary>{item.question}</summary>
              <div class="faq-body">
                <div class="faq-body-inner">
                  <p>{item.answer}</p>
                </div>
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section pk-final-cta">
    <div class="container">
      <div class="cta-final">
        <h2>Nejste si jistí, které školení vybrat?</h2>
        <p>Stačí mi stručně popsat vaši firmu, tým a cíle. Doporučím vám školení, které bude dávat největší smysl.</p>
        <div class="btn-group">
          <a href="/kontakt/" class="btn btn-white">Nezávazná konzultace</a>
          <a href="#kurzy" class="btn btn-outline">Zobrazit všechna školení</a>
        </div>
        <div class="cta-contact">
          📞 +420 770 126 519 · ✉️ <a href="mailto:mail@pavelkovarik.cz">mail@pavelkovarik.cz</a>
        </div>
        <p class="cta-note">✓ Odpovím do 24 hodin ✓ Konzultace zdarma ✓ Bez závazků</p>
      </div>
    </div>
  </section>
</div>
