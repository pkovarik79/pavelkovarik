---
import fs from 'node:fs';
import path from 'node:path';
import { blogImageAlts } from '../data/blogImageAlts';

interface Props {
  filePath: string;
}

const { filePath } = Astro.props;

const root = process.cwd();
const fullPath = path.isAbsolute(filePath) ? filePath : path.join(root, filePath);
const data = JSON.parse(fs.readFileSync(fullPath, 'utf8'));

const escapeHtml = (value: string) =>
  value
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;');

const escapeRegExp = (value: string) => value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

const routeMap: Record<string, string> = {
  'https://pavelkovarik.cz/': '/',
  'https://pavelkovarik.cz/blog/': '/blog/',
  'https://pavelkovarik.cz/ai-nastroje/': '/ai-nastroje/',
  'https://pavelkovarik.cz/prompty/': '/prompty/',
  'https://pavelkovarik.cz/materialy/ai-nastroje/': '/ai-nastroje/',
  'https://pavelkovarik.cz/materialy/prompty/': '/prompty/',
  'https://pavelkovarik.cz/materialy/': '/materialy/',
  'https://pavelkovarik.cz/skoleni/': '/skoleni/',
  'https://pavelkovarik.cz/kontakt/': '/kontakt/',
  'https://pavelkovarik.cz/prakticke-skoleni-ai-pro-firmy/': '/prakticke-skoleni-ai-pro-firmy/',
  'https://pavelkovarik.cz/microsoft-copilot-pro-firmy/': '/microsoft-copilot-pro-firmy/',
  'https://pavelkovarik.cz/marketing-pr-s-ai/': '/marketing-pr-ai/',
  'https://pavelkovarik.cz/skoleni-marketing-pr-s-ai/': '/marketing-pr-ai/',
  'https://pavelkovarik.cz/marketing-pr-ai/': '/marketing-pr-ai/',
  'https://pavelkovarik.cz/linkedin-byznys-osobni-znacka-ai/': '/marketing-pr-ai/',
  'https://pavelkovarik.cz/ai-pro-verejnou-spravu/': '/ai-pro-verejnou-spravu/',
  'https://pavelkovarik.cz/skoleni-na-miru/': '/skoleni-na-miru/',
  'https://pavelkovarik.cz/pravo-v-ai/': '/pravo-v-ai/',
  'https://pavelkovarik.cz/gdpr/': '/gdpr-ochrana-osobnich-udaju/',
  'https://pavelkovarik.cz/gdpr-ochrana-osobnich-udaju/': '/gdpr-ochrana-osobnich-udaju/',
  '/materialy/ai-nastroje/': '/ai-nastroje/',
  '/materialy/prompty/': '/prompty/',
  '/marketing-pr-s-ai/': '/marketing-pr-ai/',
  '/skoleni-marketing-pr-s-ai/': '/marketing-pr-ai/',
  '/linkedin-byznys-osobni-znacka-ai/': '/marketing-pr-ai/',
  '/microsoft-copilot/': '/microsoft-copilot-pro-firmy/',
  '/gdpr/': '/gdpr-ochrana-osobnich-udaju/',
  '/wp-content/uploads/2026/01/logo-pavel-kovarik-flt.png': '/images/web/logo-pavel-kovarik-flt.webp',
  '/wp-content/uploads/2026/03/ai-skoleni-cena.jpg': '/images/blog/ai-skoleni-cena.webp',
  '/wp-content/uploads/2026/03/blog-push-vs.-pull-learning.png': '/images/2026/03/blog-push-vs-pull-learning.svg',
  '/wp-content/uploads/2026/03/blog-seo-drive-a-ted.png': '/images/2026/03/blog-seo-drive-a-ted.svg',
  '/wp-content/uploads/2026/03/blog-claude-prez-artifacts.png': '/images/2026/03/blog-claude-prez-artifacts.svg',
  '/wp-content/uploads/2026/03/bog-claude-powerpoint.png': '/images/2026/03/blog-claude-powerpoint.svg',
};

let content = String(data.content ?? '');

content = content.replaceAll('<!-- wp:html -->', '');
content = content.replaceAll('<!-- /wp:html -->', '');
content = content.replace(/<link\b[^>]*>/gi, '');

// Style AI Act disclaimer as a subtle note.
content = content.replace(
  /<p>(Tento článek má informativní a vzdělávací charakter\. Nepředstavuje právní poradenství ani právní posouzení konkrétní situace\. U konkrétního nasazení AI vždy záleží na účelu použití, typu dat, roli dodavatele a aktuálním výkladu pravidel\.)<\/p>/g,
  '<p class="pk-meta article-disclaimer">$1</p>',
);

for (const [from, to] of Object.entries(routeMap)) {
  content = content.replaceAll(from, to);
}

content = content.replace(
  /https:\/\/pavelkovarik\.cz\/wp-content\/uploads\/(\d{4})\/(\d{2})\/([^"' )]+)/g,
  (_match, year, month, file) => `/images/${year}/${month}/${file}`,
);

content = content.replaceAll('https://pavelkovarik.cz', '');

for (const [imageSrc, imageAlt] of Object.entries(blogImageAlts)) {
  const escapedSrc = escapeRegExp(imageSrc);
  const imgRegex = new RegExp(`<img([^>]*?)\\ssrc=(["'])${escapedSrc}\\2([^>]*?)>`, 'gi');
  content = content.replace(imgRegex, (match, before, quote, after) => {
    const altValue = escapeHtml(imageAlt);
    if (/\\salt=/i.test(match)) {
      return match.replace(/\\salt=(["']).*?\\1/i, ` alt="${altValue}"`);
    }
    return `<img${before} src=${quote}${imageSrc}${quote}${after} alt="${altValue}">`;
  });
}

const fallbackAlt = data?.title ? escapeHtml(String(data.title)) : 'Ilustrace k článku';
content = content.replace(/<img([^>]*?)\salt=(\"|\')\2/gi, `<img$1 alt="${fallbackAlt}"`);

// Ensure spacing around inline links to avoid joined words in rendered text.
content = content.replace(/([\p{L}\p{N}])(<a\s)/gu, '$1 $2');
content = content.replace(/(<\/a>)([\p{L}\p{N}])/gu, '$1 $2');

const scripts: string[] = [];
content = content.replace(/<script\b[^>]*>([\s\S]*?)<\/script>/gi, (_match, scriptBody) => {
  scripts.push(scriptBody.trim());
  return '';
});
---

<Fragment set:html={content} />

{scripts.map((scriptBody) => (
  <script is:inline set:html={scriptBody}></script>
))}
